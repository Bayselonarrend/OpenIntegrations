pipeline {
    agent any
    stages {

        stage('Sync add-ins') {
            steps {
                bat 'git fetch origin addins --depth=1 && git restore --source=origin/addins --worktree -- .'
            }
        }

        stage('Upload') {
            steps {               
                bat encoding: 'UTF-8', script:'chcp 65001 & oscript ./ci/os/internal/Classes/SourceForgeUploader.os'
            }
        }
    }
}