pipeline {
    agent any
    stages {

        stage('Sync add-ins') {
            steps {
                bat 'call src\\addins\\sync-addins.bat'
            }
        }

        stage('Upload') {
            steps {               
                bat encoding: 'UTF-8', script:'chcp 65001 & oscript ./ci/os/internal/Classes/SourceForgeUploader.os'
            }
        }
    }
}