pipeline {
    agent {
        label 'windows'
    }
    stages {
        stage('Sync add-ins') {
            steps {
                bat 'call src\\addins\\sync-addins.bat'
            }
        }

        stage('Deploy') {
            steps {
                bat encoding: 'UTF-8', script:'oscript ./ci/os/DocsDeployScript.os test ru'
            }
        }
    }
}