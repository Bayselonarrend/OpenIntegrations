def runCommand(String command) {
    if (isUnix()) {
        sh(script: command)
    } else {
        bat(script: command)
    }
}

pipeline {
    agent {
        label 'Rpm-Agent'  // Имя или метка агента
    }
	parameters {
		booleanParam(name: 'Core', defaultValue: true, description: 'Run Core tests')
		booleanParam(name: 'Telegram', defaultValue: true, description: 'Run Telegram tests')
		booleanParam(name: 'VK', defaultValue: true, description: 'Run VK tests')
		booleanParam(name: 'Viber', defaultValue: true, description: 'Run Viber tests')
		booleanParam(name: 'FTP', defaultValue: true, description: 'Run FTP tests')
		booleanParam(name: 'SSH', defaultValue: true, description: 'Run SSH tests')
		booleanParam(name: 'SFTP', defaultValue: true, description: 'Run SFTP tests')
		booleanParam(name: 'PostgreSQL', defaultValue: true, description: 'Run PostgreSQL tests')
		booleanParam(name: 'MySQL', defaultValue: true, description: 'Run MySQL tests')
		booleanParam(name: 'MSSQL', defaultValue: true, description: 'Run MSSQL tests')
		booleanParam(name: 'SQLite', defaultValue: true, description: 'Run SQLite tests')
		booleanParam(name: 'MongoDB', defaultValue: true, description: 'Run MongoDB tests')
		booleanParam(name: 'RCON', defaultValue: true, description: 'Run RCON tests')
		booleanParam(name: 'YandexDisk', defaultValue: true, description: 'Run YandexDisk tests')
		booleanParam(name: 'GoogleWorkspace', defaultValue: true, description: 'Run GoogleWorkspace tests')
		booleanParam(name: 'GoogleCalendar', defaultValue: true, description: 'Run GoogleCalendar tests')
		booleanParam(name: 'GoogleDrive', defaultValue: true, description: 'Run GoogleDrive tests')
		booleanParam(name: 'GoogleSheets', defaultValue: true, description: 'Run GoogleSheets tests')
		booleanParam(name: 'Notion', defaultValue: true, description: 'Run Notion tests')
		booleanParam(name: 'Slack', defaultValue: true, description: 'Run Slack tests')
		booleanParam(name: 'Airtable', defaultValue: true, description: 'Run Airtable tests')
		booleanParam(name: 'Dropbox', defaultValue: true, description: 'Run Dropbox tests')
		booleanParam(name: 'Bitrix24', defaultValue: true, description: 'Run Bitrix24 tests')
		booleanParam(name: 'VKTeams', defaultValue: true, description: 'Run VKTeams tests')
		booleanParam(name: 'Neocities', defaultValue: true, description: 'Run Neocities tests')
		booleanParam(name: 'CDEK', defaultValue: true, description: 'Run CDEK tests')
		booleanParam(name: 'YandexMetrika', defaultValue: true, description: 'Run YandexMetrika tests')
		booleanParam(name: 'S3', defaultValue: true, description: 'Run S3 tests')
		booleanParam(name: 'TCP', defaultValue: true, description: 'Run TCP tests')
		booleanParam(name: 'WebSocket', defaultValue: true, description: 'Run WebSocket tests')
		booleanParam(name: 'ZeroMQ', defaultValue: true, description: 'Run ZeroMQ tests')
		booleanParam(name: 'GreenAPI', defaultValue: true, description: 'Run GreenAPI tests')
		booleanParam(name: 'GreenMax', defaultValue: true, description: 'Run GreenMax tests')
		booleanParam(name: 'Ollama', defaultValue: true, description: 'Run Ollama tests')
		booleanParam(name: 'HTTP', defaultValue: true, description: 'Run HTTP tests')
		booleanParam(name: 'OpenAI', defaultValue: true, description: 'Run OpenAI tests')
		booleanParam(name: 'ReportPortal', defaultValue: true, description: 'Run ReportPortal tests')
		booleanParam(name: 'GRPC', defaultValue: true, description: 'Run GRPC tests')
		booleanParam(name: 'ClickHouse', defaultValue: true, description: 'Run ClickHouse tests')
		booleanParam(name: 'RSS', defaultValue: true, description: 'Run RSS tests')
		booleanParam(name: 'MessagePack', defaultValue: true, description: 'Run MessagePack tests')
		booleanParam(name: 'Janx', defaultValue: true, description: 'Run Janx tests')
		booleanParam(name: 'Lua', defaultValue: true, description: 'Run Lua tests')
	}
	stages {

        stage('Sync add-ins') {
            steps {
                script {
                    if (isUnix()) {
                        sh 'bash src/addins/sync-addins.sh'
                    } else {
                        bat 'call src\\addins\\sync-addins.bat'
                    }
                }
            }
        }

        stage('Remove oint') {
            steps {
                script {
                    // Удаляем oint, если он установлен
                    sh 'rpm -e oint || echo "oint not installed"'
                }
            }
        }

        stage('Download oint package') {
            steps {
                script {
                    // Скачиваем новый rpm-пакет oint
                    sh 'wget -O oint-2.3.0-1.noarch_en.rpm https://jenkins.openintegrations.dev/job/OpiBuild/job/OpiRelease/lastSuccessfulBuild/artifact/2.3.0/oint-2.3.0-1.noarch_en.rpm '
                }
            }
        }

        stage('Install oint package') {
            steps {
                script {
                    // Устанавливаем скаченный пакет
                    sh 'rpm -ivh --replacepkgs oint-2.3.0-1.noarch_en.rpm'
                }
            }
        }

      	stage('Prepare'){
         		steps{
                    sh 'cd ./src/en/OInt && opm build && opm install oint-2.3.0.ospx && rm oint-2.3.0.ospx'
            		withCredentials([string(credentialsId: 'gpgkey', variable: 'GPGKEY')]) {
              			sh 'gpg --quiet --batch --yes --decrypt --passphrase="$GPGKEY" --output ./data.sqlite ./data.sqlite.gpg'
            		}
         		}
      	}
        stage('Create ReportPortal launch'){
				steps{
					sh 'oscript ./ci/os/internal/Classes/ReportPortalMethods.os start "CLI"'
				}
		}

		stage('Testing-Core') {
            when {
                expression { return params['Core'] }
            }
			steps {
				script {
					runModuleTests('./src/en/OInt/tests/Modules/OPItc_Core.os', [
'CheckIBToLastBuildCompliance',
'ValidateAdvancedCall',
					], true)
				}
			}
		}
		stage('Testing') {
			parallel {
		stage('Testing-Telegram') {
