def runCommand(String command) {
    if (isUnix()) {
        sh(script: command)
    } else {
        bat(script: command)
    }
}

def vrunnerLogHasPattern(String logFile, String pattern) {
    if (!fileExists(logFile)) {
        return false
    }

    def psPath = logFile.replace("'", "''")
    def psPattern = pattern.replace("'", "''")

    return bat(
        script: "powershell -NoProfile -Command \"if (Select-String -Path '${psPath}' -SimpleMatch -Pattern '${psPattern}' -Encoding UTF8 -Quiet) { exit 0 } else { exit 1 }\"",
        returnStatus: true
    ) == 0
}

def vrunnerLogIndicatesFailure(String logFile) {
    if (vrunnerLogHasPattern(logFile, 'Ошибка HTTP при обращении к серверу')) {
        return true
    }
    return vrunnerLogHasPattern(logFile, 'Не могу установить соединение')
}

def vrunnerLogIndicatesLicenseLimit(String logFile) {
    if (vrunnerLogHasPattern(logFile, 'Операция не может быть выполнена с текущим составом лицензий')) {
        return true
    }

    if (vrunnerLogHasPattern(logFile, 'Сеанс отсутствует или удален')) {
        return true
    }

    def enterpriseStarted = vrunnerLogHasPattern(logFile, 'Выполняю команду/действие в режиме 1С:Предприятие')
    def enterpriseFinished = vrunnerLogHasPattern(logFile, '1С:Предприятие завершено')
    def hasPlatformOutput = vrunnerLogHasPattern(logFile, 'Вывод платформы:')

    if (enterpriseStarted && enterpriseFinished && !hasPlatformOutput) {
        return true
    }

    return false
}

def noteVrunnerLog(String libraryName, String logFile) {
    if (fileExists(logFile)) {
        echo "vrunner log for ${libraryName}: ${logFile} (file kept on agent, not loaded into Jenkins console)"
    } else {
        echo "WARNING: vrunner log file not found: ${logFile}"
    }
}

def runLibraryTest(String libraryName, String configPath) {
    catchError(buildResult: 'FAILURE', stageResult: 'FAILURE') {
        script {
            def logFile = "./test_results/${libraryName}.vrunner.log"
            def codeFile = "./test_results/${libraryName}.code"
            def ibConnection = '/SDEVSRV/OpenIntegrationsEng'
            def vrunnerCmd = "\"D:/OneScript/bin/vrunner.bat\" run enterprise --nocacheuse --ibconnection ${ibConnection} --command \"RunUnitTests=${configPath}\""
            def maxLaunchAttempts = 60
            def exitCode = 0
            def licenseLimited = false

            echo "=== Starting ${libraryName} tests ==="
            echo "Command: ${vrunnerCmd}"

            for (int attempt = 1; attempt <= maxLaunchAttempts; attempt++) {
                if (attempt > 1) {
                    echo "${libraryName}: retry ${attempt}/${maxLaunchAttempts} after 60s pause (license/session issue in vrunner log)"
                    sleep(time: 60, unit: 'SECONDS')
                } else {
                    echo "${libraryName}: launch attempt 1/${maxLaunchAttempts}"
                }

                exitCode = bat(
                    script: "chcp 65001 >nul\r\n${vrunnerCmd} > \"${logFile}\" 2>&1",
                    returnStatus: true
                )

                noteVrunnerLog(libraryName, logFile)

                licenseLimited = vrunnerLogIndicatesLicenseLimit(logFile)

                if (!licenseLimited) {
                    echo "${libraryName}: vrunner log looks healthy on attempt ${attempt}"
                    break
                }

                echo "${libraryName}: license/session issue detected on attempt ${attempt}"
            }

            if (licenseLimited) {
                error "${libraryName}: vrunner blocked by license/session issue after ${maxLaunchAttempts} attempts"
            }

            if (vrunnerLogIndicatesFailure(logFile)) {
                error "vrunner failed for ${libraryName}: see ${logFile} on agent"
            }

            if (exitCode != 0) {
                error "vrunner exited with code ${exitCode} for ${libraryName}"
            }

            if (!fileExists(codeFile)) {
                try {
                    timeout(time: 5, unit: 'MINUTES') {
                        waitUntil(quiet: true, initialRecurrencePeriod: 3) {
                            fileExists(codeFile)
                        }
                    }
                } catch (Exception ignored) {
                    noteVrunnerLog(libraryName, logFile)
                    error "Test result file not found for ${libraryName} after vrunner completed"
                }
            }

            if (!fileExists(codeFile)) {
                noteVrunnerLog(libraryName, logFile)
                error "Test result file not found for ${libraryName}"
            }

            if (fileExists("./test_results/${libraryName}.report")) {
                def reportContent = readFile("./test_results/${libraryName}.report")
                echo "=== ${libraryName} report content ==="
                echo reportContent
                echo "=========================="
            } else {
                echo "WARNING: ${libraryName}.report file not found"
            }

            def testExitCode = readFile(codeFile).trim().replaceAll("[^0-9]", "")
            echo "Exit code for ${libraryName}: ${testExitCode}"
            if (testExitCode != "0") {
                error "Tests ${libraryName} failed with exit code: ${testExitCode}"
            }
        }
    }
}

pipeline {
	agent {
		label 'windows'
	}
	parameters {
		booleanParam(name: 'Core', defaultValue: true, description: 'Run Core tests')
		booleanParam(name: 'MongoDB', defaultValue: true, description: 'Run MongoDB tests')
	}
	stages {

		stage('Sync add-ins') {
			steps {
				script {
					if (isUnix()) {
						sh 'bash src/addins/sync-addins.sh'
					} else {
						bat 'call src\\addins\\sync-addins.bat'
					}
				}
			}
		}

		stage('Prepare Test Results Directory') {
            steps {
                script {
                    runCommand '''
                        if exist ".\\test_results" (
                            rmdir /s /q ".\\test_results"
                        )
                        mkdir ".\\test_results"
                    '''
                }
            }
        }

		stage('Create ReportPortal launch'){
				steps{
					bat encoding: 'UTF-8', script:'chcp 65001 & oscript ./ci/os/internal/Classes/ReportPortalMethods.os start "1C:Enterprise"'
				}
		}

		stage('Testing-Core') {
            when {
                expression { return params['Core'] }
            }
			steps {
				script {
					runLibraryTest('Core', './service/yaxunit_conf/en/Core.json')

				}
			}
		}
		stage('Testing-MongoDB') {
            when {
                expression { return params['MongoDB'] }
            }
			steps {
				script {
					catchError(buildResult: 'FAILURE', stageResult: 'FAILURE') {
						runLibraryTest('MongoDB', './service/yaxunit_conf/en/MongoDB.json')
					}

				}
			}
		}

	}
	post{
		always{
			script {
				catchError() {
				    runCommand('oscript ./ci/os/internal/Classes/ReportPortalMethods.os stop')
			    }
			}
		}
	}
}
