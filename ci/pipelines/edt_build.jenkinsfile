pipeline {
    agent { label 'windows' }
    stages {

        stage('Sync add-ins') {
            steps {
                bat 'call src\\addins\\sync-addins.bat'
            }
        }
     
        stage('Build') {
            steps {
                bat 'oscript ./ci/os/internal/Classes/IBUpdater.os'
            }
        }
    }
}