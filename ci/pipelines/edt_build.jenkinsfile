pipeline {
    agent { label 'windows' }
    stages {

        stage('Sync add-ins') {
            steps {
                bat 'git fetch origin addins --depth=1 && git restore --source=origin/addins --worktree -- .'
            }
        }
     
        stage('Build') {
            steps {
                bat 'oscript ./ci/os/internal/Classes/IBUpdater.os'
            }
        }
    }
}