{
 "module": "OPI_7z",
 "library": "7z",
 "self_depend": false,
 "dependencies": null,
 "cli_tool": false,
 "path": "formats/7z/Modules/OPI_7z.os",
 "regions": [
  {
   "name": "Archiving",
   "methods": [
    "ArchiveDirectory",
    "GetArchivingSettingsStructure",
    "UnarchiveDirectory"
   ]
  }
 ],
 "methods": [
  {
   "name": "ArchiveDirectory",
   "id": "ARCHIVEDIRECTORY",
   "description": "Packs files from the specified directory into an archive",
   "params": [
    {
     "name": "--src",
     "types": "String",
     "description": "Path to directory for archiving",
     "default": null,
     "short": "-s"
    },
    {
     "name": "--dest",
     "types": "String",
     "description": "Path to save the archive. As binary data if not filled",
     "default": "Empty value",
     "short": "-d"
    },
    {
     "name": "--settings",
     "types": "Map Of KeyAndValue",
     "description": "Additional settings. See GetArchivingSettingsStructure",
     "default": "Empty value",
     "short": "-t"
    }
   ],
   "region": "Archiving"
  },
  {
   "name": "UnarchiveDirectory",
   "id": "UNARCHIVEDIRECTORY",
   "description": "Unpacks 7z archive to the specified directory",
   "params": [
    {
     "name": "--src",
     "types": "String",
     "description": "Path to archive",
     "default": null,
     "short": "-s"
    },
    {
     "name": "--dest",
     "types": "String",
     "description": "Path to unpacking directory",
     "default": null,
     "short": "-d"
    },
    {
     "name": "--password",
     "types": "String",
     "description": "archive password, if required",
     "default": "Empty value",
     "short": "-p"
    }
   ],
   "region": "Archiving"
  },
  {
   "name": "GetArchivingSettingsStructure",
   "id": "GETARCHIVINGSETTINGSSTRUCTURE",
   "description": "Gets a structure with additional data archiving settings",
   "params": [
    {
     "name": "--empty",
     "types": "Boolean",
     "description": "True > structure with empty valuse, False > field descriptions at values",
     "default": "false",
     "short": "-e"
    },
    {
     "name": "--map",
     "types": "Boolean",
     "description": "True > returns the filter fields as a map",
     "default": "false",
     "short": "-m"
    }
   ],
   "region": "Archiving"
  }
 ]
}