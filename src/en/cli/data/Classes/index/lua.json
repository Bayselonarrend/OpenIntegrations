{
 "module": "OPI_Lua",
 "library": "lua",
 "self_depend": true,
 "dependencies": null,
 "cli_tool": false,
 "path": "api/lua/Modules/OPI_Lua.os",
 "regions": [
  {
   "name": "Script management",
   "methods": [
    "CallScriptFunction"
   ]
  },
  {
   "name": "Bytecode management",
   "methods": [
    "CallByteCodeFunction",
    "CompileCodeFromFile",
    "CompileCodeFromString"
   ]
  }
 ],
 "methods": [
  {
   "name": "CallScriptFunction",
   "id": "CALLSCRIPTFUNCTION",
   "description": "Executes Lua code from a string or file and calls the specified function",
   "params": [
    {
     "name": "--lua",
     "types": "Arbitrary",
     "description": "Lua AddIn or Lua version to run",
     "default": null,
     "short": "-l"
    },
    {
     "name": "--script",
     "types": "String",
     "description": "Lua code or file path",
     "default": null,
     "short": "-s"
    },
    {
     "name": "--func",
     "types": "String",
     "description": "Function name or path in module.func format",
     "default": null,
     "short": "-f"
    },
    {
     "name": "--params",
     "types": "Map Of KeyAndValue",
     "description": "Function parameters, if necessary",
     "default": "Empty value",
     "short": "-p"
    },
    {
     "name": "--packages",
     "types": "Map Of KeyAndValue",
     "description": "Packages: key > name, value > code or file path",
     "default": "Empty value",
     "short": "-c"
    },
    {
     "name": "--globals",
     "types": "Map Of KeyAndValue",
     "description": "Module global variables, if necessary",
     "default": "Empty value",
     "short": "-g"
    }
   ],
   "region": "Script management"
  },
  {
   "name": "CompileCodeFromString",
   "id": "COMPILECODEFROMSTRING",
   "description": "Converts source code to Lua bytecode",
   "params": [
    {
     "name": "--lua",
     "types": "Arbitrary",
     "description": "Lua AddIn or Lua version to run",
     "default": null,
     "short": "-l"
    },
    {
     "name": "--code",
     "types": "String",
     "description": "Source code for compilation",
     "default": null,
     "short": "-c"
    }
   ],
   "region": "Bytecode management"
  },
  {
   "name": "CompileCodeFromFile",
   "id": "COMPILECODEFROMFILE",
   "description": "Converts a source code file to Lua bytecode",
   "params": [
    {
     "name": "--lua",
     "types": "Arbitrary",
     "description": "Lua AddIn or Lua version to run",
     "default": null,
     "short": "-l"
    },
    {
     "name": "--path",
     "types": "String",
     "description": "Script file path",
     "default": null,
     "short": "-p"
    }
   ],
   "region": "Bytecode management"
  },
  {
   "name": "CallByteCodeFunction",
   "id": "CALLBYTECODEFUNCTION",
   "description": "Executes bytecode and calls the specified function",
   "params": [
    {
     "name": "--lua",
     "types": "Arbitrary",
     "description": "Lua AddIn or Lua version to run",
     "default": null,
     "short": "-l"
    },
    {
     "name": "--code",
     "types": "String, BinaryData",
     "description": "Byte code or file path",
     "default": null,
     "short": "-c"
    },
    {
     "name": "--func",
     "types": "String",
     "description": "Function name or path in module.func format",
     "default": null,
     "short": "-f"
    },
    {
     "name": "--params",
     "types": "Map Of KeyAndValue",
     "description": "Function parameters, if necessary",
     "default": "Empty value",
     "short": "-p"
    },
    {
     "name": "--packages",
     "types": "Map Of KeyAndValue",
     "description": "Packages: key > name, value > code or file path",
     "default": "Empty value",
     "short": "-k"
    },
    {
     "name": "--globals",
     "types": "Map Of KeyAndValue",
     "description": "Module global variables, if necessary",
     "default": "Empty value",
     "short": "-g"
    }
   ],
   "region": "Bytecode management"
  }
 ]
}