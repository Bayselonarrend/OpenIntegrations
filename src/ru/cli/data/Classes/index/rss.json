			"name": "СоздатьФидRSS",
			"id": "СОЗДАТЬФИДRSS",
			"description": "Создает текст RSS фида\n\n    Дата указывается в формате ISO 8601:\n    \"2024-04-07\"\n    \"2024-04-07T13:34:42+00:00\" \n    \"2024-04-07T13:34:42Z\"\n\n\n    Пример указания параметра типа массив:\n    --param \"['Val1','Val2','Val3']\"\n",
			"params": [
				{
					"name": "--name",
					"types": "Строка",
					"description": "Название канала",
					"default": null,
					"short": "-n"
				},
				{
					"name": "--descr",
					"types": "Строка",
					"description": "Описание канала",
					"default": null,
					"short": "-d"
				},
				{
					"name": "--link",
					"types": "Строка",
					"description": "Ссылка канала",
					"default": null,
					"short": "-l"
				},
				{
					"name": "--items",
					"types": "Массив Из Структура",
					"description": "Элементы фида. См. ПолучитьСтруктуруЭлементаФидаRSS",
					"default": null,
					"short": "-i"
				},
				{
					"name": "--date",
					"types": "Дата, Неопределено",
					"description": "Дата обновления. Текущая, если не заполнено",
					"default": "Пустое значение",
					"short": "-t"
				}
			],
			"region": "Основные методы"
		},
		{
			"name": "ПолучитьСтруктуруЭлементаФидаRSS",
			"id": "ПОЛУЧИТЬСТРУКТУРУЭЛЕМЕНТАФИДАRSS",
			"description": "Получает структуру параметров элемента RSS фида",
			"params": [
				{
					"name": "--empty",
					"types": "Булево",
					"description": "Истина > структура с пустыми значениями, Ложь > в значениях будут описания полей",
					"default": "false",
					"short": "-e"
				},
				{
					"name": "--map",
					"types": "Булево",
