    Опции.Вставить("testapi", Истина);

    Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("cdek", "ПолучитьЗаказ", Опции);

    // END

    OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "CDEK", "ПолучитьЗаказ", , ПараметрыФункции);

