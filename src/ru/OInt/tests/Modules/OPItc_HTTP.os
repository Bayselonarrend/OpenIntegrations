        .ВернутьИмяФайлаТелаОтвета();

    // END

    OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "HTTP", "ВернутьИмяФайлаТелаОтвета", , ИВФ);

    OPI_Инструменты.УдалитьФайлВПопытке(ИВФ, "Не удалось удалить временный файл после теста!");

