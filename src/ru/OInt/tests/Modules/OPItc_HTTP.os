Процедура HTTP_ВернутьИмяФайлаТелаОтвета(ПараметрыФункции)

    URL = ПараметрыФункции["HTTP_URL"];
    URL = URL + "/get";

    ИВФ = ПолучитьИмяВременногоФайла();

    Результат = OPI_ЗапросыHTTP.НовыйЗапрос()
        .Инициализировать(URL)
        .УстановитьФайлОтвета(ИВФ) // <---
