Процедура HTTP_ВернутьНастройки(ПараметрыФункции)

    Результат = OPI_ЗапросыHTTP.НовыйЗапрос()
        .Инициализировать()
        .ВернутьНастройки();

    // END

    OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "HTTP", "ВернутьНастройки");

    Результат = OPI_ЗапросыHTTP.НовыйЗапрос()
        .Инициализировать()
        .ВернутьНастройки("КодировкаТелаЗапроса");

    OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "HTTP", "ВернутьНастройки", "Одиночный");

    МассивНастроек = Новый Массив;
    МассивНастроек.Добавить("МаксимумПопыток");
    МассивНастроек.Добавить("МаксимумПереадресаций");

    Результат = OPI_ЗапросыHTTP.НовыйЗапрос()
        .Инициализировать()
        .МаксимумПопыток(5)
        .ВернутьНастройки(МассивНастроек);

    OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "HTTP", "ВернутьНастройки", "Массив");

    Результат = OPI_ЗапросыHTTP.НовыйЗапрос()
        .Инициализировать()
        .ВернутьНастройки("ААА");

    OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "HTTP", "ВернутьНастройки", "Несуществующий");

КонецПроцедуры

