// Набор тестов для YAxUnit

// BSLLS:Typo-off
// BSLLS:LatinAndCyrillicSymbolInWord-off
// BSLLS:IncorrectLineBreak-off
// BSLLS:UsingServiceTag-off
// BSLLS:UnusedParameters-off
// BSLLS:DuplicateStringLiteral-off
// BSLLS:UsingHardcodePath-off
// BSLLS:UnusedLocalVariable-off
// BSLLS:DeprecatedMessage-off
// BSLLS:LineLength-off
// BSLLS:MagicNumber-off
// BSLLS:CommentedCode-off
// BSLLS:AssignAliasFieldsInQuery-off
// BSLLS:UsingHardcodeNetworkAddress-off
// BSLLS:UnreachableCode-off
// BSLLS:UnusedLocalMethod-off
// BSLLS:NestedFunctionInParameters-off
// BSLLS:MissingTemporaryFileDeletion-off
// BSLLS:UsingSynchronousCalls-off
// BSLLS:MagicDate-off
// BSLLS:MissingParameterDescription-off
// BSLLS:NumberOfOptionalParams-off
// BSLLS:MethodSize-off
// BSLLS:NestedConstructorsInStructureDeclaration-off
// BSLLS:NumberOfValuesInStructureConstructor-off
// BSLLS:UsingHardcodeSecretInformation-off
// BSLLS:SpaceAtStartComment-off

//@skip-check undefined-variable
//@skip-check wrong-string-literal-content
//@skip-check module-structure-top-region
//@skip-check module-structure-method-in-regions
//@skip-check undefined-function-or-procedure
//@skip-check module-unused-local-variable
//@skip-check bsl-legacy-check-string-literal
//@skip-check bsl-legacy-check-method-for-statements-after-return
//@skip-check missing-temporary-file-deletion
//@skip-check module-unused-method

#Использовать oint
#Использовать asserts
#Использовать "internal"

// Для YaxUnit

Процедура ИсполняемыеСценарии() Экспорт

    OPI_ПолучениеДанныхТестов.СформироватьТестыЯкс("7z");

КонецПроцедуры

// Для Asserts

Функция ПолучитьСписокТестов(ЮнитТестирование) Экспорт

    Возврат OPI_ПолучениеДанныхТестов.СформироватьТестыАссертс("7z");

КонецФункции

#Область СлужебныйПрограммныйИнтерфейс

#Область ЗапускаемыеТесты

Процедура Z7_Архивация() Экспорт

    КаталогБазы = КаталогВременныхФайлов()
        + ПолучитьРазделительПути()
        + "opi_sevenz_"
        + Формат(ТекущаяУниверсальнаяДатаВМиллисекундах(), "ЧГ=0");

    КаталогИсточник         = Путь7z(КаталогБазы, "src");
    КаталогИсточникПароль   = Путь7z(КаталогБазы, "src_pwd");
    КаталогИсточникСжатие   = Путь7z(КаталогБазы, "src_compress");
    КаталогНазначение       = Путь7z(КаталогБазы, "out");
    КаталогНазначениеБуфер  = Путь7z(КаталогБазы, "out_buffer");
    КаталогНазначениеПароль = Путь7z(КаталогБазы, "out_pwd");
    ПутьАрхива              = Путь7z(КаталогБазы, "archive.7z");
    ПутьАрхиваОписание      = Путь7z(КаталогБазы, "archive_desc.7z");
    ПутьАрхиваПароль        = Путь7z(КаталогБазы, "archive_pwd.7z");
    ПутьАрхиваБуфер         = Путь7z(КаталогБазы, "archive_buffer.7z");
    ПутьАрхиваCopy          = Путь7z(КаталогБазы, "archive_copy.7z");
    ПутьАрхиваLzma          = Путь7z(КаталогБазы, "archive_lzma.7z");
    ПутьНовогоФайла         = Путь7z(КаталогБазы, "extra_info.txt");

    СоздатьКаталог(КаталогБазы);
    СоздатьКаталог(КаталогИсточник);
    СоздатьКаталог(КаталогИсточникПароль);
    СоздатьКаталог(КаталогИсточникСжатие);
    СоздатьКаталог(КаталогНазначение);
    СоздатьКаталог(КаталогНазначениеБуфер);
    СоздатьКаталог(КаталогНазначениеПароль);

    ПолучитьДвоичныеДанныеИзСтроки("OpenIntegrations root", "UTF-8").Записать(Путь7z(КаталогИсточник, "readme.txt"));

    СоздатьКаталог(Путь7z(КаталогИсточник, "docs"));
    ПолучитьДвоичныеДанныеИзСтроки("Nested documentation", "UTF-8").Записать(Путь7z(КаталогИсточник, "docs\note.txt"));

    СоздатьКаталог(Путь7z(КаталогИсточник, "data\nested"));
    ОписаниеБинарника = Новый Структура("binary, hex", Истина, "0102030405");
    ПолучитьДвоичныеДанныеИзHexСтроки("0102030405").Записать(Путь7z(КаталогИсточник, "data\nested\payload.bin"));

    СоздатьКаталог(Путь7z(КаталогИсточник, "config"));
    ПолучитьДвоичныеДанныеИзСтроки("{""enabled"": true}", "UTF-8").Записать(Путь7z(КаталогИсточник, "config\settings.json"));

    ПолучитьДвоичныеДанныеИзСтроки("Protected content", "UTF-8").Записать(Путь7z(КаталогИсточникПароль, "secret.txt"));
    ПолучитьДвоичныеДанныеИзСтроки("Added via path"   , "UTF-8").Записать(ПутьНовогоФайла);

    Фрагмент    = "ABCD1234EFGH5678";
    ТекстСжатия = "";

    Для Индекс = 1 По 2000 Цикл
        ТекстСжатия = ТекстСжатия + Фрагмент;
    КонецЦикла;

    ПолучитьДвоичныеДанныеИзСтроки(ТекстСжатия, "UTF-8").Записать(Путь7z(КаталогИсточникСжатие, "compressible.txt"));
    ПолучитьДвоичныеДанныеИзСтроки(ТекстСжатия, "UTF-8").Записать(Путь7z(КаталогИсточникСжатие, "compressible2.txt"));

    ОжидаемыеФайлы = Новый Соответствие;
    ОжидаемыеФайлы.Вставить("readme.txt"             , "OpenIntegrations root");
    ОжидаемыеФайлы.Вставить("docs\note.txt"          , "Nested documentation");
    ОжидаемыеФайлы.Вставить("data\nested\payload.bin", ОписаниеБинарника);
    ОжидаемыеФайлы.Вставить("config\settings.json"   , "{""enabled"": true}");

    ОжидаемыеПароль = Новый Соответствие;
    ОжидаемыеПароль.Вставить("secret.txt", "Protected content");

    ОжидаемыеСжатие = Новый Соответствие;
    ОжидаемыеСжатие.Вставить("compressible.txt" , ТекстСжатия);
    ОжидаемыеСжатие.Вставить("compressible2.txt", ТекстСжатия);

    ОжидаемыеЧастичные = Новый Соответствие;
    ОжидаемыеЧастичные.Вставить("readme.txt"   , "OpenIntegrations root");
    ОжидаемыеЧастичные.Вставить("docs\note.txt", "Nested documentation");

    ПутиЧастичные = Новый Массив;
    ПутиЧастичные.Добавить("readme.txt");
    ПутиЧастичные.Добавить("docs/note.txt");

    ОжидаемыеПослеИзменения = Новый Соответствие;
    ОжидаемыеПослеИзменения.Вставить("readme.txt"             , "Replaced readme content");
    ОжидаемыеПослеИзменения.Вставить("docs\note.txt"          , "Nested documentation");
    ОжидаемыеПослеИзменения.Вставить("data\nested\payload.bin", ОписаниеБинарника);
    ОжидаемыеПослеИзменения.Вставить("extra\info.txt"         , "Added via path");

    ЗаписиОписания = Новый Массив;

    ЭлементReadme = Новый Соответствие;
    ЭлементReadme.Вставить("name"     , "readme.txt");
    ЭлементReadme.Вставить("directory", Ложь);
    ЭлементReadme.Вставить("from_path", Истина);
    ЭлементReadme.Вставить("path"     , Путь7z(КаталогИсточник, "readme.txt"));
    ЗаписиОписания.Добавить(ЭлементReadme);

    ЗаписиDocs  = Новый Массив;
    ЭлементNote = Новый Соответствие;
    ЭлементNote.Вставить("name"     , "note.txt");
    ЭлементNote.Вставить("directory", Ложь);
    ЭлементNote.Вставить("from_path", Истина);
    ЭлементNote.Вставить("path"     , Путь7z(КаталогИсточник, "docs\note.txt"));
    ЗаписиDocs.Добавить(ЭлементNote);

    ЭлементDocs = Новый Соответствие;
    ЭлементDocs.Вставить("name"     , "docs");
    ЭлементDocs.Вставить("directory", Истина);
    ЭлементDocs.Вставить("entries"  , ЗаписиDocs);
    ЗаписиОписания.Добавить(ЭлементDocs);

    ЗаписиData     = Новый Массив;
    ЭлементPayload = Новый Соответствие;
    ЭлементPayload.Вставить("name"     , "payload.bin");
    ЭлементPayload.Вставить("directory", Ложь);
    ЭлементPayload.Вставить("from_path", Истина);
    ЭлементPayload.Вставить("path"     , Путь7z(КаталогИсточник, "data\nested\payload.bin"));
    ЗаписиData.Добавить(ЭлементPayload);

    ЭлементData   = Новый Соответствие;
    ЭлементData.Вставить("name"     , "data");
    ЭлементData.Вставить("directory", Истина);
    ЗаписиNested  = Новый Массив;
    ЭлементNested = Новый Соответствие;
    ЭлементNested.Вставить("name"     , "nested");
    ЭлементNested.Вставить("directory", Истина);
    ЭлементNested.Вставить("entries"  , ЗаписиData);
    ЗаписиNested.Добавить(ЭлементNested);
    ЭлементData.Вставить("entries"  , ЗаписиNested);
    ЗаписиОписания.Добавить(ЭлементData);

    ЗаписиConfig    = Новый Массив;
    ЭлементSettings = Новый Соответствие;
    ЭлементSettings.Вставить("name"     , "settings.json");
    ЭлементSettings.Вставить("directory", Ложь);
    ЭлементSettings.Вставить("from_path", Истина);
    ЭлементSettings.Вставить("path"     , Путь7z(КаталогИсточник, "config\settings.json"));
    ЗаписиConfig.Добавить(ЭлементSettings);

    ЭлементConfig = Новый Соответствие;
    ЭлементConfig.Вставить("name"     , "config");
    ЭлементConfig.Вставить("directory", Истина);
    ЭлементConfig.Вставить("entries"  , ЗаписиConfig);
    ЗаписиОписания.Добавить(ЭлементConfig);

    ОписаниеАрхива = Новый Соответствие;
    ОписаниеАрхива.Вставить("entries", ЗаписиОписания);

    Параметры = Новый Структура;
    Параметры.Вставить("SevenZ_BaseDir"              , КаталогБазы);
    Параметры.Вставить("SevenZ_SourceDir"            , КаталогИсточник);
    Параметры.Вставить("SevenZ_SourceDirPassword"    , КаталогИсточникПароль);
    Параметры.Вставить("SevenZ_SourceDirCompress"    , КаталогИсточникСжатие);
    Параметры.Вставить("SevenZ_ArchivePath"          , ПутьАрхива);
    Параметры.Вставить("SevenZ_ArchiveDescPath"      , ПутьАрхиваОписание);
    Параметры.Вставить("SevenZ_ArchivePasswordPath"  , ПутьАрхиваПароль);
    Параметры.Вставить("SevenZ_ArchiveBufferPath"    , ПутьАрхиваБуфер);
    Параметры.Вставить("SevenZ_ArchiveCopyPath"      , ПутьАрхиваCopy);
    Параметры.Вставить("SevenZ_ArchiveLzmaPath"      , ПутьАрхиваLzma);
    Параметры.Вставить("SevenZ_DestDir"              , КаталогНазначение);
    Параметры.Вставить("SevenZ_DestBufferDir"        , КаталогНазначениеБуфер);
    Параметры.Вставить("SevenZ_DestPasswordDir"      , КаталогНазначениеПароль);
    Параметры.Вставить("SevenZ_NewFilePath"          , ПутьНовогоФайла);
    Параметры.Вставить("SevenZ_Description"          , ОписаниеАрхива);
    Параметры.Вставить("SevenZ_Password"             , "OPI_Test7zPwd");
    Параметры.Вставить("SevenZ_ExpectedFiles"        , ОжидаемыеФайлы);
    Параметры.Вставить("SevenZ_ExpectedPassword"     , ОжидаемыеПароль);
    Параметры.Вставить("SevenZ_ExpectedCompress"     , ОжидаемыеСжатие);
    Параметры.Вставить("SevenZ_PartialPaths"         , ПутиЧастичные);
    Параметры.Вставить("SevenZ_PartialExpected"      , ОжидаемыеЧастичные);
    Параметры.Вставить("SevenZ_ExpectedAfterModify"  , ОжидаемыеПослеИзменения);

    OPI_ПолучениеДанныхТестов.ЗаписатьПараметрыАрхива(Параметры);

    Z7_ПолучитьСтруктуруНастроекАрхивации();
    Z7_ПолучитьСтруктуруИзмененияАрхива();
    Z7_АрхивироватьКаталог(Параметры);
    Z7_РазархивироватьКаталог(Параметры);
    Z7_РазархивироватьФайлы(Параметры);
    Z7_ИзменитьАрхив(Параметры);

    OPI_Инструменты.УдалитьФайлВПопытке(КаталогБазы, "Не удалось удалить каталог теста 7z");

КонецПроцедуры

Процедура Z7_ПолучениеМетаданных() Экспорт

    КаталогБазы = КаталогВременныхФайлов()
        + ПолучитьРазделительПути()
        + "opi_sevenz_meta_"
        + Формат(ТекущаяУниверсальнаяДатаВМиллисекундах(), "ЧГ=0");

    КаталогИсточник       = Путь7z(КаталогБазы, "src");
    КаталогИсточникПароль = Путь7z(КаталогБазы, "src_pwd");
    КаталогИсточникСжатие = Путь7z(КаталогБазы, "src_compress");
    ПутьАрхива            = Путь7z(КаталогБазы, "archive.7z");
    ПутьАрхиваПароль      = Путь7z(КаталогБазы, "archive_pwd.7z");
    ПутьАрхиваCopy        = Путь7z(КаталогБазы, "archive_copy.7z");
    ПутьАрхиваLzma        = Путь7z(КаталогБазы, "archive_lzma.7z");

    СоздатьКаталог(КаталогБазы);
    СоздатьКаталог(КаталогИсточник);
    СоздатьКаталог(КаталогИсточникПароль);
    СоздатьКаталог(КаталогИсточникСжатие);

    ПолучитьДвоичныеДанныеИзСтроки("7z metadata test", "UTF-8").Записать(Путь7z(КаталогИсточник, "readme.txt"));

    СоздатьКаталог(Путь7z(КаталогИсточник, "docs"));
    ПолучитьДвоичныеДанныеИзСтроки("Nested file", "UTF-8").Записать(Путь7z(КаталогИсточник, "docs\note.txt"));

    ПолучитьДвоичныеДанныеИзСтроки("Protected content", "UTF-8").Записать(Путь7z(КаталогИсточникПароль, "secret.txt"));

    Фрагмент    = "ABCD1234EFGH5678";
    ТекстСжатия = "";

    Для Индекс = 1 По 2000 Цикл
        ТекстСжатия = ТекстСжатия + Фрагмент;
    КонецЦикла;

    ПолучитьДвоичныеДанныеИзСтроки(ТекстСжатия, "UTF-8").Записать(Путь7z(КаталогИсточникСжатие, "compressible.txt"));
    ПолучитьДвоичныеДанныеИзСтроки(ТекстСжатия, "UTF-8").Записать(Путь7z(КаталогИсточникСжатие, "compressible2.txt"));

    OPI_7z.АрхивироватьКаталог(КаталогИсточник, ПутьАрхива);

    НастройкиПароль                   = OPI_7z.ПолучитьСтруктуруНастроекАрхивации(Истина);
    НастройкиПароль["password"]       = "OPI_Test7zPwd";
    НастройкиПароль["encrypt_header"] = Истина;

    OPI_7z.АрхивироватьКаталог(КаталогИсточникПароль, ПутьАрхиваПароль, НастройкиПароль);

    НастройкиCopy           = OPI_7z.ПолучитьСтруктуруНастроекАрхивации(Истина);
    НастройкиCopy["method"] = "Copy";

    OPI_7z.АрхивироватьКаталог(КаталогИсточникСжатие, ПутьАрхиваCopy, НастройкиCopy);

    НастройкиLzma           = OPI_7z.ПолучитьСтруктуруНастроекАрхивации(Истина);
    НастройкиLzma["method"] = "Lzma2";
    НастройкиLzma["level"]  = 9;
    НастройкиLzma["solid"]  = Истина;

    OPI_7z.АрхивироватьКаталог(КаталогИсточникСжатие, ПутьАрхиваLzma, НастройкиLzma);

    ОжидаемыеФайлы = Новый Соответствие;
    ОжидаемыеФайлы.Вставить("readme.txt"   , "7z metadata test");
    ОжидаемыеФайлы.Вставить("docs\note.txt", "Nested file");

    ОжидаемыеПароль = Новый Соответствие;
    ОжидаемыеПароль.Вставить("secret.txt", "Protected content");

    ОжидаемыеСжатие = Новый Соответствие;
    ОжидаемыеСжатие.Вставить("compressible.txt" , ТекстСжатия);
    ОжидаемыеСжатие.Вставить("compressible2.txt", ТекстСжатия);

    Параметры = Новый Структура;
    Параметры.Вставить("SevenZ_BaseDir"            , КаталогБазы);
    Параметры.Вставить("SevenZ_ArchivePath"        , ПутьАрхива);
    Параметры.Вставить("SevenZ_ArchivePasswordPath", ПутьАрхиваПароль);
    Параметры.Вставить("SevenZ_ArchiveCopyPath"    , ПутьАрхиваCopy);
    Параметры.Вставить("SevenZ_ArchiveLzmaPath"    , ПутьАрхиваLzma);
    Параметры.Вставить("SevenZ_Password"           , "OPI_Test7zPwd");
    Параметры.Вставить("SevenZ_ExpectedFiles"      , ОжидаемыеФайлы);
    Параметры.Вставить("SevenZ_ExpectedPassword"   , ОжидаемыеПароль);
    Параметры.Вставить("SevenZ_ExpectedCompress"   , ОжидаемыеСжатие);

    OPI_ПолучениеДанныхТестов.ЗаписатьПараметрыАрхива(Параметры);

    Z7_ПолучитьСписокФайлов(Параметры);
    Z7_ПолучитьМетаданные(Параметры);

    OPI_Инструменты.УдалитьФайлВПопытке(КаталогБазы, "Не удалось удалить каталог теста 7z");

КонецПроцедуры

#КонецОбласти // ЗапускаемыеТесты

#КонецОбласти // СлужебныйПрограммныйИнтерфейс

#Область СлужебныеПроцедурыИФункции

#Область АтомарныеТесты

Процедура Z7_ПолучитьСтруктуруНастроекАрхивации()

    Результат = OPI_7z.ПолучитьСтруктуруНастроекАрхивации();

    // END

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "7z", "ПолучитьСтруктуруНастроекАрхивации");

    Результат = OPI_7z.ПолучитьСтруктуруНастроекАрхивации(Истина);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "7z", "ПолучитьСтруктуруНастроекАрхивации", "Пустая");

    Результат = OPI_7z.ПолучитьСтруктуруНастроекАрхивации(Ложь, Истина);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "7z", "ПолучитьСтруктуруНастроекАрхивации", "КакСоответствие");

КонецПроцедуры

Процедура Z7_ПолучитьСтруктуруИзмененияАрхива()

    Результат = OPI_7z.ПолучитьСтруктуруИзмененияАрхива();

    // END

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "7z", "ПолучитьСтруктуруИзмененияАрхива");

    Результат = OPI_7z.ПолучитьСтруктуруИзмененияАрхива(Истина);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "7z", "ПолучитьСтруктуруИзмененияАрхива", "Пустая");

    Результат = OPI_7z.ПолучитьСтруктуруИзмененияАрхива(Ложь, Истина);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "7z", "ПолучитьСтруктуруИзмененияАрхива", "КакСоответствие");

КонецПроцедуры

Процедура Z7_АрхивироватьКаталог(Параметры)

    OPI_ПолучениеДанныхТестов.ДополнитьПараметрыАрхива(Параметры, "SevenZ"); // SKIP

    КаталогИсточник = Параметры["SevenZ_SourceDir"];
    ПутьАрхива      = Параметры["SevenZ_ArchivePath"];

    Результат = OPI_7z.АрхивироватьКаталог(КаталогИсточник, ПутьАрхива);

    // END

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "7z", "АрхивироватьКаталог", , ПутьАрхива);

    Результат = OPI_7z.АрхивироватьКаталог(КаталогИсточник);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "7z", "АрхивироватьКаталог", "ВПамять");

    Описание       = Параметры["SevenZ_Description"];
    ПутьАрхиваDesc = Параметры["SevenZ_ArchiveDescPath"];

    Результат = OPI_7z.АрхивироватьКаталог(Описание, ПутьАрхиваDesc);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "7z", "АрхивироватьКаталог", "ИзОписания", ПутьАрхиваDesc);

    Результат = OPI_7z.АрхивироватьКаталог(Описание);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "7z", "АрхивироватьКаталог", "ИзОписанияВПамять");

    КаталогПароль               = Параметры["SevenZ_SourceDirPassword"];
    ПутьАрхиваПароль            = Параметры["SevenZ_ArchivePasswordPath"];
    Пароль                      = Параметры["SevenZ_Password"];
    Настройки                   = OPI_7z.ПолучитьСтруктуруНастроекАрхивации(Истина);
    Настройки["password"]       = Пароль;
    Настройки["encrypt_header"] = Истина;

    Результат = OPI_7z.АрхивироватьКаталог(КаталогПароль, ПутьАрхиваПароль, Настройки);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "7z", "АрхивироватьКаталог", "СПаролем", ПутьАрхиваПароль);

    КаталогСжатие  = Параметры["SevenZ_SourceDirCompress"];
    ПутьАрхиваCopy = Параметры["SevenZ_ArchiveCopyPath"];
    ПутьАрхиваLzma = Параметры["SevenZ_ArchiveLzmaPath"];

    НастройкиCopy           = OPI_7z.ПолучитьСтруктуруНастроекАрхивации(Истина);
    НастройкиCopy["method"] = "Copy";

    Результат = OPI_7z.АрхивироватьКаталог(КаталогСжатие, ПутьАрхиваCopy, НастройкиCopy);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "7z", "АрхивироватьКаталог", "Copy", ПутьАрхиваCopy);

    НастройкиLzma           = OPI_7z.ПолучитьСтруктуруНастроекАрхивации(Истина);
    НастройкиLzma["method"] = "Lzma2";
    НастройкиLzma["level"]  = 9;
    НастройкиLzma["solid"]  = Истина;

    Результат = OPI_7z.АрхивироватьКаталог(КаталогСжатие, ПутьАрхиваLzma, НастройкиLzma);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "7z", "АрхивироватьКаталог", "Lzma2Solid", ПутьАрхиваLzma);

КонецПроцедуры

Процедура Z7_РазархивироватьКаталог(Параметры)

    OPI_ПолучениеДанныхТестов.ДополнитьПараметрыАрхива(Параметры, "SevenZ"); // SKIP

    ПутьАрхива        = Параметры["SevenZ_ArchivePath"];
    КаталогНазначение = Параметры["SevenZ_DestDir"];

    Результат = OPI_7z.РазархивироватьКаталог(ПутьАрхива, КаталогНазначение);

    // END

    ОжидаемыеФайлы = Параметры["SevenZ_ExpectedFiles"];

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "7z", "РазархивироватьКаталог", , КаталогНазначение, ОжидаемыеФайлы);

    Результат = OPI_7z.РазархивироватьКаталог(ПутьАрхива);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "7z", "РазархивироватьКаталог", "ВОписание", "", ОжидаемыеФайлы);

    КаталогНазначениеБуфер = Параметры["SevenZ_DestBufferDir"];
    АрхивДвоичные          = Новый ДвоичныеДанные(ПутьАрхива);

    Результат = OPI_7z.РазархивироватьКаталог(АрхивДвоичные, КаталогНазначениеБуфер);
    OPI_ПолучениеДанныхТестов.Обработать(Результат
        , "7z"
        , "РазархивироватьКаталог"
        , "ИзПамяти"
        , КаталогНазначениеБуфер
        , ОжидаемыеФайлы);

    Результат = OPI_7z.РазархивироватьКаталог(АрхивДвоичные);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "7z", "РазархивироватьКаталог", "ВОписаниеИзПамяти", "", ОжидаемыеФайлы);

    Пароль           = Параметры["SevenZ_Password"];
    ПутьАрхиваПароль = Параметры["SevenZ_ArchivePasswordPath"];
    КаталогПароль    = Параметры["SevenZ_DestPasswordDir"];
    ОжидаемыеПароль  = Параметры["SevenZ_ExpectedPassword"];

    Результат = OPI_7z.РазархивироватьКаталог(ПутьАрхиваПароль, КаталогПароль, Пароль);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "7z", "РазархивироватьКаталог", "СПаролем", КаталогПароль, ОжидаемыеПароль);

    АрхивПароль = Новый ДвоичныеДанные(ПутьАрхиваПароль);

    Результат = OPI_7z.РазархивироватьКаталог(АрхивПароль, "", Пароль);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "7z", "РазархивироватьКаталог", "ВОписаниеСПаролем", "", ОжидаемыеПароль);

КонецПроцедуры

Процедура Z7_РазархивироватьФайлы(Параметры)

    OPI_ПолучениеДанныхТестов.ДополнитьПараметрыАрхива(Параметры, "SevenZ"); // SKIP

    ПутьАрхива        = Параметры["SevenZ_ArchivePath"];
    КаталогНазначение = Параметры["SevenZ_DestDir"];
    Пути              = Параметры["SevenZ_PartialPaths"];

    Результат = OPI_7z.РазархивироватьФайлы(ПутьАрхива, Пути, КаталогНазначение);

    // END

    ОжидаемыеФайлы = Параметры["SevenZ_PartialExpected"];

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "7z", "РазархивироватьФайлы", , КаталогНазначение, ОжидаемыеФайлы);

    Результат = OPI_7z.РазархивироватьФайлы(ПутьАрхива, Пути);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "7z", "РазархивироватьФайлы", "ВОписание", "", ОжидаемыеФайлы);

    КаталогНазначениеБуфер = Параметры["SevenZ_DestBufferDir"];
    АрхивДвоичные          = Новый ДвоичныеДанные(ПутьАрхива);

    Результат = OPI_7z.РазархивироватьФайлы(АрхивДвоичные, Пути, КаталогНазначениеБуфер);
    OPI_ПолучениеДанныхТестов.Обработать(Результат
        , "7z"
        , "РазархивироватьФайлы"
        , "ИзПамяти"
        , КаталогНазначениеБуфер
        , ОжидаемыеФайлы);

    Результат = OPI_7z.РазархивироватьФайлы(АрхивДвоичные, Пути);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "7z", "РазархивироватьФайлы", "ВОписаниеИзПамяти", "", ОжидаемыеФайлы);

КонецПроцедуры

Процедура Z7_ИзменитьАрхив(Параметры)

    OPI_ПолучениеДанныхТестов.ДополнитьПараметрыАрхива(Параметры, "SevenZ"); // SKIP

    ПутьАрхива      = Параметры["SevenZ_ArchivePath"];
    ПутьНовогоФайла = Параметры["SevenZ_NewFilePath"];

    ДобавляемыеФайлы = Новый Соответствие;
    ДобавляемыеФайлы.Вставить("extra/info.txt", ПутьНовогоФайла);
    ДобавляемыеФайлы.Вставить("readme.txt"    , ПолучитьДвоичныеДанныеИзСтроки("Replaced readme content", "UTF-8"));

    УдаляемыеПути = Новый Массив;
    УдаляемыеПути.Добавить("config/settings.json");
    УдаляемыеПути.Добавить("missing/path.txt");

    Результат = OPI_7z.ИзменитьАрхив(ПутьАрхива, ДобавляемыеФайлы, УдаляемыеПути);

    // END

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "7z", "ИзменитьАрхив", , ПутьАрхива);

    КаталогНазначение = Параметры["SevenZ_DestDir"];
    ОжидаемыеФайлы    = Параметры["SevenZ_ExpectedAfterModify"];

    СписокФайлов = OPI_7z.ПолучитьСписокФайлов(ПутьАрхива);
    OPI_ПолучениеДанныхТестов.Обработать(СписокФайлов, "7z", "ПолучитьСписокФайлов", "ПослеИзменения", ОжидаемыеФайлы);

    РезультатРаспаковки = OPI_7z.РазархивироватьКаталог(ПутьАрхива, КаталогНазначение);
    OPI_ПолучениеДанныхТестов.Обработать(РезультатРаспаковки
        , "7z"
        , "РазархивироватьКаталог"
        , "ПослеИзменения"
        , КаталогНазначение
        , ОжидаемыеФайлы);

    ПутьАрхиваБуфер = Параметры["SevenZ_ArchiveBufferPath"];
    КаталогИсточник = Параметры["SevenZ_SourceDir"];
    OPI_7z.АрхивироватьКаталог(КаталогИсточник, ПутьАрхиваБуфер);

    АрхивДвоичные  = Новый ДвоичныеДанные(ПутьАрхиваБуфер);
    Результат      = OPI_7z.ИзменитьАрхив(АрхивДвоичные, ДобавляемыеФайлы, УдаляемыеПути);
    АрхивДляСписка = Результат;

    Если OPI_Инструменты.ЭтоКоллекция(Результат, Истина)
        И OPI_Инструменты.ПолеКоллекцииСуществует(Результат, "result") Тогда

        Результат      = OPI_7z.ИзменитьАрхив(ПутьАрхиваБуфер, ДобавляемыеФайлы, УдаляемыеПути);
        АрхивДляСписка = ПутьАрхиваБуфер;

        OPI_ПолучениеДанныхТестов.Обработать(Результат, "7z", "ИзменитьАрхив", "ИзПамятиДиск", ПутьАрхиваБуфер);

    Иначе

        OPI_ПолучениеДанныхТестов.Обработать(Результат, "7z", "ИзменитьАрхив", "ИзПамяти");

    КонецЕсли;

    СписокФайлов = OPI_7z.ПолучитьСписокФайлов(АрхивДляСписка);
    OPI_ПолучениеДанныхТестов.Обработать(СписокФайлов, "7z", "ПолучитьСписокФайлов", "ПослеИзмененияИзПамяти", ОжидаемыеФайлы);

КонецПроцедуры

Процедура Z7_ПолучитьСписокФайлов(Параметры)

    OPI_ПолучениеДанныхТестов.ДополнитьПараметрыАрхива(Параметры, "SevenZ"); // SKIP

    ПутьАрхива = Параметры["SevenZ_ArchivePath"];

    Результат = OPI_7z.ПолучитьСписокФайлов(ПутьАрхива);

    // END

    ОжидаемыеФайлы = Параметры["SevenZ_ExpectedFiles"];

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "7z", "ПолучитьСписокФайлов", , ОжидаемыеФайлы);

    АрхивДвоичные = Новый ДвоичныеДанные(ПутьАрхива);

    Результат = OPI_7z.ПолучитьСписокФайлов(АрхивДвоичные);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "7z", "ПолучитьСписокФайлов", "ИзПамяти", ОжидаемыеФайлы);

    Пароль           = Параметры["SevenZ_Password"];
    ПутьАрхиваПароль = Параметры["SevenZ_ArchivePasswordPath"];
    ОжидаемыеПароль  = Параметры["SevenZ_ExpectedPassword"];

    Результат = OPI_7z.ПолучитьСписокФайлов(ПутьАрхиваПароль, Пароль);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "7z", "ПолучитьСписокФайлов", "СПаролем", ОжидаемыеПароль);

    АрхивПароль = Новый ДвоичныеДанные(ПутьАрхиваПароль);

    Результат = OPI_7z.ПолучитьСписокФайлов(АрхивПароль, Пароль);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "7z", "ПолучитьСписокФайлов", "ИзПамятиСПаролем", ОжидаемыеПароль);

КонецПроцедуры

Процедура Z7_ПолучитьМетаданные(Параметры)

    OPI_ПолучениеДанныхТестов.ДополнитьПараметрыАрхива(Параметры, "SevenZ"); // SKIP

    ПутьАрхива = Параметры["SevenZ_ArchivePath"];

    Результат = OPI_7z.ПолучитьМетаданные(ПутьАрхива);

    // END

    ОжидаемыеФайлы = Параметры["SevenZ_ExpectedFiles"];

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "7z", "ПолучитьМетаданные", , ОжидаемыеФайлы);

    АрхивДвоичные = Новый ДвоичныеДанные(ПутьАрхива);

    Результат = OPI_7z.ПолучитьМетаданные(АрхивДвоичные);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "7z", "ПолучитьМетаданные", "ИзПамяти", ОжидаемыеФайлы);

    Пароль           = Параметры["SevenZ_Password"];
    ПутьАрхиваПароль = Параметры["SevenZ_ArchivePasswordPath"];
    ОжидаемыеПароль  = Параметры["SevenZ_ExpectedPassword"];

    Результат = OPI_7z.ПолучитьМетаданные(ПутьАрхиваПароль, Пароль);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "7z", "ПолучитьМетаданные", "СПаролем", ОжидаемыеПароль);

    АрхивПароль = Новый ДвоичныеДанные(ПутьАрхиваПароль);

    Результат = OPI_7z.ПолучитьМетаданные(АрхивПароль, Пароль);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "7z", "ПолучитьМетаданные", "ИзПамятиСПаролем", ОжидаемыеПароль);

    ПутьАрхиваCopy  = Параметры["SevenZ_ArchiveCopyPath"];
    ПутьАрхиваLzma  = Параметры["SevenZ_ArchiveLzmaPath"];
    ОжидаемыеСжатие = Параметры["SevenZ_ExpectedCompress"];

    МетаданныеCopy = OPI_7z.ПолучитьМетаданные(ПутьАрхиваCopy);
    РазмерCopy     = МетаданныеCopy["packed_size"];

    ОжиданияМетаданных = Новый Структура;
    ОжиданияМетаданных.Вставить("solid"           , Истина);
    ОжиданияМетаданных.Вставить("packed_less_than", РазмерCopy);

    Результат = OPI_7z.ПолучитьМетаданные(ПутьАрхиваLzma);
    OPI_ПолучениеДанныхТестов.Обработать(Результат
        , "7z"
        , "ПолучитьМетаданные"
        , "СНастройками"
        , ОжидаемыеСжатие
        , ОжиданияМетаданных);

КонецПроцедуры

#КонецОбласти // АтомарныеТесты

Функция Путь7z(БазовыйКаталог, ОтносительныйПуть)

    ОтносительныйПуть = СтрЗаменить(ОтносительныйПуть, "\", "/");
    Возврат СтрШаблон("%1/%2", БазовыйКаталог, ОтносительныйПуть);

КонецФункции

#КонецОбласти // СлужебныеПроцедурыИФункции


#Region Alternate

Procedure Z7_Archiving() Export
    Z7_Архивация();
EndProcedure

Procedure Z7_GettingMetadata() Export
    Z7_ПолучениеМетаданных();
EndProcedure

#EndRegion