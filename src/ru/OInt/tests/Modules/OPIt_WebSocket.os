Процедура WebSocket_ПолучитьСообщение(ПараметрыФункции)

    Постфикс = ПараметрыФункции["Postfix"]; // SKIP

    Адрес = "wss://127.0.0.1:8443";
    Адрес = ПолучитьАдресWebSocket(ПараметрыФункции); // SKIP

    НастройкиTls    = Неопределено; // SKIP
    НастройкиПрокси = Неопределено; // SKIP

    НуженПрокси = Истина;
    НуженTLS    = Истина;

    НуженПрокси = ПараметрыФункции["Proxy"]; // SKIP
    НуженTls    = ПараметрыФункции["TLS"];   // SKIP

    Заголовки = Новый Соответствие;
    Заголовки.Вставить("X-Trace-Id", "OPI-WS-TEST");

    Если НуженTls Тогда
        НастройкиTls = OPI_WebSocket.ПолучитьНастройкиTls(Истина);
    КонецЕсли;

    Если НуженПрокси Тогда

        ПроксиАдрес = ПараметрыФункции["Proxy_IP"];
        ПроксиПорт  = ПараметрыФункции["Proxy_Port"];
        ПроксиВид   = ПараметрыФункции["Proxy_Type"];

        ПроксиПользователь = ПараметрыФункции["Proxy_User"];
        ПроксиПароль       = ПараметрыФункции["Proxy_Password"];

        НастройкиПрокси = OPI_Компоненты.ПолучитьНастройкиПрокси(ПроксиАдрес
            , ПроксиПорт
            , ПроксиВид
            , ПроксиПользователь
            , ПроксиПароль);

    КонецЕсли;

    Соединение = OPI_WebSocket.ОткрытьСоединение(Адрес, НастройкиTls, НастройкиПрокси, Заголовки);

    Сообщение = "echo-text-" + Формат(ТекущаяДата(), "ДФ=yyyyMMddhhmmss");

    Если OPI_WebSocket.ЭтоОбъектКлиента(Соединение) Тогда

        // Отправляем сообщение ECHO-серверу
        Отправка = OPI_WebSocket.ОтправитьТекстовоеСообщение(Соединение, Сообщение);

        OPI_ПолучениеДанныхТестов.Обработать(Отправка, "WebSocket", "ПолучитьСообщение", "Отправка, " + Постфикс); // SKIP

        // Пропускаем все ответы от сервера до последнего
        Пока Истина Цикл

            ПоследнееСообщение = OPI_WebSocket.ПолучитьСообщение(Соединение, 3000);  // <----

            Если ПоследнееСообщение["result"] Тогда
                Результат = ПоследнееСообщение;
            Иначе
                Прервать;
            КонецЕсли;

        КонецЦикла;

    Иначе
        Результат = Соединение;
    КонецЕсли;

    // END

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "WebSocket", "ПолучитьСообщение", Постфикс, Сообщение);

    Если OPI_WebSocket.ЭтоОбъектКлиента(Соединение) Тогда
        OPI_WebSocket.ЗакрытьСоединение(Соединение);
    КонецЕсли;

КонецПроцедуры

Процедура WebSocket_ОтправитьТекстовоеСообщение(ПараметрыФункции)

    Постфикс = ПараметрыФункции["Postfix"]; // SKIP

    Адрес = "wss://127.0.0.1:8443";
    Адрес = ПолучитьАдресWebSocket(ПараметрыФункции); // SKIP

    НастройкиTls    = Неопределено; // SKIP
    НастройкиПрокси = Неопределено; // SKIP

    НуженПрокси = Истина;
    НуженTLS    = Истина;

    НуженПрокси = ПараметрыФункции["Proxy"]; // SKIP
    НуженTls    = ПараметрыФункции["TLS"];   // SKIP

    Заголовки = Новый Соответствие;
    Заголовки.Вставить("X-Trace-Id", "OPI-WS-TEST");

    Если НуженTls Тогда
        НастройкиTls = OPI_WebSocket.ПолучитьНастройкиTls(Истина);
    КонецЕсли;

    Если НуженПрокси Тогда

        ПроксиАдрес = ПараметрыФункции["Proxy_IP"];
        ПроксиПорт  = ПараметрыФункции["Proxy_Port"];
        ПроксиВид   = ПараметрыФункции["Proxy_Type"];

        ПроксиПользователь = ПараметрыФункции["Proxy_User"];
        ПроксиПароль       = ПараметрыФункции["Proxy_Password"];

        НастройкиПрокси = OPI_Компоненты.ПолучитьНастройкиПрокси(ПроксиАдрес
            , ПроксиПорт
            , ПроксиВид
            , ПроксиПользователь
            , ПроксиПароль);

    КонецЕсли;

    Соединение = OPI_WebSocket.ОткрытьСоединение(Адрес, НастройкиTls, НастройкиПрокси, Заголовки);

    Сообщение = "echo-text-" + Формат(ТекущаяДата(), "ДФ=yyyyMMddhhmmss");

    Если OPI_WebSocket.ЭтоОбъектКлиента(Соединение) Тогда
        Результат = OPI_WebSocket.ОтправитьТекстовоеСообщение(Соединение, Сообщение);
    Иначе
        Результат = Соединение;
    КонецЕсли;

    // END

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "WebSocket", "ОтправитьТекстовоеСообщение", Постфикс);

    Пока Истина Цикл

        ПоследнееСообщение = OPI_WebSocket.ПолучитьСообщение(Соединение, 3000);

        Если ПоследнееСообщение["result"] Тогда
            Проверка = ПоследнееСообщение;
        Иначе
            Прервать;
        КонецЕсли;

    КонецЦикла;

    OPI_ПолучениеДанныхТестов.Обработать(Проверка , "WebSocket", "ОтправитьТекстовоеСообщение", "Проверка, " + Постфикс, Сообщение);

    Если OPI_WebSocket.ЭтоОбъектКлиента(Соединение) Тогда
        OPI_WebSocket.ЗакрытьСоединение(Соединение);
    КонецЕсли;

КонецПроцедуры

Процедура WebSocket_ОтправитьДвоичноеСообщение(ПараметрыФункции)

    Постфикс = ПараметрыФункции["Postfix"]; // SKIP

    Адрес = "wss://127.0.0.1:8443";
    Адрес = ПолучитьАдресWebSocket(ПараметрыФункции); // SKIP

    НастройкиTls    = Неопределено; // SKIP
    НастройкиПрокси = Неопределено; // SKIP

    НуженПрокси = Истина;
    НуженTLS    = Истина;

    НуженПрокси = ПараметрыФункции["Proxy"]; // SKIP
    НуженTls    = ПараметрыФункции["TLS"];   // SKIP

    Заголовки = Новый Соответствие;
    Заголовки.Вставить("X-Trace-Id", "OPI-WS-TEST");

    Если НуженTls Тогда
        НастройкиTls = OPI_WebSocket.ПолучитьНастройкиTls(Истина);
    КонецЕсли;

    Если НуженПрокси Тогда

        ПроксиАдрес = ПараметрыФункции["Proxy_IP"];
        ПроксиПорт  = ПараметрыФункции["Proxy_Port"];
        ПроксиВид   = ПараметрыФункции["Proxy_Type"];

        ПроксиПользователь = ПараметрыФункции["Proxy_User"];
        ПроксиПароль       = ПараметрыФункции["Proxy_Password"];

        НастройкиПрокси = OPI_Компоненты.ПолучитьНастройкиПрокси(ПроксиАдрес
            , ПроксиПорт
            , ПроксиВид
            , ПроксиПользователь
            , ПроксиПароль);

    КонецЕсли;

    Соединение = OPI_WebSocket.ОткрытьСоединение(Адрес, НастройкиTls, НастройкиПрокси, Заголовки);

    ИсходнаяСтрока = "binary-message-" + Формат(ТекущаяДата(), "ДФ=yyyyMMddhhmmss");
    Данные = ПолучитьДвоичныеДанныеИзСтроки(ИсходнаяСтрока);

    Если OPI_WebSocket.ЭтоОбъектКлиента(Соединение) Тогда
        Результат = OPI_WebSocket.ОтправитьДвоичноеСообщение(Соединение, Данные);
    Иначе
        Результат = Соединение;
    КонецЕсли;

    // END

    Пока Истина Цикл

        ПоследнееСообщение = OPI_WebSocket.ПолучитьСообщение(Соединение, 3000);

        Если ПоследнееСообщение["result"] Тогда
            Проверка = ПоследнееСообщение;
        Иначе
            Прервать;
        КонецЕсли;

    КонецЦикла;

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "WebSocket", "ОтправитьДвоичноеСообщение", Постфикс);
    OPI_ПолучениеДанныхТестов.Обработать(Проверка , "WebSocket", "ОтправитьДвоичноеСообщение", "Проверка, " + Постфикс, ИсходнаяСтрока);

    Если OPI_WebSocket.ЭтоОбъектКлиента(Соединение) Тогда
        OPI_WebSocket.ЗакрытьСоединение(Соединение);
    КонецЕсли;

КонецПроцедуры

Процедура WebSocket_ПолучитьНастройкиTls(ПараметрыФункции)

    Результат = OPI_WebSocket.ПолучитьНастройкиTls(Истина);

    // END

    Постфикс = ПараметрыФункции["Postfix"];

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "WebSocket", "ПолучитьНастройкиTls", Постфикс);

КонецПроцедуры

Процедура WebSocket_ПолучитьНастройкиПрокси(ПараметрыФункции)

    ТипПрокси = ПараметрыФункции["Proxy_Type"];

    АдресПрокси  = ПараметрыФункции["Proxy_IP"];
    ПортПрокси   = ПараметрыФункции["Proxy_Port"];
    ЛогинПрокси  = ПараметрыФункции["Proxy_User"];
    ПарольПрокси = ПараметрыФункции["Proxy_Password"];

    Результат = OPI_WebSocket.ПолучитьНастройкиПрокси(АдресПрокси, ПортПрокси, ТипПрокси, ЛогинПрокси, ПарольПрокси);

    // END

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "WebSocket", "ПолучитьНастройкиПрокси");

КонецПроцедуры

Процедура WebSocket_ПолучитьЛогКлиента(ПараметрыФункции)

    Адрес = "wss://127.0.0.1:8443";
    Адрес = ПолучитьАдресWebSocket(ПараметрыФункции); // SKIP

    НастройкиTls    = Неопределено; // SKIP
    НастройкиПрокси = Неопределено; // SKIP

    НуженПрокси = Истина;
    НуженTLS    = Истина;

    НуженПрокси = ПараметрыФункции["Proxy"]; // SKIP
    НуженTls    = ПараметрыФункции["TLS"];   // SKIP

    Если НуженTls Тогда
        НастройкиTls = OPI_WebSocket.ПолучитьНастройкиTls(Истина);
    КонецЕсли;

    Если НуженПрокси Тогда

        ПроксиАдрес = ПараметрыФункции["Proxy_IP"];
        ПроксиПорт  = ПараметрыФункции["Proxy_Port"];
        ПроксиВид   = ПараметрыФункции["Proxy_Type"];

        ПроксиПользователь = ПараметрыФункции["Proxy_User"];
        ПроксиПароль       = ПараметрыФункции["Proxy_Password"];

        НастройкиПрокси = OPI_Компоненты.ПолучитьНастройкиПрокси(ПроксиАдрес
            , ПроксиПорт
            , ПроксиВид
            , ПроксиПользователь
            , ПроксиПароль);

    КонецЕсли;

    ФайлЛога             = ПолучитьИмяВременногоФайла("txt");
    НастройкиЛогирования = OPI_WebSocket.ПолучитьНастройкиЛогирования(Истина, 100, ФайлЛога);
    Соединение           = OPI_WebSocket.ОткрытьСоединение(Адрес, НастройкиTls, НастройкиПрокси, Неопределено, НастройкиЛогирования);
    OPI_Инструменты.Пауза(1); // SKIP

    Если Не OPI_WebSocket.ЭтоОбъектКлиента(Соединение) Тогда
        ВызватьИсключение OPI_Инструменты.JSONСтрокой(Соединение);
    КонецЕсли;

    Результат = OPI_WebSocket.ПолучитьЛог(Соединение);

    // END

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "WebSocket", "ПолучитьЛог", , ФайлЛога);

    Результат = OPI_WebSocket.ПолучитьЛог(Соединение, Истина);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "WebSocket", "ПолучитьЛог", "КакСтрока", ФайлЛога);

    OPI_WebSocket.ЗакрытьСоединение(Соединение);

КонецПроцедуры

Процедура WebSocket_ЭтоОбъектКлиента(ПараметрыФункции)

    Постфикс = ПараметрыФункции["Postfix"]; // SKIP

    Адрес = "wss://127.0.0.1:8443";
    Адрес = ПолучитьАдресWebSocket(ПараметрыФункции); // SKIP

    НастройкиTls    = Неопределено; // SKIP
    НастройкиПрокси = Неопределено; // SKIP

    НуженПрокси = Истина;
    НуженTLS    = Истина;

    НуженПрокси = ПараметрыФункции["Proxy"]; // SKIP
    НуженTls    = ПараметрыФункции["TLS"];   // SKIP

    Заголовки = Новый Соответствие;
    Заголовки.Вставить("X-Trace-Id", "OPI-WS-TEST");

    Если НуженTls Тогда
        НастройкиTls = OPI_WebSocket.ПолучитьНастройкиTls(Истина);
    КонецЕсли;

    Если НуженПрокси Тогда

        ПроксиАдрес = ПараметрыФункции["Proxy_IP"];
        ПроксиПорт  = ПараметрыФункции["Proxy_Port"];
        ПроксиВид   = ПараметрыФункции["Proxy_Type"];

        ПроксиПользователь = ПараметрыФункции["Proxy_User"];
        ПроксиПароль       = ПараметрыФункции["Proxy_Password"];

        НастройкиПрокси = OPI_Компоненты.ПолучитьНастройкиПрокси(ПроксиАдрес
            , ПроксиПорт
            , ПроксиВид
            , ПроксиПользователь
            , ПроксиПароль);

    КонецЕсли;

    Соединение = OPI_WebSocket.ОткрытьСоединение(Адрес, НастройкиTls, НастройкиПрокси, Заголовки);
    Результат  = OPI_WebSocket.ЭтоОбъектКлиента(Соединение);

    // END

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "WebSocket", "ЭтоОбъектКлиента", Постфикс);

    Результат = OPI_WebSocket.ЭтоОбъектКлиента("not-a-client");
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "WebSocket", "ЭтоОбъектКлиента", "Ложь, " + Постфикс);

    Если OPI_WebSocket.ЭтоОбъектКлиента(Результат) Тогда
        OPI_WebSocket.ЗакрытьСоединение(Результат);
    КонецЕсли;

КонецПроцедуры

Процедура WebSocket_ЗапуститьСервер(ПараметрыФункции)

    Порт       = 9894;
    РазмерПула = 10;

    Результат = OPI_WebSocket.ЗапуститьСервер(Порт, РазмерПула);

    // END

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "WebSocket", "ЗапуститьСервер");

    OPI_WebSocket.ОстановитьСервер(Результат);

КонецПроцедуры

Процедура WebSocket_ОстановитьСервер(ПараметрыФункции)

    Порт          = 9894;
    ОбъектСервера = OPI_WebSocket.ЗапуститьСервер(Порт);

    Результат = OPI_WebSocket.ОстановитьСервер(ОбъектСервера);

    // END

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "WebSocket", "ОстановитьСервер");

    РезультатСписка = OPI_WebSocket.ПолучитьСписокСоединений(ОбъектСервера);

    OPI_ПолучениеДанныхТестов.Обработать(РезультатСписка, "WebSocket", "ОстановитьСервер", "Список");

    Адрес         = "ws://127.0.0.1:9894";
    ОбъектКлиента = OPI_WebSocket.ОткрытьСоединение(Адрес);

    OPI_ПолучениеДанныхТестов.Обработать(ОбъектКлиента, "WebSocket", "ОстановитьСервер", "Подключение");

КонецПроцедуры

Процедура WebSocket_ПолучитьДанныеОчередногоСоединения(ПараметрыФункции)

    // Запуск сервера
    ПортЗапуска   = 9894;
    ОбъектСервера = OPI_WebSocket.ЗапуститьСервер(ПортЗапуска);

    // Подключение к серверу при помощи клиента
    АдресПодключения = "ws://127.0.0.1:9894";
    ОбъектКлиента    = OPI_WebSocket.ОткрытьСоединение(АдресПодключения);

    Если Не OPI_WebSocket.ЭтоОбъектКлиента(ОбъектКлиента) Тогда
        ВызватьИсключение OPI_Инструменты.JSONСтрокой(ОбъектКлиента);
    Иначе
        // Отправка с клиента
        Сообщение = "Hello from client!";
        Отправка  = OPI_WebSocket.ОтправитьТекстовоеСообщение(ОбъектКлиента, Сообщение);
    КонецЕсли;

    // Получение на сервере
    Результат = OPI_WebSocket.ПолучитьДанныеОчередногоСоединения(ОбъектСервера, 5000);

    // END

    OPI_WebSocket.ЗакрытьСоединение(ОбъектКлиента);

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "WebSocket", "ПолучитьДанныеОчередногоСоединения", , Сообщение);

    OPI_WebSocket.ОтправитьТекстовоеСообщение(ОбъектКлиента, Сообщение);
    OPI_WebSocket.ЗакрытьСоединение(ОбъектКлиента);

    Результат = OPI_WebSocket.ПолучитьДанныеОчередногоСоединения(ОбъектСервера, 5000);

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "WebSocket", "ПолучитьДанныеОчередногоСоединения", "Закрытое", Сообщение);

    OPI_WebSocket.ОстановитьСервер(ОбъектСервера);

КонецПроцедуры

Процедура WebSocket_ПолучитьДанныеСоединения(ПараметрыФункции)

    // Запуск сервера
    ПортЗапуска   = 9894;
    ОбъектСервера = OPI_WebSocket.ЗапуститьСервер(ПортЗапуска);

    // Подключение к серверу при помощи клиента
    АдресПодключения = "ws://127.0.0.1:9894";
    ОбъектКлиента    = OPI_WebSocket.ОткрытьСоединение(АдресПодключения);

    Если Не OPI_WebSocket.ЭтоОбъектКлиента(ОбъектКлиента) Тогда
        ВызватьИсключение OPI_Инструменты.JSONСтрокой(ОбъектКлиента);
    КонецЕсли;

    OPI_Инструменты.Пауза(1); // SKIP

    // Получение списка активных соединений на сервере
    СписокСоединений = OPI_WebSocket.ПолучитьСписокСоединений(ОбъектСервера);

    Если Не СписокСоединений["result"] Тогда
        ВызватьИсключение OPI_Инструменты.JSONСтрокой(СписокСоединений);
    КонецЕсли;

    Если СписокСоединений["connections"].Количество() = 0 Тогда
        ВызватьИсключение "Список соединений пуст";
    Иначе
        IDСоединения = СписокСоединений["connections"][0]["connectionId"];
    КонецЕсли;

    Для Н = 0 По 5 Цикл

        // Отправка сообщения с клиента
        ТекущееСообщение = СтрШаблон("Message no. %1", Н);
        OPI_WebSocket.ОтправитьТекстовоеСообщение(ОбъектКлиента, ТекущееСообщение);

        // Получение входящего сообщения на сервере по ID
        Результат = OPI_WebSocket.ПолучитьДанныеСоединения(ОбъектСервера, IDСоединения, 5000);

        OPI_ПолучениеДанныхТестов.Обработать(Результат, "WebSocket", "ПолучитьДанныеСоединения", , ТекущееСообщение); // SKIP

    КонецЦикла;

    // END

    OPI_WebSocket.ОтправитьТекстовоеСообщение(ОбъектКлиента, ТекущееСообщение);
    OPI_WebSocket.ЗакрытьСоединение(ОбъектКлиента);

    Результат = OPI_WebSocket.ПолучитьДанныеСоединения(ОбъектСервера, IDСоединения, 5000);

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "WebSocket", "ПолучитьДанныеСоединения", "Закрытое", ТекущееСообщение);

    OPI_WebSocket.ПолучитьДанныеСоединения(ОбъектСервера, IDСоединения, 5000);
    Результат = OPI_WebSocket.ПолучитьСписокСоединений(ОбъектСервера);

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "WebSocket", "ПолучитьДанныеСоединения", "ПустойСписок");

    OPI_WebSocket.ОстановитьСервер(ОбъектСервера);

КонецПроцедуры

Процедура WebSocket_ОтправитьДанные(ПараметрыФункции)

    // Запуск сервера
    ПортЗапуска   = 9894;
    ОбъектСервера = OPI_WebSocket.ЗапуститьСервер(ПортЗапуска);

    // Подключение к серверу при помощи клиента
    АдресПодключения = "ws://127.0.0.1:9894";
    ОбъектКлиента    = OPI_WebSocket.ОткрытьСоединение(АдресПодключения);

    Если Не OPI_WebSocket.ЭтоОбъектКлиента(ОбъектКлиента) Тогда
        ВызватьИсключение OPI_Инструменты.JSONСтрокой(ОбъектКлиента);
    КонецЕсли;

    // Отправка сообщения с клиента
    Сообщение = "Hello!";
    OPI_WebSocket.ОтправитьТекстовоеСообщение(ОбъектКлиента, Сообщение);

    // Получение очередного соединения на сервере и возврат ответа
    ОчередноеСообщение = OPI_WebSocket.ПолучитьДанныеОчередногоСоединения(ОбъектСервера, 5000);
    IDСоединения       = ОчередноеСообщение["connectionId"];

    ОтветСервера = "Response from server!";
    Результат    = OPI_WebSocket.ОтправитьДанные(ОбъектСервера, IDСоединения, ОтветСервера);

    // END

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "WebSocket", "ОтправитьДанные");

    ОтветКлиента = OPI_WebSocket.ПолучитьСообщение(ОбъектКлиента, 3000);

    OPI_ПолучениеДанныхТестов.Обработать(ОтветКлиента, "WebSocket", "ОтправитьДанные", "Проверка", ОтветСервера);

    OPI_WebSocket.ЗакрытьСоединение(ОбъектКлиента);
    OPI_WebSocket.ОстановитьСервер(ОбъектСервера);

КонецПроцедуры

Процедура WebSocket_ЗакрытьВходящееСоединение(ПараметрыФункции)

    // Запуск сервера
    ПортЗапуска   = 9894;
    ОбъектСервера = OPI_WebSocket.ЗапуститьСервер(ПортЗапуска);

    // Подключение к серверу при помощи клиента
    АдресПодключения = "ws://127.0.0.1:9894";
    ОбъектКлиента    = OPI_WebSocket.ОткрытьСоединение(АдресПодключения);

    Если Не OPI_WebSocket.ЭтоОбъектКлиента(ОбъектКлиента) Тогда
        ВызватьИсключение OPI_Инструменты.JSONСтрокой(ОбъектКлиента);
    КонецЕсли;

    // Отправка сообщения с клиента
    Сообщение = "Hello!";
    OPI_WebSocket.ОтправитьТекстовоеСообщение(ОбъектКлиента, Сообщение);

    // Получение и закрытие соединения на сервере
    ПервоеСообщение = OPI_WebSocket.ПолучитьДанныеОчередногоСоединения(ОбъектСервера, 5000);
    IDСоединения    = ПервоеСообщение["connectionId"];

    Результат = OPI_WebSocket.ЗакрытьВходящееСоединение(ОбъектСервера, IDСоединения, Истина);

    // END

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "WebSocket", "ЗакрытьВходящееСоединение");

    Результат = OPI_WebSocket.ПолучитьСписокСоединений(ОбъектСервера);

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "WebSocket", "ЗакрытьВходящееСоединение", "ПустойСписок");

    OPI_WebSocket.ОтправитьТекстовоеСообщение(ОбъектКлиента, Сообщение);
    Результат = OPI_WebSocket.ОтправитьТекстовоеСообщение(ОбъектКлиента, Сообщение);

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "WebSocket", "ЗакрытьВходящееСоединение", "ОтправкаВЗакрытое");

    OPI_WebSocket.ОстановитьСервер(ОбъектСервера);

КонецПроцедуры

Процедура WebSocket_ПолучитьСписокСоединений(ПараметрыФункции)

    // Запуск сервера
    ПортЗапуска   = 9894;
    ОбъектСервера = OPI_WebSocket.ЗапуститьСервер(ПортЗапуска);

    // Создание нескольких соединений клиента
    АдресПодключения = "ws://127.0.0.1:9894";

    Клиент1 = OPI_WebSocket.ОткрытьСоединение(АдресПодключения);
    Клиент2 = OPI_WebSocket.ОткрытьСоединение(АдресПодключения);

    Если Не OPI_WebSocket.ЭтоОбъектКлиента(Клиент1) Тогда
        ВызватьИсключение OPI_Инструменты.JSONСтрокой(Клиент1);
    КонецЕсли;

    Если Не OPI_WebSocket.ЭтоОбъектКлиента(Клиент2) Тогда
        ВызватьИсключение OPI_Инструменты.JSONСтрокой(Клиент2);
    КонецЕсли;

    // Получение списка активных соединений на сервере
    Результат = OPI_WebSocket.ПолучитьСписокСоединений(ОбъектСервера);

    // END

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "WebSocket", "ПолучитьСписокСоединений");

    OPI_WebSocket.ЗакрытьСоединение(Клиент1);
    OPI_WebSocket.ЗакрытьСоединение(Клиент2);

    Клиент3 = OPI_WebSocket.ОткрытьСоединение(АдресПодключения);
    Клиент4 = OPI_WebSocket.ОткрытьСоединение(АдресПодключения);

    OPI_WebSocket.ОтправитьТекстовоеСообщение(Клиент3, "Yo");

    OPI_WebSocket.ЗакрытьСоединение(Клиент3);
    OPI_WebSocket.ЗакрытьСоединение(Клиент4);

    Результат = OPI_WebSocket.ПолучитьСписокСоединений(ОбъектСервера);

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "WebSocket", "ПолучитьСписокСоединений", "Закрытые");

    OPI_WebSocket.ОстановитьСервер(ОбъектСервера);

КонецПроцедуры

Процедура WebSocket_ЭтоОбъектСервера(ПараметрыФункции)

    Порт   = 9894;
    Сервер = OPI_WebSocket.ЗапуститьСервер(Порт);

    Результат = OPI_WebSocket.ЭтоОбъектСервера(Сервер);

    // END

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "WebSocket", "ЭтоОбъектСервера");

    OPI_WebSocket.ОстановитьСервер(Сервер);

    Результат = OPI_WebSocket.ЭтоОбъектСервера("Не сервер");

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "WebSocket", "ЭтоОбъектСервера", "Ложь");

КонецПроцедуры

Процедура WebSocket_ПолучитьЛог(ПараметрыФункции)

    // Запуск сервера
    ПортЗапуска          = 9894;
    ФайлЛога             = ПолучитьИмяВременногоФайла("txt");
    НастройкиЛогирования = OPI_WebSocket.ПолучитьНастройкиЛогирования(Истина, 100, ФайлЛога);
    ОбъектСервера        = OPI_WebSocket.ЗапуститьСервер(ПортЗапуска, , НастройкиЛогирования);

    // Подключение к серверу с клиента
    АдресПодключения = "ws://127.0.0.1:9894";
    ОбъектКлиента    = OPI_WebSocket.ОткрытьСоединение(АдресПодключения);
    OPI_Инструменты.Пауза(1); // SKIP

    Если Не OPI_WebSocket.ЭтоОбъектКлиента(ОбъектКлиента) Тогда
        ВызватьИсключение OPI_Инструменты.JSONСтрокой(ОбъектКлиента);
    КонецЕсли;

    // Получение лога сервера
    Результат = OPI_WebSocket.ПолучитьЛог(ОбъектСервера);

    // END

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "WebSocket", "ПолучитьЛог", , ФайлЛога);

    Результат = OPI_WebSocket.ПолучитьЛог(ОбъектСервера, Истина);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "WebSocket", "ПолучитьЛог", "КакСтрока", ФайлЛога);

    OPI_WebSocket.ЗакрытьСоединение(ОбъектКлиента);
    OPI_WebSocket.ОстановитьСервер(ОбъектСервера);

КонецПроцедуры

Процедура WebSocket_ПолучитьНастройкиЛогирования(ПараметрыФункции)

    Результат = OPI_WebSocket.ПолучитьНастройкиЛогирования(Истина, 100, ПолучитьИмяВременногоФайла());

    // END

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "WebSocket", "ПолучитьНастройкиЛогирования");

    Результат = OPI_WebSocket.ПолучитьНастройкиЛогирования(Ложь, , ПолучитьИмяВременногоФайла());

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "WebSocket", "ПолучитьНастройкиЛогирования", "Файл");

    Результат = OPI_WebSocket.ПолучитьНастройкиЛогирования(Истина);

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "WebSocket", "ПолучитьНастройкиЛогирования", "Память");

КонецПроцедуры

#КонецОбласти // WebSocket

#КонецОбласти // АтомарныеТесты

#Область ВспомогательныеФункции

Функция ПолучитьАдресWebSocket(ПараметрыФункции)

    Схема = ?(ПараметрыФункции["TLS"], "wss://", "ws://");
    Хост  = ПараметрыФункции["WS_IP"];
    Порт  = ПараметрыФункции["WS_Port"];

    OPI_ПреобразованиеТипов.ПолучитьСтроку(Порт);

    Возврат СтрШаблон("%1%2:%3", Схема, Хост, Порт);

КонецФункции

#КонецОбласти // ВспомогательныеФункции

#КонецОбласти // СлужебныеПроцедурыИФункции

#Region Alternate

Procedure WS_Client() Export
    WS_Клиент();
EndProcedure

Procedure WS_Server() Export
    WS_Сервер();
EndProcedure

#EndRegion