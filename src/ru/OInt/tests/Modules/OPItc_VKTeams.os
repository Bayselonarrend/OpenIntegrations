    Текст    = "<b>Новый полужирный текст сообщения</b>";
    Разметка = "HTML";

    Опции = Новый Структура;
    Опции.Вставить("token", Токен);
    Опции.Вставить("chatid", IDЧата);
    Опции.Вставить("messageid", IDСообщения);
