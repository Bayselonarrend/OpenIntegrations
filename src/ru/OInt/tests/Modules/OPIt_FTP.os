    Результат = OPI_FTP.УдалитьФайл(Соединение, "pic_from_binary.png");

    OPI_ПолучениеДанныхТестов.Обработать(Результат , "FTP", "УдалитьФайл", "Несуществующий, " + Постфикс);

    Результат = OPI_FTP.ПолучитьСписокОбъектов(Соединение, "", Истина);

    OPI_ПолучениеДанныхТестов.Обработать(Результат , "FTP", "УдалитьФайл", "Проверка, " + Постфикс);

