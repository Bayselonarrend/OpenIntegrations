//@skip-check missing-temporary-file-deletion
//@skip-check module-unused-method

#Использовать "../../tools/main"
#Использовать "../../tools/http"
#Использовать "../../api"
#Использовать "../../formats"
#Использовать asserts
#Использовать "internal"

// Для YaxUnit

Процедура ИсполняемыеСценарии() Экспорт

    OPI_ПолучениеДанныхТестов.СформироватьТестыЯксCLI("Tar");

КонецПроцедуры

// Для Asserts

Функция ПолучитьСписокТестов(ЮнитТестирование) Экспорт

    Возврат OPI_ПолучениеДанныхТестов.СформироватьТестыАссертсCLI("Tar");

КонецФункции

#Область СлужебныйПрограммныйИнтерфейс

#Область ЗапускаемыеТесты

#Область Архивация

Процедура ZTar_Архивация() Экспорт

    ZTar_ПолучитьСтруктуруНастроекАрхивации();

    КаталогБазы = КаталогВременныхФайлов()
        + "\opi_tar_"
        + Формат(ТекущаяУниверсальнаяДатаВМиллисекундах(), "ЧГ=0");

    СоздатьКаталог(КаталогБазы);

    КаталогИсточник        = ПутьTar(КаталогБазы, "src");
    КаталогНазначение      = ПутьTar(КаталогБазы, "out");
    КаталогНазначениеБуфер = ПутьTar(КаталогБазы, "out_buffer");
    ПутьАрхива             = ПутьTar(КаталогБазы, "archive.tar");
    ПутьАрхиваОписание     = ПутьTar(КаталогБазы, "archive_desc.tar");

    СоздатьКаталог(КаталогИсточник);
    СоздатьКаталог(КаталогНазначение);
    СоздатьКаталог(КаталогНазначениеБуфер);

    ОжидаемыеФайлы = Новый Соответствие;

    ОжидаемыеФайлы.Вставить("readme.txt", "OpenIntegrations root");
    ПолучитьДвоичныеДанныеИзСтроки("OpenIntegrations root", "UTF-8").Записать(ПутьTar(КаталогИсточник, "readme.txt"));

    СоздатьКаталог(ПутьTar(КаталогИсточник, "docs"));
    ОжидаемыеФайлы.Вставить("docs\note.txt", "Nested documentation");
    ПолучитьДвоичныеДанныеИзСтроки("Nested documentation", "UTF-8").Записать(ПутьTar(КаталогИсточник, "docs\note.txt"));

    СоздатьКаталог(ПутьTar(КаталогИсточник, "data\nested"));
    ОписаниеБинарника = Новый Структура("binary, hex", Истина, "0102030405");
    ОжидаемыеФайлы.Вставить("data\nested\payload.bin", ОписаниеБинарника);
    ПолучитьДвоичныеДанныеИзHexСтроки("0102030405").Записать(ПутьTar(КаталогИсточник, "data\nested\payload.bin"));

    СоздатьКаталог(ПутьTar(КаталогИсточник, "config"));
    ОжидаемыеФайлы.Вставить("config\settings.json", "{""enabled"": true}");
    ПолучитьДвоичныеДанныеИзСтроки("{""enabled"": true}", "UTF-8").Записать(ПутьTar(КаталогИсточник, "config\settings.json"));

    ЗаписиОписания = Новый Массив;

    ЭлементReadme = Новый Соответствие;
    ЭлементReadme.Вставить("name"      , "readme.txt");
    ЭлементReadme.Вставить("directory" , Ложь);
    ЭлементReadme.Вставить("from_path" , Истина);
    ЭлементReadme.Вставить("path"      , ПутьTar(КаталогИсточник, "readme.txt"));
    ЗаписиОписания.Добавить(ЭлементReadme);

    ЗаписиDocs  = Новый Массив;
    ЭлементNote = Новый Соответствие;
    ЭлементNote.Вставить("name"      , "note.txt");
    ЭлементNote.Вставить("directory" , Ложь);
    ЭлементNote.Вставить("from_path" , Истина);
    ЭлементNote.Вставить("path"      , ПутьTar(КаталогИсточник, "docs\note.txt"));
    ЗаписиDocs.Добавить(ЭлементNote);

    ЭлементDocs = Новый Соответствие;
    ЭлементDocs.Вставить("name"      , "docs");
    ЭлементDocs.Вставить("directory" , Истина);
    ЭлементDocs.Вставить("entries"   , ЗаписиDocs);
    ЗаписиОписания.Добавить(ЭлементDocs);

    ЗаписиData     = Новый Массив;
    ЭлементPayload = Новый Соответствие;
    ЭлементPayload.Вставить("name"      , "payload.bin");
    ЭлементPayload.Вставить("directory" , Ложь);
    ЭлементPayload.Вставить("from_path" , Истина);
    ЭлементPayload.Вставить("path"      , ПутьTar(КаталогИсточник, "data\nested\payload.bin"));
    ЗаписиData.Добавить(ЭлементPayload);

    ЭлементData   = Новый Соответствие;
    ЭлементData.Вставить("name"      , "data");
    ЭлементData.Вставить("directory" , Истина);
    ЗаписиNested  = Новый Массив;
    ЭлементNested = Новый Соответствие;
    ЭлементNested.Вставить("name"      , "nested");
    ЭлементNested.Вставить("directory" , Истина);
    ЭлементNested.Вставить("entries"   , ЗаписиData);
    ЗаписиNested.Добавить(ЭлементNested);
    ЭлементData.Вставить("entries"   , ЗаписиNested);
    ЗаписиОписания.Добавить(ЭлементData);

    ЗаписиConfig    = Новый Массив;
    ЭлементSettings = Новый Соответствие;
    ЭлементSettings.Вставить("name"      , "settings.json");
    ЭлементSettings.Вставить("directory" , Ложь);
    ЭлементSettings.Вставить("from_path" , Истина);
    ЭлементSettings.Вставить("path"      , ПутьTar(КаталогИсточник, "config\settings.json"));
    ЗаписиConfig.Добавить(ЭлементSettings);

    ЭлементConfig = Новый Соответствие;
    ЭлементConfig.Вставить("name"      , "config");
    ЭлементConfig.Вставить("directory" , Истина);
    ЭлементConfig.Вставить("entries"   , ЗаписиConfig);
    ЗаписиОписания.Добавить(ЭлементConfig);

    ОписаниеАрхива = Новый Соответствие;
    ОписаниеАрхива.Вставить("entries", ЗаписиОписания);

    Параметры = Новый Структура;
    Параметры.Вставить("Tar_BaseDir"        , КаталогБазы);
    Параметры.Вставить("Tar_SourceDir"      , КаталогИсточник);
    Параметры.Вставить("Tar_ArchivePath"    , ПутьАрхива);
    Параметры.Вставить("Tar_ArchiveDescPath", ПутьАрхиваОписание);
    Параметры.Вставить("Tar_DestDir"        , КаталогНазначение);
    Параметры.Вставить("Tar_DestBufferDir"  , КаталогНазначениеБуфер);
    Параметры.Вставить("Tar_Description"    , ОписаниеАрхива);
    Параметры.Вставить("Tar_ExpectedFiles"  , ОжидаемыеФайлы);

    OPI_ПолучениеДанныхТестов.ЗаписатьПараметрыАрхива(Параметры);

    ZTar_АрхивироватьКаталог(Параметры);
    ZTar_РазархивироватьКаталог(Параметры);

    OPI_Инструменты.УдалитьФайлВПопытке(КаталогБазы, "Не удалось удалить каталог теста tar");

КонецПроцедуры

Процедура ZTar_АрхивацияСGzip() Экспорт

    КаталогБазы = КаталогВременныхФайлов()
        + "\opi_tar_gzip_"
        + Формат(ТекущаяУниверсальнаяДатаВМиллисекундах(), "ЧГ=0");

    СоздатьКаталог(КаталогБазы);

    КаталогИсточник        = ПутьTar(КаталогБазы, "src");
    КаталогНазначение      = ПутьTar(КаталогБазы, "out");
    КаталогНазначениеБуфер = ПутьTar(КаталогБазы, "out_buffer");
    ПутьАрхива             = ПутьTar(КаталогБазы, "archive.tar.gz");

    СоздатьКаталог(КаталогИсточник);
    СоздатьКаталог(КаталогНазначение);
    СоздатьКаталог(КаталогНазначениеБуфер);

    ОжидаемыеФайлы = Новый Соответствие;
    ОжидаемыеФайлы.Вставить("secret.txt", "Compressed content");
    ПолучитьДвоичныеДанныеИзСтроки("Compressed content", "UTF-8").Записать(ПутьTar(КаталогИсточник, "secret.txt"));

    Параметры = Новый Структура;
    Параметры.Вставить("Tar_BaseDir"            , КаталогБазы);
    Параметры.Вставить("Tar_SourceDir"          , КаталогИсточник);
    Параметры.Вставить("Tar_ArchiveGzipPath"    , ПутьАрхива);
    Параметры.Вставить("Tar_DestDir"            , КаталогНазначение);
    Параметры.Вставить("Tar_DestBufferDir"      , КаталогНазначениеБуфер);
    Параметры.Вставить("Tar_ExpectedFiles"      , ОжидаемыеФайлы);

    OPI_ПолучениеДанныхТестов.ЗаписатьПараметрыАрхива(Параметры);

    ZTar_АрхивироватьКаталог(Параметры);
    ZTar_РазархивироватьКаталог(Параметры);
    ZTar_ПолучитьСписокФайлов(Параметры);
    ZTar_ПолучитьМетаданные(Параметры);

    OPI_Инструменты.УдалитьФайлВПопытке(КаталогБазы, "Не удалось удалить каталог теста tar");

КонецПроцедуры

#КонецОбласти // Архивация

#Область ПолучениеМетаданных

Процедура ZTar_ПолучениеМетаданных() Экспорт

    КаталогБазы = КаталогВременныхФайлов()
        + "\opi_tar_meta_"
        + Формат(ТекущаяУниверсальнаяДатаВМиллисекундах(), "ЧГ=0");

    СоздатьКаталог(КаталогБазы);

    КаталогИсточник = ПутьTar(КаталогБазы, "src");
    ПутьАрхива      = ПутьTar(КаталогБазы, "archive.tar");

    СоздатьКаталог(КаталогИсточник);

    ОжидаемыеФайлы = Новый Соответствие;

    ОжидаемыеФайлы.Вставить("readme.txt", "tar metadata test");
    ПолучитьДвоичныеДанныеИзСтроки("tar metadata test", "UTF-8").Записать(ПутьTar(КаталогИсточник, "readme.txt"));

    СоздатьКаталог(ПутьTar(КаталогИсточник, "docs"));
    ОжидаемыеФайлы.Вставить("docs\note.txt", "Nested file");
    ПолучитьДвоичныеДанныеИзСтроки("Nested file", "UTF-8").Записать(ПутьTar(КаталогИсточник, "docs\note.txt"));

    OPI_Tar.АрхивироватьКаталог(КаталогИсточник, ПутьАрхива);

    Параметры = Новый Структура;
    Параметры.Вставить("Tar_ArchivePath"  , ПутьАрхива);
    Параметры.Вставить("Tar_ExpectedFiles", ОжидаемыеФайлы);

    ZTar_ПолучитьСписокФайлов(Параметры);
    ZTar_ПолучитьМетаданные(Параметры);

    КаталогСжатие   = ПутьTar(КаталогБазы, "src_compress");
    ПутьАрхиваPlain = ПутьTar(КаталогБазы, "archive_plain.tar");
    ПутьАрхиваGzip  = ПутьTar(КаталогБазы, "archive_gzip.tar.gz");
    ПутьФайлаСжатия = ПутьTar(КаталогСжатие, "compressible.txt");

    СоздатьКаталог(КаталогСжатие);

    ОжидаемыеФайлыСжатие = Новый Соответствие;

    Фрагмент    = "ABCD1234EFGH5678";
    ТекстСжатия = "";

    Для Индекс = 1 По 2000 Цикл
        ТекстСжатия = ТекстСжатия + Фрагмент;
    КонецЦикла;

    ОжидаемыеФайлыСжатие.Вставить("compressible.txt" , ТекстСжатия);
    ОжидаемыеФайлыСжатие.Вставить("compressible2.txt", ТекстСжатия);
    ПолучитьДвоичныеДанныеИзСтроки(ТекстСжатия, "UTF-8").Записать(ПутьФайлаСжатия);
    ПолучитьДвоичныеДанныеИзСтроки(ТекстСжатия, "UTF-8").Записать(ПутьTar(КаталогСжатие, "compressible2.txt"));

    ПараметрыСжатие = Новый Структура;
    ПараметрыСжатие.Вставить("Tar_SourceDirCompress", КаталогСжатие);
    ПараметрыСжатие.Вставить("Tar_ArchivePlainPath" , ПутьАрхиваPlain);
    ПараметрыСжатие.Вставить("Tar_ArchiveGzipPath"  , ПутьАрхиваGzip);
    ПараметрыСжатие.Вставить("Tar_ExpectedFiles"    , ОжидаемыеФайлыСжатие);

    ZTar_АрхивироватьКаталог(ПараметрыСжатие);
    ZTar_ПолучитьМетаданные(ПараметрыСжатие);

    OPI_Инструменты.УдалитьФайлВПопытке(КаталогБазы, "Не удалось удалить каталог теста tar");

КонецПроцедуры

#КонецОбласти // ПолучениеМетаданных

#Область ИзменениеАрхива

Процедура ZTar_ЧастичнаяРаспаковка() Экспорт

    КаталогБазы = КаталогВременныхФайлов()
        + "\opi_tar_partial_"
        + Формат(ТекущаяУниверсальнаяДатаВМиллисекундах(), "ЧГ=0");

    СоздатьКаталог(КаталогБазы);

    КаталогИсточник        = ПутьTar(КаталогБазы, "src");
    КаталогНазначение      = ПутьTar(КаталогБазы, "out");
    КаталогНазначениеБуфер = ПутьTar(КаталогБазы, "out_buffer");
    ПутьАрхива             = ПутьTar(КаталогБазы, "archive.tar");

    СоздатьКаталог(КаталогИсточник);
    СоздатьКаталог(КаталогНазначение);
    СоздатьКаталог(КаталогНазначениеБуфер);

    ОжидаемыеФайлы = Новый Соответствие;

    ОжидаемыеФайлы.Вставить("readme.txt", "OpenIntegrations root");
    ПолучитьДвоичныеДанныеИзСтроки("OpenIntegrations root", "UTF-8").Записать(ПутьTar(КаталогИсточник, "readme.txt"));

    СоздатьКаталог(ПутьTar(КаталогИсточник, "docs"));
    ОжидаемыеФайлы.Вставить("docs\note.txt", "Nested documentation");
    ПолучитьДвоичныеДанныеИзСтроки("Nested documentation", "UTF-8").Записать(ПутьTar(КаталогИсточник, "docs\note.txt"));

    СоздатьКаталог(ПутьTar(КаталогИсточник, "data\nested"));
    ОписаниеБинарника = Новый Структура("binary, hex", Истина, "0102030405");
    ОжидаемыеФайлы.Вставить("data\nested\payload.bin", ОписаниеБинарника);
    ПолучитьДвоичныеДанныеИзHexСтроки("0102030405").Записать(ПутьTar(КаталогИсточник, "data\nested\payload.bin"));

    СоздатьКаталог(ПутьTar(КаталогИсточник, "config"));
    ОжидаемыеФайлы.Вставить("config\settings.json", "{""enabled"": true}");
    ПолучитьДвоичныеДанныеИзСтроки("{""enabled"": true}", "UTF-8").Записать(ПутьTar(КаталогИсточник, "config\settings.json"));

    OPI_Tar.АрхивироватьКаталог(КаталогИсточник, ПутьАрхива);

    ОжидаемыеЧастичные = Новый Соответствие;
    ОжидаемыеЧастичные.Вставить("readme.txt"   , "OpenIntegrations root");
    ОжидаемыеЧастичные.Вставить("docs\note.txt", "Nested documentation");

    ПутиЧастичные = Новый Массив;
    ПутиЧастичные.Добавить("readme.txt");
    ПутиЧастичные.Добавить("docs/note.txt");

    Параметры = Новый Структура;
    Параметры.Вставить("Tar_ArchivePath"      , ПутьАрхива);
    Параметры.Вставить("Tar_DestDir"          , КаталогНазначение);
    Параметры.Вставить("Tar_DestBufferDir"    , КаталогНазначениеБуфер);
    Параметры.Вставить("Tar_PartialPaths"     , ПутиЧастичные);
    Параметры.Вставить("Tar_PartialExpected"  , ОжидаемыеЧастичные);

    ZTar_РазархивироватьФайлы(Параметры);

    OPI_Инструменты.УдалитьФайлВПопытке(КаталогБазы, "Не удалось удалить каталог теста tar");

КонецПроцедуры

Процедура ZTar_ИзменениеАрхива() Экспорт

    КаталогБазы = КаталогВременныхФайлов()
        + "\opi_tar_modify_"
        + Формат(ТекущаяУниверсальнаяДатаВМиллисекундах(), "ЧГ=0");

    СоздатьКаталог(КаталогБазы);

    КаталогИсточник   = ПутьTar(КаталогБазы, "src");
    КаталогНазначение = ПутьTar(КаталогБазы, "out");
    ПутьАрхива        = ПутьTar(КаталогБазы, "archive.tar");
    ПутьАрхиваБуфер   = ПутьTar(КаталогБазы, "archive_buffer.tar");
    ПутьНовогоФайла   = ПутьTar(КаталогБазы, "extra_info.txt");

    СоздатьКаталог(КаталогИсточник);
    СоздатьКаталог(КаталогНазначение);

    ОжидаемыеФайлы = Новый Соответствие;

    ОжидаемыеФайлы.Вставить("readme.txt", "OpenIntegrations root");
    ПолучитьДвоичныеДанныеИзСтроки("OpenIntegrations root", "UTF-8").Записать(ПутьTar(КаталогИсточник, "readme.txt"));

    СоздатьКаталог(ПутьTar(КаталогИсточник, "docs"));
    ОжидаемыеФайлы.Вставить("docs\note.txt", "Nested documentation");
    ПолучитьДвоичныеДанныеИзСтроки("Nested documentation", "UTF-8").Записать(ПутьTar(КаталогИсточник, "docs\note.txt"));

    СоздатьКаталог(ПутьTar(КаталогИсточник, "data\nested"));
    ОписаниеБинарника = Новый Структура("binary, hex", Истина, "0102030405");
    ОжидаемыеФайлы.Вставить("data\nested\payload.bin", ОписаниеБинарника);
    ПолучитьДвоичныеДанныеИзHexСтроки("0102030405").Записать(ПутьTar(КаталогИсточник, "data\nested\payload.bin"));

    СоздатьКаталог(ПутьTar(КаталогИсточник, "config"));
    ОжидаемыеФайлы.Вставить("config\settings.json", "{""enabled"": true}");
    ПолучитьДвоичныеДанныеИзСтроки("{""enabled"": true}", "UTF-8").Записать(ПутьTar(КаталогИсточник, "config\settings.json"));

    OPI_Tar.АрхивироватьКаталог(КаталогИсточник, ПутьАрхива);
    КопироватьФайл(ПутьАрхива, ПутьАрхиваБуфер);

    ПолучитьДвоичныеДанныеИзСтроки("Added via path", "UTF-8").Записать(ПутьНовогоФайла);

    ОжидаемыеПослеИзменения = Новый Соответствие;
    ОжидаемыеПослеИзменения.Вставить("readme.txt"             , "Replaced readme content");
    ОжидаемыеПослеИзменения.Вставить("docs\note.txt"          , "Nested documentation");
    ОжидаемыеПослеИзменения.Вставить("data\nested\payload.bin", ОписаниеБинарника);
    ОжидаемыеПослеИзменения.Вставить("extra\info.txt"         , "Added via path");

    Параметры = Новый Структура;
    Параметры.Вставить("Tar_ArchivePath"        , ПутьАрхива);
    Параметры.Вставить("Tar_ArchiveBufferPath"  , ПутьАрхиваБуфер);
    Параметры.Вставить("Tar_DestDir"            , КаталогНазначение);
    Параметры.Вставить("Tar_NewFilePath"        , ПутьНовогоФайла);
    Параметры.Вставить("Tar_ExpectedAfterModify", ОжидаемыеПослеИзменения);

    ZTar_ИзменитьАрхив(Параметры);

    OPI_Инструменты.УдалитьФайлВПопытке(КаталогБазы, "Не удалось удалить каталог теста tar");

КонецПроцедуры

#КонецОбласти // ИзменениеАрхива

#КонецОбласти // ЗапускаемыеТесты

#КонецОбласти // СлужебныйПрограммныйИнтерфейс

#Область СлужебныеПроцедурыИФункции

#Область АтомарныеТесты

#Область Архивация

Процедура ZTar_ПолучитьСтруктуруНастроекАрхивации()

    Опции = Новый Структура;

    Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("tar", "ПолучитьСтруктуруНастроекАрхивации", Опции);

    // END

    OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "Tar", "ПолучитьСтруктуруНастроекАрхивации");

    Опции = Новый Структура;
    Опции.Вставить("empty", Истина);

    Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("tar", "ПолучитьСтруктуруНастроекАрхивации", Опции);
    OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "Tar", "ПолучитьСтруктуруНастроекАрхивации", "Пустая");

    Опции = Новый Структура;
    Опции.Вставить("empty", Ложь);
    Опции.Вставить("map", Истина);

    Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("tar", "ПолучитьСтруктуруНастроекАрхивации", Опции);
    OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "Tar", "ПолучитьСтруктуруНастроекАрхивации", "КакСоответствие");

КонецПроцедуры

Процедура ZTar_АрхивироватьКаталог(Параметры)

    OPI_ПолучениеДанныхТестов.ДополнитьПараметрыАрхива(Параметры, "Tar");

    Если Параметры.Свойство("Tar_SourceDir")
        И Параметры.Свойство("Tar_ArchivePath")
        И НЕ Параметры.Свойство("Tar_SourceDirCompress")
        И НЕ (Параметры.Свойство("Tar_ArchiveGzipPath") И НЕ Параметры.Свойство("Tar_Description")) Тогда

        КаталогИсточник = Параметры["Tar_SourceDir"];
        ПутьАрхива      = Параметры["Tar_ArchivePath"];

        Опции = Новый Структура;
        Опции.Вставить("src", КаталогИсточник);
        Опции.Вставить("dest", ПутьАрхива);

        Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("tar", "АрхивироватьКаталог", Опции);

        // END

        OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "Tar", "АрхивироватьКаталог", , ПутьАрхива);

        Опции = Новый Структура;
        Опции.Вставить("src", КаталогИсточник);

        Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("tar", "АрхивироватьКаталог", Опции);
        OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "Tar", "АрхивироватьКаталог", "ВПамять");

        Если Параметры.Свойство("Tar_Description") И Параметры.Свойство("Tar_ArchiveDescPath") Тогда

            Описание       = Параметры["Tar_Description"];
            ПутьАрхиваDesc = Параметры["Tar_ArchiveDescPath"];

            Опции = Новый Структура;
            Опции.Вставить("src", Описание);
            Опции.Вставить("dest", ПутьАрхиваDesc);

            Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("tar", "АрхивироватьКаталог", Опции);
            OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "Tar", "АрхивироватьКаталог", "ИзОписания", ПутьАрхиваDesc);

            Опции = Новый Структура;
            Опции.Вставить("src", Описание);

            Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("tar", "АрхивироватьКаталог", Опции);
            OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "Tar", "АрхивироватьКаталог", "ИзОписанияВПамять");

        КонецЕсли;

    КонецЕсли;

    Если Параметры.Свойство("Tar_ArchiveGzipPath")
        И Параметры.Свойство("Tar_SourceDir")
        И НЕ Параметры.Свойство("Tar_SourceDirCompress") Тогда

        КаталогИсточник         = Параметры["Tar_SourceDir"];
        ПутьАрхиваGzip          = Параметры["Tar_ArchiveGzipPath"];
        Опции = Новый Структура;
        Опции.Вставить("empty", Истина);

        Настройки = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("tar", "ПолучитьСтруктуруНастроекАрхивации", Опции);
        Настройки["gzip"]       = Истина;
        Настройки["gzip_level"] = 9;

        Опции = Новый Структура;
        Опции.Вставить("src", КаталогИсточник);
        Опции.Вставить("dest", ПутьАрхиваGzip);
        Опции.Вставить("settings", Настройки);

        Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("tar", "АрхивироватьКаталог", Опции);
        OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "Tar", "АрхивироватьКаталог", "СGzip", ПутьАрхиваGzip);

    КонецЕсли;

    Если Параметры.Свойство("Tar_SourceDirCompress") Тогда

        КаталогСжатие   = Параметры["Tar_SourceDirCompress"];
        ПутьАрхиваPlain = Параметры["Tar_ArchivePlainPath"];
        ПутьАрхиваGzip  = Параметры["Tar_ArchiveGzipPath"];

        Опции = Новый Структура;
        Опции.Вставить("src", КаталогСжатие);
        Опции.Вставить("dest", ПутьАрхиваPlain);

        Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("tar", "АрхивироватьКаталог", Опции);
        OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "Tar", "АрхивироватьКаталог", "БезGzip", ПутьАрхиваPlain);

        Опции = Новый Структура;
        Опции.Вставить("empty", Истина);

        НастройкиGzip = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("tar", "ПолучитьСтруктуруНастроекАрхивации", Опции);
        НастройкиGzip["gzip"]       = Истина;
        НастройкиGzip["gzip_level"] = 9;

        Опции = Новый Структура;
        Опции.Вставить("src", КаталогСжатие);
        Опции.Вставить("dest", ПутьАрхиваGzip);
        Опции.Вставить("settings", НастройкиGzip);

        Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("tar", "АрхивироватьКаталог", Опции);
        OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "Tar", "АрхивироватьКаталог", "СGzip", ПутьАрхиваGzip);

    КонецЕсли;

КонецПроцедуры

Процедура ZTar_РазархивироватьКаталог(Параметры)

    OPI_ПолучениеДанныхТестов.ДополнитьПараметрыАрхива(Параметры, "Tar");

    ПутьАрхива = Неопределено;

    Если Параметры.Свойство("Tar_ArchivePath") Тогда
        ПутьАрхива = Параметры["Tar_ArchivePath"];
    ИначеЕсли Параметры.Свойство("Tar_ArchiveGzipPath") Тогда
        ПутьАрхива = Параметры["Tar_ArchiveGzipPath"];
    КонецЕсли;

    Если ПутьАрхива <> Неопределено Тогда
        КаталогНазначение      = Параметры["Tar_DestDir"];
        КаталогНазначениеБуфер = Параметры["Tar_DestBufferDir"];
        ОжидаемыеФайлы         = Параметры["Tar_ExpectedFiles"];

        Опции = Новый Структура;
        Опции.Вставить("src", ПутьАрхива);
        Опции.Вставить("dest", КаталогНазначение);

        Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("tar", "РазархивироватьКаталог", Опции);

        // END

        OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "Tar", "РазархивироватьКаталог", , КаталогНазначение, ОжидаемыеФайлы);

        Опции = Новый Структура;
        Опции.Вставить("src", ПутьАрхива);

        Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("tar", "РазархивироватьКаталог", Опции);
        OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "Tar", "РазархивироватьКаталог", "ВОписание", "", ОжидаемыеФайлы);

        АрхивДвоичные = Новый ДвоичныеДанные(ПутьАрхива);

        Опции = Новый Структура;
        Опции.Вставить("src", АрхивДвоичные);
        Опции.Вставить("dest", КаталогНазначениеБуфер);

        Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("tar", "РазархивироватьКаталог", Опции);
        OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "Tar", "РазархивироватьКаталог", "ИзПамяти", КаталогНазначениеБуфер, ОжидаемыеФайлы);

        Опции = Новый Структура;
        Опции.Вставить("src", АрхивДвоичные);

        Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("tar", "РазархивироватьКаталог", Опции);
        OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "Tar", "РазархивироватьКаталог", "ВОписаниеИзПамяти", "", ОжидаемыеФайлы);

    КонецЕсли;

КонецПроцедуры

#КонецОбласти // Архивация

#Область ПолучениеМетаданных

Процедура ZTar_ПолучитьСписокФайлов(Параметры)

    ПутьАрхива = Неопределено;

    Если Параметры.Свойство("Tar_ArchivePath") Тогда
        ПутьАрхива = Параметры["Tar_ArchivePath"];
    ИначеЕсли Параметры.Свойство("Tar_ArchiveGzipPath") Тогда
        ПутьАрхива = Параметры["Tar_ArchiveGzipPath"];
    КонецЕсли;

    Если ПутьАрхива <> Неопределено Тогда
        ОжидаемыеФайлы = Параметры["Tar_ExpectedFiles"];

        Опции = Новый Структура;
        Опции.Вставить("src", ПутьАрхива);

        Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("tar", "ПолучитьСписокФайлов", Опции);

        // END

        OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "Tar", "ПолучитьСписокФайлов", , ОжидаемыеФайлы);

        АрхивДвоичные = Новый ДвоичныеДанные(ПутьАрхива);

        Опции = Новый Структура;
        Опции.Вставить("src", АрхивДвоичные);

        Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("tar", "ПолучитьСписокФайлов", Опции);
        OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "Tar", "ПолучитьСписокФайлов", "ИзПамяти", ОжидаемыеФайлы);

    КонецЕсли;

КонецПроцедуры

Процедура ZTar_ПолучитьМетаданные(Параметры)

    ПутьАрхива = Неопределено;

    Если Параметры.Свойство("Tar_ArchivePath") Тогда
        ПутьАрхива = Параметры["Tar_ArchivePath"];
    ИначеЕсли Параметры.Свойство("Tar_ArchiveGzipPath") Тогда
        ПутьАрхива = Параметры["Tar_ArchiveGzipPath"];
    КонецЕсли;

    Если ПутьАрхива <> Неопределено Тогда
        ОжидаемыеФайлы = Параметры["Tar_ExpectedFiles"];

        Опции = Новый Структура;
        Опции.Вставить("src", ПутьАрхива);

        Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("tar", "ПолучитьМетаданные", Опции);

        // END

        OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "Tar", "ПолучитьМетаданные", , ОжидаемыеФайлы);

        АрхивДвоичные = Новый ДвоичныеДанные(ПутьАрхива);

        Опции = Новый Структура;
        Опции.Вставить("src", АрхивДвоичные);

        Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("tar", "ПолучитьМетаданные", Опции);
        OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "Tar", "ПолучитьМетаданные", "ИзПамяти", ОжидаемыеФайлы);

    КонецЕсли;

    Если Параметры.Свойство("Tar_ArchiveGzipPath") И Параметры.Свойство("Tar_ArchivePlainPath") Тогда

        ПутьАрхиваPlain = Параметры["Tar_ArchivePlainPath"];
        ПутьАрхиваGzip  = Параметры["Tar_ArchiveGzipPath"];
        ОжидаемыеФайлы  = Параметры["Tar_ExpectedFiles"];

        Опции = Новый Структура;
        Опции.Вставить("src", ПутьАрхиваPlain);

        МетаданныеPlain = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("tar", "ПолучитьМетаданные", Опции);
        РазмерPlain     = МетаданныеPlain["archive_size"];

        ОжиданияМетаданных = Новый Структура;
        ОжиданияМетаданных.Вставить("archive_less_than", РазмерPlain);

        Опции = Новый Структура;
        Опции.Вставить("src", ПутьАрхиваGzip);

        Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("tar", "ПолучитьМетаданные", Опции);
        OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "Tar", "ПолучитьМетаданные", "СGzip", ОжидаемыеФайлы, ОжиданияМетаданных);

    КонецЕсли;

КонецПроцедуры

#КонецОбласти // ПолучениеМетаданных

#Область ИзменениеАрхива

Процедура ZTar_РазархивироватьФайлы(Параметры)

    OPI_ПолучениеДанныхТестов.ДополнитьПараметрыАрхива(Параметры, "Tar");

    ПутьАрхива             = Параметры["Tar_ArchivePath"];
    КаталогНазначение      = Параметры["Tar_DestDir"];
    КаталогНазначениеБуфер = Параметры["Tar_DestBufferDir"];
    ПутиЧастичные          = Параметры["Tar_PartialPaths"];
    ОжидаемыеФайлы         = Параметры["Tar_PartialExpected"];

    Опции = Новый Структура;
    Опции.Вставить("src", ПутьАрхива);
    Опции.Вставить("paths", ПутиЧастичные);
    Опции.Вставить("dest", КаталогНазначение);

    Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("tar", "РазархивироватьФайлы", Опции);

    // END

    OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "Tar", "РазархивироватьФайлы", , КаталогНазначение, ОжидаемыеФайлы);

    Опции = Новый Структура;
    Опции.Вставить("src", ПутьАрхива);
    Опции.Вставить("paths", ПутиЧастичные);

    Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("tar", "РазархивироватьФайлы", Опции);
    OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "Tar", "РазархивироватьФайлы", "ВОписание", "", ОжидаемыеФайлы);

    АрхивДвоичные = Новый ДвоичныеДанные(ПутьАрхива);

    Опции = Новый Структура;
    Опции.Вставить("src", АрхивДвоичные);
    Опции.Вставить("paths", ПутиЧастичные);
    Опции.Вставить("dest", КаталогНазначениеБуфер);

    Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("tar", "РазархивироватьФайлы", Опции);
    OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "Tar", "РазархивироватьФайлы", "ИзПамяти", КаталогНазначениеБуфер, ОжидаемыеФайлы);

    Опции = Новый Структура;
    Опции.Вставить("src", АрхивДвоичные);
    Опции.Вставить("paths", ПутиЧастичные);

    Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("tar", "РазархивироватьФайлы", Опции);
    OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "Tar", "РазархивироватьФайлы", "ВОписаниеИзПамяти", "", ОжидаемыеФайлы);

КонецПроцедуры

Процедура ZTar_ИзменитьАрхив(Параметры)

    OPI_ПолучениеДанныхТестов.ДополнитьПараметрыАрхива(Параметры, "Tar");

    ПутьАрхива        = Параметры["Tar_ArchivePath"];
    ПутьАрхиваБуфер   = Параметры["Tar_ArchiveBufferPath"];
    КаталогНазначение = Параметры["Tar_DestDir"];
    ПутьНовогоФайла   = Параметры["Tar_NewFilePath"];
    ОжидаемыеФайлы    = Параметры["Tar_ExpectedAfterModify"];

    ДобавляемыеФайлы = Новый Соответствие;
    ДобавляемыеФайлы.Вставить("extra/info.txt", ПутьНовогоФайла);
    ДобавляемыеФайлы.Вставить("readme.txt"    , ПолучитьДвоичныеДанныеИзСтроки("Replaced readme content", "UTF-8"));

    УдаляемыеПути = Новый Массив;
    УдаляемыеПути.Добавить("config/settings.json");
    УдаляемыеПути.Добавить("missing/path.txt");

    Опции = Новый Структура;
    Опции.Вставить("src", ПутьАрхива);
    Опции.Вставить("additions", ДобавляемыеФайлы);
    Опции.Вставить("deletions", УдаляемыеПути);

    Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("tar", "ИзменитьАрхив", Опции);

    // END

    OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "Tar", "ИзменитьАрхив", , ПутьАрхива);

    Опции = Новый Структура;
    Опции.Вставить("src", ПутьАрхива);

    СписокФайлов = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("tar", "ПолучитьСписокФайлов", Опции);
    OPI_ПолучениеДанныхТестов.ОбработатьCLI(СписокФайлов, "Tar", "ПолучитьСписокФайлов", "ПослеИзменения", ОжидаемыеФайлы);

    Опции = Новый Структура;
    Опции.Вставить("src", ПутьАрхива);
    Опции.Вставить("dest", КаталогНазначение);

    РезультатРаспаковки = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("tar", "РазархивироватьКаталог", Опции);
    OPI_ПолучениеДанныхТестов.ОбработатьCLI(РезультатРаспаковки, "Tar", "РазархивироватьКаталог", "ПослеИзменения", КаталогНазначение, ОжидаемыеФайлы);

    АрхивДвоичные = Новый ДвоичныеДанные(ПутьАрхиваБуфер);

    Опции = Новый Структура;
    Опции.Вставить("src", АрхивДвоичные);
    Опции.Вставить("additions", ДобавляемыеФайлы);
    Опции.Вставить("deletions", УдаляемыеПути);

    Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("tar", "ИзменитьАрхив", Опции);
    OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "Tar", "ИзменитьАрхив", "ИзПамяти");

    Опции = Новый Структура;
    Опции.Вставить("src", Результат);

    СписокФайлов = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("tar", "ПолучитьСписокФайлов", Опции);
    OPI_ПолучениеДанныхТестов.ОбработатьCLI(СписокФайлов, "Tar", "ПолучитьСписокФайлов", "ПослеИзмененияИзПамяти", ОжидаемыеФайлы);

КонецПроцедуры

#КонецОбласти // ИзменениеАрхива

#КонецОбласти // АтомарныеТесты

Функция ПутьTar(БазовыйКаталог, ОтносительныйПуть)

    Возврат СтрШаблон("%1/%2", БазовыйКаталог, ОтносительныйПуть);

КонецФункции

#КонецОбласти // СлужебныеПроцедурыИФункции


