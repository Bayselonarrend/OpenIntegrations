#Область ПрограммныйИнтерфейс

// Сериализовать данные
// Сериализует данные в формат MessagePack
//
// Параметры:
//  Данные - Произвольный - Коллекция для сериализации - value
//
// Возвращаемое значение:
//  ДвоичныеДанные - Сериализованные данные
Функция СериализоватьДанные(Знач Данные) Экспорт

    Контекст = НовыйКонтекстЗаписи();
    ЗаписатьЗначение(Данные, Контекст);

    Возврат ПолучитьДвоичныеДанныеИзКонтекстаЗаписи(Контекст);

КонецФункции

// Десериализовать данные
// Десериализует данные из формата MessagePack
//
// Параметры:
//  Данные - ДвоичныеДанные - Сериализованное значение - data
//
// Возвращаемое значение:
//  Произвольный - Восстановленное значение
Функция ДесериализоватьДанные(Знач Данные) Экспорт

    Буфер  = ПолучитьБуферДвоичныхДанныхИзДвоичныхДанных(Данные);
    Чтение = ПрочитатьЗначение(Буфер, 0);

    Возврат Чтение.Значение;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ЗаписатьЗначение(Знач Данные, Контекст)

    ТипДанных = ТипЗнч(Данные);

    Если Данные = Неопределено Тогда

        ЗаписатьNilВКонтекст(Контекст);

    ИначеЕсли ТипДанных = Тип("Булево") Тогда

        ЗаписатьБулевоВКонтекст(Данные, Контекст);

    ИначеЕсли ТипДанных = Тип("Строка") Тогда

        ЗаписатьСтрокуВКонтекст(Данные, Контекст);

    ИначеЕсли ТипДанных = Тип("ДвоичныеДанные") Тогда

        ЗаписатьБинарныеДанныеВКонтекст(Данные, Контекст);

    ИначеЕсли ТипДанных = Тип("Массив") Тогда

        ЗаписатьМассивВКонтекст(Данные, Контекст);

    ИначеЕсли ТипДанных = Тип("Структура")
        Или ТипДанных = Тип("Соответствие") Тогда

        ЗаписатьКартуВКонтекст(Данные, Контекст);

    ИначеЕсли ТипДанных = Тип("Число") Тогда

        ЗаписатьЧислоВКонтекст(Данные, Контекст);

    КонецЕсли;

КонецПроцедуры

Функция ПрочитатьЗначение(Знач Буфер, Знач Позиция)

    Тег = Буфер.Получить(Позиция);

    Если Тег <= _posFixintMax() Тогда
        Возврат РезультатЧтения(Тег, Позиция + 1);
    КонецЕсли;

    Если Тег >= _negFixintMin() Тогда
        Возврат РезультатЧтения(Тег - 256, Позиция + 1);
    КонецЕсли;

    Если Тег >= _fixstr() И Тег <= _fixstrMax() Тогда
        Возврат ПрочитатьСтрокуИзБуфера(Буфер, Позиция + 1, Тег - _fixstr());
    КонецЕсли;

    Если Тег = _str8() Тогда
        Длина = Буфер.Получить(Позиция + 1);
        Возврат ПрочитатьСтрокуИзБуфера(Буфер, Позиция + 2, Длина);
    КонецЕсли;

    Если Тег = _str16() Тогда
        ЧтениеДлины = ПрочитатьБеззнаковоеЦелое16ИзБуфера(Буфер, Позиция + 1);
        Возврат ПрочитатьСтрокуИзБуфера(Буфер, ЧтениеДлины.Позиция, ЧтениеДлины.Значение);
    КонецЕсли;

    Если Тег = _str32() Тогда
        ЧтениеДлины = ПрочитатьБеззнаковоеЦелое32ИзБуфера(Буфер, Позиция + 1);
        Возврат ПрочитатьСтрокуИзБуфера(Буфер, ЧтениеДлины.Позиция, ЧтениеДлины.Значение);
    КонецЕсли;

    Если Тег = _nil() Тогда
        Возврат РезультатЧтения(Неопределено, Позиция + 1);
    КонецЕсли;

    Если Тег = _false() Тогда
        Возврат РезультатЧтения(Ложь, Позиция + 1);
    КонецЕсли;

    Если Тег = _true() Тогда
        Возврат РезультатЧтения(Истина, Позиция + 1);
    КонецЕсли;

    Если Тег = _bin8() Тогда
        Длина = Буфер.Получить(Позиция + 1);
        Возврат ПрочитатьБинарныеДанныеИзБуфера(Буфер, Позиция + 2, Длина);
    КонецЕсли;

    Если Тег = _bin16() Тогда
        ЧтениеДлины = ПрочитатьБеззнаковоеЦелое16ИзБуфера(Буфер, Позиция + 1);
        Возврат ПрочитатьБинарныеДанныеИзБуфера(Буфер, ЧтениеДлины.Позиция, ЧтениеДлины.Значение);
    КонецЕсли;

    Если Тег = _bin32() Тогда
        ЧтениеДлины = ПрочитатьБеззнаковоеЦелое32ИзБуфера(Буфер, Позиция + 1);
        Возврат ПрочитатьБинарныеДанныеИзБуфера(Буфер, ЧтениеДлины.Позиция, ЧтениеДлины.Значение);
    КонецЕсли;

    Если Тег >= _fixmap() И Тег <= _fixmapMax() Тогда
        Возврат ПрочитатьКартуИзБуфера(Буфер, Позиция + 1, Тег - _fixmap());
    КонецЕсли;

    Если Тег = _map16() Тогда
        ЧтениеДлины = ПрочитатьБеззнаковоеЦелое16ИзБуфера(Буфер, Позиция + 1);
        Возврат ПрочитатьКартуИзБуфера(Буфер, ЧтениеДлины.Позиция, ЧтениеДлины.Значение);
    КонецЕсли;

    Если Тег = _map32() Тогда
        ЧтениеДлины = ПрочитатьБеззнаковоеЦелое32ИзБуфера(Буфер, Позиция + 1);
        Возврат ПрочитатьКартуИзБуфера(Буфер, ЧтениеДлины.Позиция, ЧтениеДлины.Значение);
    КонецЕсли;

    Если Тег >= _fixarray() И Тег <= _fixarrayMax() Тогда
        Возврат ПрочитатьМассивИзБуфера(Буфер, Позиция + 1, Тег - _fixarray());
    КонецЕсли;

    Если Тег = _array16() Тогда
        ЧтениеДлины = ПрочитатьБеззнаковоеЦелое16ИзБуфера(Буфер, Позиция + 1);
        Возврат ПрочитатьМассивИзБуфера(Буфер, ЧтениеДлины.Позиция, ЧтениеДлины.Значение);
    КонецЕсли;

    Если Тег = _array32() Тогда
        ЧтениеДлины = ПрочитатьБеззнаковоеЦелое32ИзБуфера(Буфер, Позиция + 1);
        Возврат ПрочитатьМассивИзБуфера(Буфер, ЧтениеДлины.Позиция, ЧтениеДлины.Значение);
    КонецЕсли;

    ЧтениеЧисла = ПрочитатьЧисло(Буфер, Позиция, Тег);

    Если ЧтениеЧисла <> Неопределено Тогда
        Возврат ЧтениеЧисла;
    КонецЕсли;

    ВызватьИсключение "Неподдерживаемый тег MessagePack: " + Формат(Тег, "ЧН=0; ЧГ=");

КонецФункции

#Область Общее

Функция НачальныйРазмерБуфераСериализации()

    Возврат 65536;

КонецФункции

Функция НовыйКонтекстЗаписи()

    Емкость = НачальныйРазмерБуфераСериализации();
    Буфер   = Новый БуферДвоичныхДанных(Емкость, ПорядокБайтов.BigEndian);

    Возврат Новый Структура("Буфер, Позиция, Емкость", Буфер, 0, Емкость);

КонецФункции

Процедура ОбеспечитьЕмкостьКонтекста(Контекст, Знач НужноБайт)

    Если НужноБайт <= Контекст.Емкость - Контекст.Позиция Тогда
        Возврат;
    КонецЕсли;

    НоваяЕмкость = Контекст.Емкость;

    Пока НоваяЕмкость - Контекст.Позиция < НужноБайт Цикл
        НоваяЕмкость = НоваяЕмкость * 2;
    КонецЦикла;

    НовыйБуфер = Новый БуферДвоичныхДанных(НоваяЕмкость, ПорядокБайтов.BigEndian);

    Если Контекст.Позиция > 0 Тогда
        Фрагмент = Контекст.Буфер.Прочитать(0, Контекст.Позиция);
        НовыйБуфер.Записать(0, Фрагмент);
    КонецЕсли;

    Контекст.Буфер   = НовыйБуфер;
    Контекст.Емкость = НоваяЕмкость;

КонецПроцедуры

Процедура ЗаписатьБайтВКонтекст(Контекст, Знач Байт)

    ОбеспечитьЕмкостьКонтекста(Контекст, 1);
    Контекст.Буфер.Установить(Контекст.Позиция, Байт);
    Контекст.Позиция = Контекст.Позиция + 1;

КонецПроцедуры

Функция ПолучитьДвоичныеДанныеИзКонтекстаЗаписи(Знач Контекст)

    Если Контекст.Позиция = 0 Тогда
        Возврат ПолучитьДвоичныеДанныеИзСтроки("");
    КонецЕсли;

    Если Контекст.Позиция = Контекст.Емкость Тогда
        Возврат ПолучитьДвоичныеДанныеИзБуфераДвоичныхДанных(Контекст.Буфер);
    КонецЕсли;

    Фрагмент = Контекст.Буфер.Прочитать(0, Контекст.Позиция);

    Возврат ПолучитьДвоичныеДанныеИзБуфераДвоичныхДанных(Фрагмент);

КонецФункции

Функция РезультатЧтения(Знач Значение, Знач Позиция)

    Возврат Новый Структура("Значение, Позиция", Значение, Позиция);

КонецФункции

Функция ПрочитатьБеззнаковоеЦелое16ИзБуфера(Знач Буфер, Знач Позиция)

    Байт0 = Буфер.Получить(Позиция);
    Байт1 = Буфер.Получить(Позиция + 1);

    Возврат РезультатЧтения(Байт0 * 256 + Байт1, Позиция + 2);

КонецФункции

Функция ПрочитатьБеззнаковоеЦелое32ИзБуфера(Знач Буфер, Знач Позиция)

    Значение = Буфер.ПрочитатьЦелое32(Позиция);

    Если Значение < 0 Тогда
        Значение = Значение + 4294967296;
    КонецЕсли;

    Возврат РезультатЧтения(Значение, Позиция + 4);

КонецФункции

Функция ПрочитатьБеззнаковоеЦелое64ИзБуфера(Знач Буфер, Знач Позиция)

    Значение = Буфер.ПрочитатьЦелое64(Позиция);

    Если Значение < 0 Тогда
        Значение = Значение + 18446744073709551616;
    КонецЕсли;

    Возврат РезультатЧтения(Значение, Позиция + 8);

КонецФункции

Функция ПрочитатьЗнаковоеЦелое8ИзБуфера(Знач Буфер, Знач Позиция)

    Байт = Буфер.Получить(Позиция);

    Если Байт >= 128 Тогда
        Байт = Байт - 256;
    КонецЕсли;

    Возврат РезультатЧтения(Байт, Позиция + 1);

КонецФункции

Функция ПрочитатьЗнаковоеЦелое16ИзБуфера(Знач Буфер, Знач Позиция)

    Значение = Буфер.ПрочитатьЦелое16(Позиция);

    Возврат РезультатЧтения(Значение, Позиция + 2);

КонецФункции

Функция ПрочитатьЗнаковоеЦелое32ИзБуфера(Знач Буфер, Знач Позиция)

    Значение = Буфер.ПрочитатьЦелое32(Позиция);

    Возврат РезультатЧтения(Значение, Позиция + 4);

КонецФункции

Функция ПрочитатьЗнаковоеЦелое64ИзБуфера(Знач Буфер, Знач Позиция)

    Значение = Буфер.ПрочитатьЦелое64(Позиция);

    Возврат РезультатЧтения(Значение, Позиция + 8);

КонецФункции

Функция ПрочитатьВещественное32ИзБуфера(Знач Буфер, Знач Позиция)

    БуферЧисла = Буфер.Прочитать(Позиция, 4);
    Значение   = ДекодироватьFloat32BE(БуферЧисла);

    Возврат РезультатЧтения(Значение, Позиция + 4);

КонецФункции

Функция ПрочитатьВещественное64ИзБуфера(Знач Буфер, Знач Позиция)

    БуферЧисла = Буфер.Прочитать(Позиция, 8);
    Значение   = ДекодироватьFloat64BE(БуферЧисла);

    Возврат РезультатЧтения(Значение, Позиция + 8);

КонецФункции

Функция ДелительМантиссыFloat32()

    Возврат 8388608;

КонецФункции

Функция ДелительМантиссыFloat64()

    Возврат 4503599627370496;

КонецФункции

Функция ПолучитьНесмещеннуюЭкспонентуIEEE754(Знач Абс)

    ЭкспНеСмещ = Цел(Log(Абс) / Log(2));

    Пока Абс < Pow(2, ЭкспНеСмещ) Цикл
        ЭкспНеСмещ = ЭкспНеСмещ - 1;
    КонецЦикла;

    Возврат ЭкспНеСмещ;

КонецФункции

Функция ЗакодироватьFloat32BE(Знач Число)

    Буфер = Новый БуферДвоичныхДанных(4, ПорядокБайтов.BigEndian);

    Если Число = 0 Тогда
        Возврат Буфер;
    КонецЕсли;

    Знак = ?(Число < 0, 1, 0);
    Абс  = ?(Число < 0, -Число, Число);

    ЭкспНеСмещ  = ПолучитьНесмещеннуюЭкспонентуIEEE754(Абс);
    Доля        = Абс / Pow(2, ЭкспНеСмещ);
    Мантисса    = (Доля - 1) * ДелительМантиссыFloat32();
    МантиссаЦел = Цел(Окр(Мантисса, 0));
    ЭкспСмещ    = ЭкспНеСмещ + 127;

    Буфер.Установить(0, Знак * 128 + Цел(ЭкспСмещ / 2));
    Буфер.Установить(1, (ЭкспСмещ % 2) * 128 + Цел(МантиссаЦел / 65536));

    ОстатокМантиссы = МантиссаЦел % 65536;
    Буфер.Установить(2, Цел(ОстатокМантиссы / 256));
    Буфер.Установить(3, ОстатокМантиссы % 256);

    Возврат Буфер;

КонецФункции

Функция ДекодироватьFloat32BE(Знач Буфер)

    Байт0 = Буфер.Получить(0);
    Байт1 = Буфер.Получить(1);

    Знак       = ?(Байт0 >= 128, -1, 1);
    Экспонента = (Байт0 % 128) * 2 + Цел(Байт1 / 128);
    Мантисса   = (Байт1 % 128) * 65536 + Буфер.Получить(2) * 256 + Буфер.Получить(3);

    Если Экспонента = 0 И Мантисса = 0 Тогда
        Возврат 0;
    КонецЕсли;

    Возврат Знак * (1 + Мантисса / ДелительМантиссыFloat32()) * Pow(2, Экспонента - 127);

КонецФункции

Функция ЗакодироватьFloat64BE(Знач Число)

    Буфер = Новый БуферДвоичныхДанных(8, ПорядокБайтов.BigEndian);

    Если Число = 0 Тогда
        Возврат Буфер;
    КонецЕсли;

    Знак = ?(Число < 0, 1, 0);
    Абс  = ?(Число < 0, -Число, Число);

    ЭкспНеСмещ  = ПолучитьНесмещеннуюЭкспонентуIEEE754(Абс);
    Доля        = Абс / Pow(2, ЭкспНеСмещ);
    Мантисса    = (Доля - 1) * ДелительМантиссыFloat64();
    МантиссаЦел = Цел(Окр(Мантисса, 0));
    ЭкспСмещ    = ЭкспНеСмещ + 1023;

    Буфер.Установить(0, Знак * 128 + Цел(ЭкспСмещ / 16));
    Буфер.Установить(1, (ЭкспСмещ % 16) * 16 + Цел(МантиссаЦел / Pow(2, 48)));

    ОстатокМантиссы = МантиссаЦел % Pow(2, 48);

    Для Индекс = 2 По 7 Цикл
        Сдвиг = (7 - Индекс) * 8;
        Буфер.Установить(Индекс, Цел(ОстатокМантиссы / Pow(2, Сдвиг)) % 256);
    КонецЦикла;

    Возврат Буфер;

КонецФункции

Функция ДекодироватьFloat64BE(Знач Буфер)

    Байт0 = Буфер.Получить(0);
    Байт1 = Буфер.Получить(1);

    Знак       = ?(Байт0 >= 128, -1, 1);
    Экспонента = (Байт0 % 128) * 16 + Цел(Байт1 / 16);
    Мантисса   = (Байт1 % 16) * Pow(2, 48);

    Для Индекс = 2 По 7 Цикл
        Мантисса = Мантисса + Буфер.Получить(Индекс) * Pow(2, (7 - Индекс) * 8);
    КонецЦикла;

    Если Экспонента = 0 И Мантисса = 0 Тогда
        Возврат 0;
    КонецЕсли;

    Возврат Знак * (1 + Мантисса / ДелительМантиссыFloat64()) * Pow(2, Экспонента - 1023);

КонецФункции

#КонецОбласти

#Область ТипNil

Процедура ЗаписатьNilВКонтекст(Контекст)

    ЗаписатьБайтВКонтекст(Контекст, _nil());

КонецПроцедуры

#КонецОбласти

#Область ТипБулево

Процедура ЗаписатьБулевоВКонтекст(Знач Данные, Контекст)

    ЗаписатьБайтВКонтекст(Контекст, ?(Данные, _true(), _false()));

КонецПроцедуры

#КонецОбласти

#Область ТипСтрока

Процедура ЗаписатьСтрокуВКонтекст(Знач Данные, Контекст)

    СтрокаДД     = ПолучитьДвоичныеДанныеИзСтроки(Данные, "UTF-8");
    РазмерДанных = СтрокаДД.Размер();
    СтрокаБуфер  = ПолучитьБуферДвоичныхДанныхИзДвоичныхДанных(СтрокаДД);

    Если РазмерДанных < 32 Тогда

        ОбеспечитьЕмкостьКонтекста(Контекст, 1 + РазмерДанных);
        Контекст.Буфер.Установить(Контекст.Позиция, _fixstr() + РазмерДанных);
        Контекст.Буфер.Записать(Контекст.Позиция + 1, СтрокаБуфер);
        Контекст.Позиция = Контекст.Позиция + 1 + РазмерДанных;

    ИначеЕсли РазмерДанных < 256 Тогда

        ОбеспечитьЕмкостьКонтекста(Контекст, 2 + РазмерДанных);
        Контекст.Буфер.Установить(Контекст.Позиция    , _str8());
        Контекст.Буфер.Установить(Контекст.Позиция + 1, РазмерДанных);
        Контекст.Буфер.Записать(Контекст.Позиция + 2, СтрокаБуфер);
        Контекст.Позиция = Контекст.Позиция + 2 + РазмерДанных;

    ИначеЕсли РазмерДанных < 65536 Тогда

        ОбеспечитьЕмкостьКонтекста(Контекст, 3 + РазмерДанных);
        Контекст.Буфер.Установить(Контекст.Позиция, _str16());
        Контекст.Буфер.ЗаписатьЦелое16(Контекст.Позиция + 1, РазмерДанных);
        Контекст.Буфер.Записать(Контекст.Позиция + 3, СтрокаБуфер);
        Контекст.Позиция = Контекст.Позиция + 3 + РазмерДанных;

    Иначе

        ОбеспечитьЕмкостьКонтекста(Контекст, 5 + РазмерДанных);
        Контекст.Буфер.Установить(Контекст.Позиция, _str32());
        Контекст.Буфер.ЗаписатьЦелое32(Контекст.Позиция + 1, РазмерДанных);
        Контекст.Буфер.Записать(Контекст.Позиция + 5, СтрокаБуфер);
        Контекст.Позиция = Контекст.Позиция + 5 + РазмерДанных;

    КонецЕсли;

КонецПроцедуры

Функция ПрочитатьСтрокуИзБуфера(Знач Буфер, Знач Позиция, Знач Длина)

    Если Длина = 0 Тогда
        Возврат РезультатЧтения("", Позиция);
    КонецЕсли;

    ФрагментБуфер = Буфер.Прочитать(Позиция, Длина);
    ФрагментДД    = ПолучитьДвоичныеДанныеИзБуфераДвоичныхДанных(ФрагментБуфер);
    Строка        = ПолучитьСтрокуИзДвоичныхДанных(ФрагментДД, "UTF-8");

    Возврат РезультатЧтения(Строка, Позиция + Длина);

КонецФункции

#КонецОбласти

#Область ТипБинарные

Процедура ЗаписатьБинарныеДанныеВКонтекст(Знач Данные, Контекст)

    РазмерДанных = Данные.Размер();
    ТелоБуфер    = ПолучитьБуферДвоичныхДанныхИзДвоичныхДанных(Данные);

    Если РазмерДанных < 256 Тогда

        ОбеспечитьЕмкостьКонтекста(Контекст, 2 + РазмерДанных);
        Контекст.Буфер.Установить(Контекст.Позиция    , _bin8());
        Контекст.Буфер.Установить(Контекст.Позиция + 1, РазмерДанных);
        Контекст.Буфер.Записать(Контекст.Позиция + 2, ТелоБуфер);
        Контекст.Позиция = Контекст.Позиция + 2 + РазмерДанных;

    ИначеЕсли РазмерДанных < 65536 Тогда

        ОбеспечитьЕмкостьКонтекста(Контекст, 3 + РазмерДанных);
        Контекст.Буфер.Установить(Контекст.Позиция, _bin16());
        Контекст.Буфер.ЗаписатьЦелое16(Контекст.Позиция + 1, РазмерДанных);
        Контекст.Буфер.Записать(Контекст.Позиция + 3, ТелоБуфер);
        Контекст.Позиция = Контекст.Позиция + 3 + РазмерДанных;

    Иначе

        ОбеспечитьЕмкостьКонтекста(Контекст, 5 + РазмерДанных);
        Контекст.Буфер.Установить(Контекст.Позиция, _bin32());
        Контекст.Буфер.ЗаписатьЦелое32(Контекст.Позиция + 1, РазмерДанных);
        Контекст.Буфер.Записать(Контекст.Позиция + 5, ТелоБуфер);
        Контекст.Позиция = Контекст.Позиция + 5 + РазмерДанных;

    КонецЕсли;

КонецПроцедуры

Функция ПрочитатьБинарныеДанныеИзБуфера(Знач Буфер, Знач Позиция, Знач Длина)

    Если Длина = 0 Тогда
        Возврат РезультатЧтения(ПолучитьДвоичныеДанныеИзСтроки(""), Позиция);
    КонецЕсли;

    ФрагментБуфер = Буфер.Прочитать(Позиция, Длина);
    ФрагментДД    = ПолучитьДвоичныеДанныеИзБуфераДвоичныхДанных(ФрагментБуфер);

    Возврат РезультатЧтения(ФрагментДД, Позиция + Длина);

КонецФункции

#КонецОбласти

#Область ТипМассив

Процедура ЗаписатьМассивВКонтекст(Знач Данные, Контекст)

    КоличествоЭлементов = Данные.Количество();

    Если КоличествоЭлементов <= 15 Тогда

        ЗаписатьБайтВКонтекст(Контекст, _fixarray() + КоличествоЭлементов);

    ИначеЕсли КоличествоЭлементов < 65536 Тогда

        ОбеспечитьЕмкостьКонтекста(Контекст, 3);
        Контекст.Буфер.Установить(Контекст.Позиция, _array16());
        Контекст.Буфер.ЗаписатьЦелое16(Контекст.Позиция + 1, КоличествоЭлементов);
        Контекст.Позиция = Контекст.Позиция + 3;

    Иначе

        ОбеспечитьЕмкостьКонтекста(Контекст, 5);
        Контекст.Буфер.Установить(Контекст.Позиция, _array32());
        Контекст.Буфер.ЗаписатьЦелое32(Контекст.Позиция + 1, КоличествоЭлементов);
        Контекст.Позиция = Контекст.Позиция + 5;

    КонецЕсли;

    Для Каждого Элемент Из Данные Цикл
        ЗаписатьЗначение(Элемент, Контекст);
    КонецЦикла;

КонецПроцедуры

Функция ПрочитатьМассивИзБуфера(Знач Буфер, Знач Позиция, Знач КоличествоЭлементов)

    Массив = Новый Массив;

    Для Индекс = 1 По КоличествоЭлементов Цикл

        ЧтениеЭлемента = ПрочитатьЗначение(Буфер, Позиция);
        Массив.Добавить(ЧтениеЭлемента.Значение);
        Позиция        = ЧтениеЭлемента.Позиция;

    КонецЦикла;

    Возврат РезультатЧтения(Массив, Позиция);

КонецФункции

#КонецОбласти

#Область ТипКарта

Процедура ЗаписатьКартуВКонтекст(Знач Данные, Контекст)

    КоличествоПар = 0;

    Для Каждого Пара Из Данные Цикл
        КоличествоПар = КоличествоПар + 1;
    КонецЦикла;

    Если КоличествоПар <= 15 Тогда

        ЗаписатьБайтВКонтекст(Контекст, _fixmap() + КоличествоПар);

    ИначеЕсли КоличествоПар < 65536 Тогда

        ОбеспечитьЕмкостьКонтекста(Контекст, 3);
        Контекст.Буфер.Установить(Контекст.Позиция, _map16());
        Контекст.Буфер.ЗаписатьЦелое16(Контекст.Позиция + 1, КоличествоПар);
        Контекст.Позиция = Контекст.Позиция + 3;

    Иначе

        ОбеспечитьЕмкостьКонтекста(Контекст, 5);
        Контекст.Буфер.Установить(Контекст.Позиция, _map32());
        Контекст.Буфер.ЗаписатьЦелое32(Контекст.Позиция + 1, КоличествоПар);
        Контекст.Позиция = Контекст.Позиция + 5;

    КонецЕсли;

    Для Каждого Пара Из Данные Цикл

        Если ТипЗнч(Пара.Ключ) = Тип("Строка") Тогда
            ЗаписатьСтрокуВКонтекст(Пара.Ключ        , Контекст);
        Иначе
            ЗаписатьСтрокуВКонтекст(Строка(Пара.Ключ), Контекст);
        КонецЕсли;

        ЗаписатьЗначение(Пара.Значение, Контекст);

    КонецЦикла;

КонецПроцедуры

Функция ПрочитатьКартуИзБуфера(Знач Буфер, Знач Позиция, Знач КоличествоПар)

    Карта = Новый Соответствие;

    Для Индекс = 1 По КоличествоПар Цикл

        ЧтениеКлюча = ПрочитатьЗначение(Буфер, Позиция);
        Позиция     = ЧтениеКлюча.Позиция;

        Если ТипЗнч(ЧтениеКлюча.Значение) <> Тип("Строка") Тогда
            ВызватьИсключение "Ключ map MessagePack должен быть строкой";
        КонецЕсли;

        ЧтениеЗначения = ПрочитатьЗначение(Буфер, Позиция);
        Карта.Вставить(ЧтениеКлюча.Значение, ЧтениеЗначения.Значение);
        Позиция        = ЧтениеЗначения.Позиция;

    КонецЦикла;

    Возврат РезультатЧтения(Карта, Позиция);

КонецФункции

#КонецОбласти

#Область ТипЧисло

Процедура ЗаписатьЧислоВКонтекст(Знач Данные, Контекст)

    Если Данные = Цел(Данные) Тогда

        Если Данные >= 0 Тогда
            ЗаписатьПоложительноеЦелоеВКонтекст(Данные, Контекст);
        Иначе
            ЗаписатьОтрицательноеЦелоеВКонтекст(Данные, Контекст);
        КонецЕсли;

    Иначе
        ЗаписатьВещественноеЧислоВКонтекст(Данные, Контекст);
    КонецЕсли;

КонецПроцедуры

Процедура ЗаписатьВещественноеЧислоВКонтекст(Знач Число, Контекст)

    БуферПроверки = ЗакодироватьFloat32BE(Число);

    Если ДекодироватьFloat32BE(БуферПроверки) = Число Тогда
        ЗаписатьВещественное32ВКонтекст(Число, Контекст);
    Иначе
        ЗаписатьВещественное64ВКонтекст(Число, Контекст);
    КонецЕсли;

КонецПроцедуры

Процедура ЗаписатьВещественное32ВКонтекст(Знач Число, Контекст)

    Тело = ЗакодироватьFloat32BE(Число);

    ОбеспечитьЕмкостьКонтекста(Контекст, 5);
    Контекст.Буфер.Установить(Контекст.Позиция, _float32());
    Контекст.Буфер.Записать(Контекст.Позиция + 1, Тело);
    Контекст.Позиция = Контекст.Позиция + 5;

КонецПроцедуры

Процедура ЗаписатьВещественное64ВКонтекст(Знач Число, Контекст)

    Тело = ЗакодироватьFloat64BE(Число);

    ОбеспечитьЕмкостьКонтекста(Контекст, 9);
    Контекст.Буфер.Установить(Контекст.Позиция, _float64());
    Контекст.Буфер.Записать(Контекст.Позиция + 1, Тело);
    Контекст.Позиция = Контекст.Позиция + 9;

КонецПроцедуры

Процедура ЗаписатьПоложительноеЦелоеВКонтекст(Знач Число, Контекст)

    Если Число <= _posFixintMax() Тогда

        ЗаписатьБайтВКонтекст(Контекст, Число);

    ИначеЕсли Число < 256 Тогда

        ОбеспечитьЕмкостьКонтекста(Контекст, 2);
        Контекст.Буфер.Установить(Контекст.Позиция    , _uint8());
        Контекст.Буфер.Установить(Контекст.Позиция + 1, Число);
        Контекст.Позиция = Контекст.Позиция + 2;

    ИначеЕсли Число < 65536 Тогда

        ОбеспечитьЕмкостьКонтекста(Контекст, 3);
        Контекст.Буфер.Установить(Контекст.Позиция, _uint16());
        Контекст.Буфер.ЗаписатьЦелое16(Контекст.Позиция + 1, Число);
        Контекст.Позиция = Контекст.Позиция + 3;

    ИначеЕсли Число < 4294967296 Тогда

        ОбеспечитьЕмкостьКонтекста(Контекст, 5);
        Контекст.Буфер.Установить(Контекст.Позиция, _uint32());
        Контекст.Буфер.ЗаписатьЦелое32(Контекст.Позиция + 1, Число);
        Контекст.Позиция = Контекст.Позиция + 5;

    Иначе

        ОбеспечитьЕмкостьКонтекста(Контекст, 9);
        Контекст.Буфер.Установить(Контекст.Позиция, _uint64());
        Контекст.Буфер.ЗаписатьЦелое64(Контекст.Позиция + 1, Число);
        Контекст.Позиция = Контекст.Позиция + 9;

    КонецЕсли;

КонецПроцедуры

Процедура ЗаписатьОтрицательноеЦелоеВКонтекст(Знач Число, Контекст)

    Если Число >= -32 Тогда

        ЗаписатьБайтВКонтекст(Контекст, _negFixintMin() + 32 + Число);

    ИначеЕсли Число >= -128 Тогда

        ОбеспечитьЕмкостьКонтекста(Контекст, 2);
        Контекст.Буфер.Установить(Контекст.Позиция    , _int8());
        Контекст.Буфер.Установить(Контекст.Позиция + 1, _negFixintMin() + 32 + Число);
        Контекст.Позиция = Контекст.Позиция + 2;

    ИначеЕсли Число >= -32768 Тогда

        ОбеспечитьЕмкостьКонтекста(Контекст, 3);
        Контекст.Буфер.Установить(Контекст.Позиция, _int16());
        Контекст.Буфер.ЗаписатьЦелое16(Контекст.Позиция + 1, Число);
        Контекст.Позиция = Контекст.Позиция + 3;

    ИначеЕсли Число >= -2147483648 Тогда

        ОбеспечитьЕмкостьКонтекста(Контекст, 5);
        Контекст.Буфер.Установить(Контекст.Позиция, _int32());
        Контекст.Буфер.ЗаписатьЦелое32(Контекст.Позиция + 1, Число);
        Контекст.Позиция = Контекст.Позиция + 5;

    Иначе

        ОбеспечитьЕмкостьКонтекста(Контекст, 9);
        Контекст.Буфер.Установить(Контекст.Позиция, _int64());
        Контекст.Буфер.ЗаписатьЦелое64(Контекст.Позиция + 1, Число);
        Контекст.Позиция = Контекст.Позиция + 9;

    КонецЕсли;

КонецПроцедуры

Функция ПрочитатьЧисло(Знач Буфер, Знач Позиция, Знач Тег)

    Если Тег = _uint8() Тогда
        Возврат РезультатЧтения(Буфер.Получить(Позиция + 1), Позиция + 2);
    КонецЕсли;

    Если Тег = _uint16() Тогда
        Возврат ПрочитатьБеззнаковоеЦелое16ИзБуфера(Буфер, Позиция + 1);
    КонецЕсли;

    Если Тег = _uint32() Тогда
        Возврат ПрочитатьБеззнаковоеЦелое32ИзБуфера(Буфер, Позиция + 1);
    КонецЕсли;

    Если Тег = _uint64() Тогда
        Возврат ПрочитатьБеззнаковоеЦелое64ИзБуфера(Буфер, Позиция + 1);
    КонецЕсли;

    Если Тег = _int8() Тогда
        Возврат ПрочитатьЗнаковоеЦелое8ИзБуфера(Буфер, Позиция + 1);
    КонецЕсли;

    Если Тег = _int16() Тогда
        Возврат ПрочитатьЗнаковоеЦелое16ИзБуфера(Буфер, Позиция + 1);
    КонецЕсли;

    Если Тег = _int32() Тогда
        Возврат ПрочитатьЗнаковоеЦелое32ИзБуфера(Буфер, Позиция + 1);
    КонецЕсли;

    Если Тег = _int64() Тогда
        Возврат ПрочитатьЗнаковоеЦелое64ИзБуфера(Буфер, Позиция + 1);
    КонецЕсли;

    Если Тег = _float32() Тогда
        Возврат ПрочитатьВещественное32ИзБуфера(Буфер, Позиция + 1);
    КонецЕсли;

    Если Тег = _float64() Тогда
        Возврат ПрочитатьВещественное64ИзБуфера(Буфер, Позиция + 1);
    КонецЕсли;

    Возврат Неопределено;

КонецФункции

