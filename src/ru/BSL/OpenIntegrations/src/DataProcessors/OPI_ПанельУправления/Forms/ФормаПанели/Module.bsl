Функция ПолучитьCSSПанели()

    Стили = OPI_Инструменты.ПолучитьТекстовыйМакет("OPI_Text_PanelStyles");

    Если ИспользуетсяТемнаяТема() Тогда
        Стили = Стили + Символы.ПС + OPI_Инструменты.ПолучитьТекстовыйМакет("OPI_Text_PanelThemeDark");
    КонецЕсли;

    Возврат Стили;

КонецФункции

&НаСервере
Функция ПолучитьСкриптыПанели(АрхивРелизов = Неопределено)

    Скрипты = "<script>" + OPI_Инструменты.ПолучитьТекстовыйМакет("OPI_Text_PanelScript") + "</script>";
    Скрипты = Скрипты + "<script>" + ТекстСкриптаАрхиваРелизов(АрхивРелизов) + "</script>";

    Возврат Скрипты;

КонецФункции

&НаКлиенте
Процедура УстановитьТекстУзлаHTML(Узел, Знач Текст)

    Если Узел = Неопределено Тогда
        Возврат;
    КонецЕсли;

    Попытка
        Узел.textContent = Строка(Текст);
    Исключение
        Попытка
            Узел.innerText  = Строка(Текст);
        Исключение
            Возврат;
        КонецПопытки;
    КонецПопытки;

КонецПроцедуры

