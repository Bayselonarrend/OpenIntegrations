&НаКлиенте
Функция ПолучитьВыбранноеЗеркалоИзДокумента(Документ)

    Если Документ = Неопределено Тогда
        Документ = Элементы.HTML.Документ;
    КонецЕсли;

    Если Документ = Неопределено Тогда
        Возврат "github";
    КонецЕсли;

    Попытка

        ЭлементыВвода = Документ.getElementsByTagName("input");

        Для Индекс = 0 По ЭлементыВвода.length - 1 Цикл

            ЭлементВвода = ЭлементыВвода[Индекс];

            Если ЭлементВвода = Неопределено Тогда
                Прервать;
            КонецЕсли;

            Если ЭлементВвода.name = "opi-mirror" И ЭлементВвода.checked Тогда
                Возврат ЭлементВвода.value;
            КонецЕсли;

        КонецЦикла;

    Исключение
        Возврат "github";
    КонецПопытки;

    Возврат "github";

КонецФункции

