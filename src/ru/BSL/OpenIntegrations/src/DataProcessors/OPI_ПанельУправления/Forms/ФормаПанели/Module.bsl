&НаКлиенте
Процедура ОткрытьАрхивРелизов(Документ = Неопределено)

	ВерсияРелиза = ПолучитьВыбраннуюВерсиюРелизаИзДокумента(Документ);
	АдресСтраницы = "https://openintegrations.dev/releases";

	Если ЗначениеЗаполнено(ВерсияРелиза) Тогда
		АдресСтраницы = АдресСтраницы + "/" + ВерсияРелиза;
	КонецЕсли;

	ЗапуститьПриложение(АдресСтраницы);

КонецПроцедуры

&НаКлиенте
Функция ПолучитьВыбраннуюВерсиюРелизаИзДокумента(Документ)

	Если Документ = Неопределено Тогда
		Документ = Элементы.HTML.Документ;
	КонецЕсли;

	Если Документ = Неопределено Тогда
		Возврат "";
	КонецЕсли;

	Попытка

		СелектВерсии = Документ.getElementById("opi-release-version");

		Если СелектВерсии = Неопределено Тогда
			Возврат "";
		КонецЕсли;

		Возврат СелектВерсии.value;

	Исключение
		Возврат "";
	КонецПопытки;

КонецФункции

&НаКлиенте
Процедура ОткрытьКаталогКэша()

	ПутьКэша = OPI_УправлениеРасширением.ПолучитьПутьКэшаКомпонент();
	ЗапуститьПриложение(ПутьКэша);

КонецПроцедуры

&НаКлиенте
Процедура УстановитьКомпонентыНаКлиенте(МассивИмен)

	#Если Не ВебКлиент Тогда
		OPI_УправлениеРасширением.ОбновитьКомпонентыНаКлиенте(МассивИмен);
	#КонецЕсли

КонецПроцедуры

&НаКлиенте
Функция ПолучитьВыделенныеКомпонентыИзДокумента(Документ)

	Результат     = Новый Массив;
	ПрефиксИД     = "opi-addin-";
	ДлинаПрефикса = СтрДлина(ПрефиксИД);

	Если Документ = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;

	Попытка
		ТелоТаблицы = ПолучитьТелоТаблицыКомпонент(Документ);
	Исключение
		Возврат Результат;
	КонецПопытки;

	Если ТелоТаблицы = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;

	Попытка
		Флажки = ТелоТаблицы.getElementsByTagName("input");
	Исключение
		Возврат Результат;
	КонецПопытки;

	Для Индекс = 0 По Флажки.length - 1 Цикл

		Попытка
			
			Флажок = Флажки[Индекс];
			
			Если Флажок = Неопределено Тогда
				Прервать;
			КонецЕсли;
			
			Если Не Флажок.checked Тогда
				Продолжить;
			КонецЕсли;

			ИдФлажка = Флажок.id;

			Если СтрНачинаетсяС(ИдФлажка, ПрефиксИД) Тогда
				Результат.Добавить(Сред(ИдФлажка, ДлинаПрефикса + 1));
			КонецЕсли;

		Исключение
			Продолжить;
		КонецПопытки;

	КонецЦикла;

	Возврат Результат;

КонецФункции

&НаКлиенте
Процедура ОбновитьСтрокуКомпонентыВДокументе(Знач ДанныеКомпоненты)

	ИмяКомпоненты = ДанныеКомпоненты["ИмяКомпоненты"];
	ПрефиксСтроки = "addin-row-" + ИмяКомпоненты;

	Документ = Элементы.HTML.Документ;

	Если Документ = Неопределено Тогда
		Возврат;
	КонецЕсли;

	УстановитьТекстУзлаHTML(Документ.getElementById(ПрефиксСтроки + "-cfg"), ДанныеКомпоненты["ВерсияКонфигурации"]);

	УстановитьТекстУзлаHTML(Документ.getElementById(ПрефиксСтроки + "-client")
		, ПредставлениеВерсииКлиентаКомпонентыНаКлиенте(ДанныеКомпоненты["ВерсияКлиента"]
			, ДанныеКомпоненты["ВерсияКонфигурации"]));

КонецПроцедуры

&НаКлиенте
Процедура УстановитьТекстУзлаHTML(Узел, Знач Текст)

	Если Узел = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Попытка
		Узел.textContent = Строка(Текст);
	Исключение
		Попытка
			Узел.innerText = Строка(Текст);
		Исключение
			Возврат;
		КонецПопытки;
	КонецПопытки;

КонецПроцедуры

&НаКлиенте
Функция ВерсииКомпонентыРазличаютсяНаКлиенте(Знач ВерсияКлиента, Знач ВерсияКонфигурации)

	Возврат Строка(ВерсияКлиента)
		<> Строка(ВерсияКонфигурации);

КонецФункции

&НаКлиенте
Функция ПредставлениеВерсииКлиентаКомпонентыНаКлиенте(Знач ВерсияКлиента, Знач ВерсияКонфигурации)

	ТекстВерсии = Строка(ВерсияКлиента);

	Если Не ВерсииКомпонентыРазличаютсяНаКлиенте(ВерсияКлиента, ВерсияКонфигурации) Тогда
		Возврат ТекстВерсии;
	КонецЕсли;

	Если ЗначениеЗаполнено(ТекстВерсии) Тогда
		Возврат ТекстВерсии + " ⚠️";
	КонецЕсли;

	Возврат "";

КонецФункции

&НаКлиенте
Процедура СинхронизироватьТаблицуКомпонентВДокументе()

	Документ = Элементы.HTML.Документ;

	Если Документ = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ТелоТаблицы = ПолучитьТелоТаблицыКомпонент(Документ);

	Если ТелоТаблицы = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ИменаВДокументе = ПолучитьИменаКомпонентВТаблице(ТелоТаблицы);
	ИменаВДанных    = Новый Соответствие;

	Для Каждого СтрокаКомпоненты Из ВерсииКомпонент Цикл

		ИмяКомпоненты = СтрокаКомпоненты.ИмяКомпоненты;
		ИменаВДанных.Вставить(ИмяКомпоненты, Истина);

		Если ИменаВДокументе[ИмяКомпоненты] = Неопределено Тогда
			ДобавитьСтрокуКомпонентыВДокумент(Документ, ТелоТаблицы, СтрокаКомпоненты);
		Иначе
			ОбновитьСтрокуКомпонентыВДокументе(ДанныеКомпонентыИзСтрокиТаблицы(СтрокаКомпоненты));
		КонецЕсли;

	КонецЦикла;

	Для Каждого ИмяКомпоненты Из ИменаВДокументе Цикл

		Если ИменаВДанных[ИмяКомпоненты] = Неопределено Тогда
			УдалитьСтрокуКомпонентыИзДокумента(Документ, ИмяКомпоненты);
		КонецЕсли;

	КонецЦикла;

	ВызватьСкриптСинхронизацииПанели(Документ);

КонецПроцедуры

&НаКлиенте
Функция ДанныеКомпонентыИзСтрокиТаблицы(СтрокаКомпоненты)

	Возврат Новый Структура("ИмяКомпоненты, ВерсияКонфигурации, ВерсияКлиента"
		, СтрокаКомпоненты.ИмяКомпоненты
		, СтрокаКомпоненты.ВерсияКонфигурации
		, СтрокаКомпоненты.ВерсияКлиента);

КонецФункции

&НаКлиенте
Функция ПолучитьТелоТаблицыКомпонент(Документ)

	Попытка
		Возврат Документ.getElementById("opi-addins-body");
	Исключение
		Возврат Неопределено;
	КонецПопытки;

КонецФункции

&НаКлиенте
Функция ПолучитьИменаКомпонентВТаблице(ТелоТаблицы)

	Результат = Новый Соответствие;

	Попытка
		Строки = ТелоТаблицы.getElementsByTagName("tr");
	Исключение
		Возврат Результат;
	КонецПопытки;

	Для Индекс = 0 По Строки.length - 1 Цикл

		Попытка

			Строка = Строки[Индекс];

			Если Строка = Неопределено Тогда
				Прервать;
			КонецЕсли;

			ИмяКомпоненты = Строка.getAttribute("data-component");

			Если ЗначениеЗаполнено(ИмяКомпоненты) Тогда
				Результат.Вставить(ИмяКомпоненты, Истина);
			КонецЕсли;

		Исключение
			Продолжить;
		КонецПопытки;

	КонецЦикла;

	Возврат Результат;

КонецФункции

&НаКлиенте
Процедура ДобавитьСтрокуКомпонентыВДокумент(Документ, ТелоТаблицы, СтрокаКомпоненты)

	ИмяКомпоненты = СтрокаКомпоненты.ИмяКомпоненты;
	ПрефиксСтроки = "addin-row-" + ИмяКомпоненты;
	ИдФлажка      = "opi-addin-" + ИмяКомпоненты;

	Попытка

		Строка = Документ.createElement("tr");
		Строка.setAttribute("id", ПрефиксСтроки);
		Строка.setAttribute("data-component", ИмяКомпоненты);

		ЯчейкаФлажка = Документ.createElement("td");
		ЯчейкаФлажка.setAttribute("class", "opi-col-check");

		Флажок = Документ.createElement("input");
		Флажок.setAttribute("type", "checkbox");
		Флажок.setAttribute("class", "opi-checkbox");
		Флажок.setAttribute("id", ИдФлажка);

		ЯчейкаФлажка.appendChild(Флажок);
		Строка.appendChild(ЯчейкаФлажка);

		ЯчейкаИмя = Документ.createElement("td");
		ЯчейкаИмя.setAttribute("id", ПрефиксСтроки + "-name");
		УстановитьТекстУзлаHTML(ЯчейкаИмя, ИмяКомпоненты);
		Строка.appendChild(ЯчейкаИмя);

		ЯчейкаКонфигурации = Документ.createElement("td");
		ЯчейкаКонфигурации.setAttribute("id", ПрефиксСтроки + "-cfg");
		УстановитьТекстУзлаHTML(ЯчейкаКонфигурации, СтрокаКомпоненты.ВерсияКонфигурации);
		Строка.appendChild(ЯчейкаКонфигурации);

		ЯчейкаКлиента = Документ.createElement("td");
		ЯчейкаКлиента.setAttribute("id", ПрефиксСтроки + "-client");
		
		УстановитьТекстУзлаHTML(ЯчейкаКлиента
			, ПредставлениеВерсииКлиентаКомпонентыНаКлиенте(СтрокаКомпоненты.ВерсияКлиента
				, СтрокаКомпоненты.ВерсияКонфигурации));
				
		Строка.appendChild(ЯчейкаКлиента);

		ТелоТаблицы.appendChild(Строка);

	Исключение
		Возврат;
	КонецПопытки;

КонецПроцедуры

&НаКлиенте
Процедура УдалитьСтрокуКомпонентыИзДокумента(Документ, ИмяКомпоненты)

	Попытка

		Строка = Документ.getElementById("addin-row-" + ИмяКомпоненты);

		Если Строка = Неопределено Тогда
			Возврат;
		КонецЕсли;

		Родитель = Строка.parentNode;

		Если Родитель <> Неопределено Тогда
			Родитель.removeChild(Строка);
		КонецЕсли;

	Исключение
		Возврат;
	КонецПопытки;

КонецПроцедуры

&НаКлиенте
Процедура ВызватьСкриптСинхронизацииПанели(Документ)

	Попытка

		ОкноПанели = Документ.parentWindow;

		Если ОкноПанели <> Неопределено Тогда
			ОкноПанели.execScript("if (window.OPI_PANEL_afterAddinsSync) { window.OPI_PANEL_afterAddinsSync(); }", "JavaScript");
		КонецЕсли;

	Исключение
		Возврат;
	КонецПопытки;

КонецПроцедуры

&НаСервере
Функция ПолучитьЛоготипSVG()

	ЛогоДвоичные = БиблиотекаКартинок.OPI_Logo.ПолучитьДвоичныеДанные();

	Возврат ПолучитьСтрокуИзДвоичныхДанных(ЛогоДвоичные);

КонецФункции

&НаСервере
Функция ПредставлениеЗначенияКомпоненты(Знач Значение)

	Если Значение = Неопределено Тогда
		Возврат "";
	КонецЕсли;

	Возврат Строка(Значение);

КонецФункции

&НаСервере
Функция ВерсииКомпонентыРазличаются(Знач ВерсияКлиента, Знач ВерсияКонфигурации)

	Возврат ПредставлениеЗначенияКомпоненты(ВерсияКлиента) <> ПредставлениеЗначенияКомпоненты(ВерсияКонфигурации);

КонецФункции

&НаСервере
Функция ПредставлениеВерсииКлиентаКомпоненты(Знач ВерсияКлиента, Знач ВерсияКонфигурации)

	ТекстВерсии = ПредставлениеЗначенияКомпоненты(ВерсияКлиента);

	Если Не ВерсииКомпонентыРазличаются(ВерсияКлиента, ВерсияКонфигурации) Тогда
		Возврат ТекстВерсии;
	КонецЕсли;

	Если ЗначениеЗаполнено(ТекстВерсии) Тогда
		Возврат ТекстВерсии + " ⚠️";
	КонецЕсли;

	Возврат "";

КонецФункции

