#Область ОписаниеПеременных

&НаКлиенте
Перем ОжидаетсяКомпонент;

&НаКлиенте
Перем ОжидаетсяЗавершениеЗагрузки;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	СформироватьHTMLПанелиНаСервере(Истина);

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)

	#Если Не ВебКлиент Тогда

		ОжидаетсяКомпонент = ПолучитьКоличествоКомпонентНаСервере();
		ОжидаетсяЗавершениеЗагрузки = ОжидаетсяКомпонент > 0;

		OPI_УправлениеРасширением.ПодключитьВсеКомпоненты();

		Если ОжидаетсяКомпонент = 0 Тогда
			СформироватьHTMLПанелиНаСервере();
		КонецЕсли;

	#Иначе

		СформироватьHTMLПанелиНаСервере();

	#КонецЕсли

КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)

	Если ИмяСобытия = "OPI_ЗавершениеУстановки" Тогда

		ИмяКомпоненты = Параметр["ИмяКомпоненты"];

		ОтборКомпонент   = Новый Структура("ИмяКомпоненты", ИмяКомпоненты);
		СтрокаКомпоненты = ВерсииКомпонент.НайтиСтроки(ОтборКомпонент);

		Если СтрокаКомпоненты.Количество() > 0 Тогда
			НужнаяСтрока = СтрокаКомпоненты[0];
		Иначе
			НужнаяСтрока = ВерсииКомпонент.Добавить();
		КонецЕсли;

		ЗаполнитьЗначенияСвойств(НужнаяСтрока, Параметр);

		ОбновитьСтрокуКомпонентыВДокументе(Параметр);

		ОжидаетсяКомпонент = ОжидаетсяКомпонент - 1;

		Если ОжидаетсяКомпонент = 0 И ОжидаетсяЗавершениеЗагрузки Тогда
			ОжидаетсяЗавершениеЗагрузки = Ложь;
			СформироватьHTMLПанелиНаСервере();
		КонецЕсли;

	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура HTMLПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)

	Попытка

		IDОбъекта  = ДанныеСобытия["Element"]["id"];
		ТипСобытия = ДанныеСобытия["Event"]["type"];
		
		Если ТипСобытия <> "click" Тогда
			Возврат;
		КонецЕсли;
		
		Если IDОбъекта = "opi-btn-docs" Тогда
			ОткрытьСайт();
		ИначеЕсли IDОбъекта = "opi-btn-github" Тогда
			ОткрытьGitHub();
		ИначеЕсли IDОбъекта = "opi-btn-sourcecraft" Тогда
			ОткрытьSourceCraft();
		ИначеЕсли IDОбъекта = "opi-btn-boosty" Тогда
			ОткрытьBoosty();
		ИначеЕсли IDОбъекта = "opi-btn-refresh-list" Тогда
			ОбновитьСписокВерсийКомпонент();
		ИначеЕсли IDОбъекта = "opi-btn-open-cache" Тогда
			ОткрытьКаталогКэша();
		ИначеЕсли IDОбъекта = "opi-btn-install-addins" Тогда

			МассивКомпонент = ПолучитьВыделенныеКомпонентыИзДокумента(ДанныеСобытия["Document"]);

			Если МассивКомпонент.Количество() > 0 Тогда
				ОжидаетсяКомпонент = МассивКомпонент.Количество();
				УстановитьКомпонентыНаКлиенте(МассивКомпонент);
			КонецЕсли;

		ИначеЕсли IDОбъекта = "opi-btn-download-cf" Тогда
			СкачатьCF();
		ИначеЕсли IDОбъекта = "opi-btn-download-cfe" Тогда
			СкачатьCFE();
		ИначеЕсли IDОбъекта = "opi-btn-install-cfe" Тогда
			УстановитьCFE();
		ИначеЕсли IDОбъекта = "opi-btn-releases" Тогда
			ОткрытьАрхивРелизов(ДанныеСобытия["Document"]);

		Иначе
			Возврат;
		КонецЕсли;

	Исключение
		Возврат;
	КонецПопытки;
	
КонецПроцедуры

#КонецОбласти

