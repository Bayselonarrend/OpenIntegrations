&НаКлиенте
Процедура СкачатьАртефактРелиза(Знач IDАртефакта, Документ = Неопределено)

    #Если ВебКлиент Тогда
        ВызватьИсключение "Работа с файлами недоступна в веб-клиенте!";
    #Иначе

        НомерВерсии = ПолучитьВыбраннуюВерсиюРелизаИзДокумента(Документ);

        Если Не ЗначениеЗаполнено(НомерВерсии) Тогда
            ПоказатьПредупреждение(, "Не выбрана версия релиза.");
            Возврат;
        КонецЕсли;

        IDЗеркала = ПолучитьВыбранноеЗеркалоИзДокумента(Документ);
        ИмяФайла  = ПолучитьИмяФайлаАртефактаНаСервере(НомерВерсии, IDАртефакта, IDЗеркала);

        Если Не ЗначениеЗаполнено(ИмяФайла) Тогда
            ПоказатьПредупреждение(, "Не удалось определить имя файла для скачивания.");
            Возврат;
        КонецЕсли;

        ДопПараметры              = Новый Структура("НомерВерсии, IDАртефакта, IDЗеркала", НомерВерсии, IDАртефакта, IDЗеркала);
        ООп                       = Новый ОписаниеОповещения("ПослеВыбораПутиСкачиванияАртефакта", ЭтотОбъект, ДопПараметры);
        Диалог                    = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
        Диалог.ПолноеИмяФайла     = ИмяФайла;
        Диалог.МножественныйВыбор = Ложь;
        Диалог.Показать(ООп);

    #КонецЕсли

КонецПроцедуры

&НаКлиенте
Процедура ПослеВыбораПутиСкачиванияАртефакта(Результат, ДопПараметры) Экспорт

    #Если Не ВебКлиент Тогда

        Если Результат = Неопределено Тогда
            Возврат;
        КонецЕсли;

        Попытка

            //@skip-check bsl-legacy-check-expression-type
            АрхивРелизов = ЗагрузитьАрхивРелизов();

            Сообщение = OPI_УправлениеРасширением.СкачатьАртефактРелиза(АрхивРелизов
                , ДопПараметры.НомерВерсии
                , ДопПараметры.IDАртефакта
                , ДопПараметры.IDЗеркала
                , Результат[0]);

            ПоказатьПредупреждение(, Сообщение);

        Исключение
            ПоказатьПредупреждение(, "Ошибка при загрузке файла: " + ОписаниеОшибки());
        КонецПопытки;

    #КонецЕсли

КонецПроцедуры

&НаКлиенте
Процедура УстановитьCFE(Документ = Неопределено)

    #Если ВебКлиент Тогда
        ПоказатьПредупреждение(, "Установка расширения недоступна в веб-клиенте.");
        Возврат;
    #Иначе

        НомерВерсии = ПолучитьВыбраннуюВерсиюРелизаИзДокумента(Документ);

        Если Не ЗначениеЗаполнено(НомерВерсии) Тогда
            ПоказатьПредупреждение(, "Не выбрана версия релиза.");
            Возврат;
        КонецЕсли;

        IDЗеркала    = ПолучитьВыбранноеЗеркалоИзДокумента(Документ);
        ДопПараметры = Новый Структура("НомерВерсии, IDЗеркала", НомерВерсии, IDЗеркала);
        ТекстВопроса = СтрШаблон("Установить расширение OpenIntegrations версии %1?", НомерВерсии);
        ООп          = Новый ОписаниеОповещения("ПослеПодтвержденияУстановкиCFE", ЭтотОбъект, ДопПараметры);

        ПоказатьВопрос(ООп, ТекстВопроса, РежимДиалогаВопрос.ДаНет, , , "Установка расширения");

    #КонецЕсли

КонецПроцедуры

&НаКлиенте
Процедура ПослеПодтвержденияУстановкиCFE(Результат, ДопПараметры) Экспорт

    #Если Не ВебКлиент Тогда

        Если Результат <> КодВозвратаДиалога.Да Тогда
            Возврат;
        КонецЕсли;

        Попытка

            ИтогУстановки = УстановитьCFEНаСервере(ДопПараметры.НомерВерсии, ДопПараметры.IDЗеркала);

            Если ИтогУстановки.ТребуетсяПерезапуск Тогда
                ПредложитьПерезапускПослеУстановкиCFE(ИтогУстановки.Сообщение);
            Иначе
                ПоказатьПредупреждение(, ИтогУстановки.Сообщение);
            КонецЕсли;

        Исключение
            ПоказатьПредупреждение(, "Ошибка установки расширения: " + ОписаниеОшибки());
        КонецПопытки;

    #КонецЕсли

КонецПроцедуры

&НаКлиенте
Процедура ПредложитьПерезапускПослеУстановкиCFE(Знач ТекстСообщения)

    ТекстВопроса = ТекстСообщения
        + Символы.ПС
        + Символы.ПС
        + "Перезапустить 1С сейчас?";

    СписокКнопок = Новый СписокЗначений;
    СписокКнопок.Добавить("Перезапуск", "Перезапустить");
    СписокКнопок.Добавить("Закрытие"  , "Позже");

    ООп = Новый ОписаниеОповещения("ПослеЗапросаПерезапускаПослеУстановкиCFE", ЭтотОбъект);
    ПоказатьВопрос(ООп, ТекстВопроса, СписокКнопок, , , "Требуется перезапуск");

КонецПроцедуры

&НаКлиенте
Процедура ПослеЗапросаПерезапускаПослеУстановкиCFE(Результат, ДопПараметры) Экспорт

    Если Результат = "Перезапуск" Тогда
        ЗавершитьРаботуСистемы(, Истина);
    КонецЕсли;

КонецПроцедуры

