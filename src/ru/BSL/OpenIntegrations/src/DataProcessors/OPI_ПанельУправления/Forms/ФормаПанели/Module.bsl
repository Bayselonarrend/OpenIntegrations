КонецФункции

#КонецОбласти

#Область Обновления

&НаСервере
Функция ПолучитьURLАрхиваРелизов()

    Возврат "https://raw.githubusercontent.com/Bayselonarrend/OpenIntegrations/refs/heads/main/docs/docusaurus/archive/releases-archive.json";
    //"https://openintegrations.dev/archive/releases-archive.json";

КонецФункции

&НаСервере
Функция ЗагрузитьАрхивРелизов()

    Попытка

        URL = ПолучитьURLАрхиваРелизов();

        Ответ = OPI_ЗапросыHTTP.НовыйЗапрос()
            .Инициализировать()
            .УстановитьURL(URL)
            .УстановитьТаймаут(35)
            .ОбработатьЗапрос("GET")
            .ВернутьОтветКакJSONКоллекцию();

        Если АрхивРелизовЗагружен(Ответ) Тогда
            Возврат Ответ;
        КонецЕсли;

        ДанныеОтвета = Неопределено;

        Если ТипЗнч(Ответ) = Тип("Структура") Или ТипЗнч(Ответ) = Тип("Соответствие") Тогда

            Если Ответ["result"] = Истина Тогда
                ДанныеОтвета = Ответ["data"];
            Иначе
                ДанныеОтвета = Ответ;
            КонецЕсли;

        КонецЕсли;

        Если АрхивРелизовЗагружен(ДанныеОтвета) Тогда
            Возврат ДанныеОтвета;
        КонецЕсли;

        Если ТипЗнч(ДанныеОтвета) = Тип("Строка") И ЗначениеЗаполнено(ДанныеОтвета) Тогда
            Возврат OPI_Инструменты.JsonВСтруктуру(ДанныеОтвета, Истина);
        КонецЕсли;

    Исключение
        Возврат Неопределено;
    КонецПопытки;

    Возврат Неопределено;

КонецФункции

&НаСервере
Функция АрхивРелизовЗагружен(Знач Архив)

    Если Архив = Неопределено Тогда
        Возврат Ложь;
    КонецЕсли;

    Версии = Архив["versions"];

    Возврат ТипЗнч(Версии) = Тип("Массив") И Версии.Количество() > 0;

КонецФункции

&НаСервере
Функция ТекстСкриптаАрхиваРелизов(АрхивРелизов)

    Если Не АрхивРелизовЗагружен(АрхивРелизов) Тогда
        Возврат "window.OPI_RELEASES_ARCHIVE = null;";
    КонецЕсли;

    ТекстJSON = OPI_Инструменты.JSONСтрокой(АрхивРелизов, "Нет", Ложь, Истина);
    ТекстJSON = СтрЗаменить(ТекстJSON, "</", "<\/");

    Возврат "window.OPI_RELEASES_ARCHIVE = " + ТекстJSON + ";";

КонецФункции

&НаСервере
Функция СравнитьВерсииРелизов(Знач Версия1, Знач Версия2)

    Части1     = СтрРазделить(СокрЛП(Версия1), ".", Ложь);
    Части2     = СтрРазделить(СокрЛП(Версия2), ".", Ложь);
    МаксИндекс = Макс(Части1.Количество(), Части2.Количество()) - 1;

    Для Индекс = 0 По МаксИндекс Цикл

        Номер1 = 0;
        Номер2 = 0;

        Если Индекс < Части1.Количество() Тогда
            Номер1 = Число(Части1[Индекс]);
        КонецЕсли;

        Если Индекс < Части2.Количество() Тогда
            Номер2 = Число(Части2[Индекс]);
        КонецЕсли;

        Если Номер1 > Номер2 Тогда
            Возврат 1;
        ИначеЕсли Номер1 < Номер2 Тогда
            Возврат -1;
        КонецЕсли;

    КонецЦикла;

    Возврат 0;

КонецФункции

&НаСервере
Функция ПолучитьВерсиюРелизаПоУмолчанию(АрхивРелизов)

    Версии = АрхивРелизов["versions"];

    Если Версии.Количество() = 0 Тогда
        Возврат "";
    КонецЕсли;

    Возврат Версии[0]["version"];

КонецФункции

&НаСервере
Функция НайтиДанныеРелиза(АрхивРелизов, Знач НомерВерсии)

    Для Каждого Релиз Из АрхивРелизов["versions"] Цикл

        Если Релиз["version"] = НомерВерсии Тогда
            Возврат Релиз;
        КонецЕсли;

    КонецЦикла;

    Возврат Неопределено;

КонецФункции

&НаСервере
Функция ЗеркалоДоступноДляВерсии(АрхивРелизов, Знач IDЗеркала, Знач НомерВерсии)

    Для Каждого Зеркало Из АрхивРелизов["mirrors"] Цикл

        Если Зеркало["id"] <> IDЗеркала Тогда
            Продолжить;
        КонецЕсли;

        МинимальнаяВерсия = Зеркало["minVersion"];

        Если Не ЗначениеЗаполнено(МинимальнаяВерсия) Тогда
            Возврат Истина;
        КонецЕсли;

        Возврат СравнитьВерсииРелизов(НомерВерсии, МинимальнаяВерсия) >= 0;

    КонецЦикла;

    Возврат Ложь;

КонецФункции

&НаСервере
Функция ЗеркалоОтображаетсяВПанели(Знач IDЗеркала)

    Возврат IDЗеркала <> "sourcecraft";

КонецФункции

&НаСервере
Функция ПолучитьПоследнююВерсиюАрхива(АрхивРелизов)

    Версии = АрхивРелизов["versions"];

    Если Версии.Количество() = 0 Тогда
        Возврат "";
    КонецЕсли;

    Возврат Версии[0]["version"];

КонецФункции

&НаСервере
Функция ЕстьДоступноеОбновление(АрхивРелизов, Знач ТекущаяВерсия)

    Если Не АрхивРелизовЗагружен(АрхивРелизов) Тогда
        Возврат Ложь;
    КонецЕсли;

    ПоследняяВерсия = ПолучитьПоследнююВерсиюАрхива(АрхивРелизов);

    Если Не ЗначениеЗаполнено(ПоследняяВерсия) Тогда
        Возврат Ложь;
    КонецЕсли;

    Возврат СравнитьВерсииРелизов(ТекущаяВерсия, ПоследняяВерсия) < 0;

КонецФункции

&НаСервере
Функция ПолучитьТекстВкладкиОбновления(АрхивРелизов, Знач ТекущаяВерсия)

    ПодписьВкладки = "Обновление";

    Если ЕстьДоступноеОбновление(АрхивРелизов, ТекущаяВерсия) Тогда
        ПодписьВкладки = "⚠️ " + ПодписьВкладки;
    КонецЕсли;

    Возврат ПодписьВкладки;

КонецФункции

&НаСервере
Функция ПолучитьНаименованиеЗеркала(Знач IDЗеркала)

    Если IDЗеркала = "github" Тогда
        Возврат "GitHub";
    ИначеЕсли IDЗеркала = "yandex" Тогда
        Возврат "Yandex.Disk";
    ИначеЕсли IDЗеркала = "s3" Тогда
        Возврат "Архив (S3)";
    КонецЕсли;

    Возврат IDЗеркала;

КонецФункции

&НаСервере
Функция URLИконкиИзмененияРелиза(АрхивРелизов, Изменение)

    URLИконки = Изменение["iconUrl"];

    Если ЗначениеЗаполнено(URLИконки) Тогда
        Возврат URLИконки;
    КонецЕсли;

    ПутьИконки = Изменение["icon"];

    Если Не ЗначениеЗаполнено(ПутьИконки) Тогда
        Возврат "";
    КонецЕсли;

    Возврат АрхивРелизов["githubContentBase"] + ПутьИконки;

КонецФункции

&НаСервере
Функция ПредставлениеТекстаЧенджлогаСоСсылками(Текст)

    Если Не ЗначениеЗаполнено(Текст) Тогда
        Возврат "";
    КонецЕсли;

    Результат = "";
    Остаток   = Текст;

    Пока Истина Цикл

        НачалоСсылки = СтрНайти(Остаток, "[");

        Если НачалоСсылки = 0 Тогда
            Результат = Результат + OPI_ШаблонизаторHTML.ЭкранироватьHTML(Остаток);
            Прервать;
        КонецЕсли;

        Результат = Результат + OPI_ШаблонизаторHTML.ЭкранироватьHTML(Лев(Остаток, НачалоСсылки - 1));
        Остаток   = Сред(Остаток, НачалоСсылки + 1);

        КонецПодписи = СтрНайти(Остаток, "]");

        Если КонецПодписи = 0 Тогда
            Результат = Результат + OPI_ШаблонизаторHTML.ЭкранироватьHTML("[" + Остаток);
            Прервать;
        КонецЕсли;

        Подпись = Лев(Остаток, КонецПодписи - 1);
        Остаток = Сред(Остаток, КонецПодписи + 1);

        Если Лев(Остаток, 1) <> "(" Тогда
            Результат = Результат + OPI_ШаблонизаторHTML.ЭкранироватьHTML("[" + Подпись + "]" + Остаток);
            Прервать;
        КонецЕсли;

        Остаток  = Сред(Остаток, 2);
        КонецURL = СтрНайти(Остаток, ")");

        Если КонецURL = 0 Тогда
            Результат = Результат + OPI_ШаблонизаторHTML.ЭкранироватьHTML("[" + Подпись + "](" + Остаток);
            Прервать;
        КонецЕсли;

        URL     = Лев(Остаток, КонецURL - 1);
        Остаток = Сред(Остаток, КонецURL + 1);

        Результат = Результат + СтрШаблон(
            "<a href=""%1"" target=""_blank"" rel=""noopener noreferrer"">%2</a>"
            , OPI_ШаблонизаторHTML.ЭкранироватьHTML(URL)
            , OPI_ШаблонизаторHTML.ЭкранироватьHTML(Подпись));

    КонецЦикла;

    Возврат Результат;

КонецФункции

&НаСервере
Функция ПредставлениеОписанияЧенджлога(Описание)

    Если Не ЗначениеЗаполнено(Описание) Тогда
        Возврат "";
    КонецЕсли;

    Части     = СтрРазделить(Описание, "`");
    Результат = "";

    Для Индекс = 0 По Части.ВГраница() Цикл

        Если Индекс % 2 = 1 Тогда
            Результат = Результат + "<code>" + OPI_ШаблонизаторHTML.ЭкранироватьHTML(Части[Индекс]) + "</code>";
        Иначе
            Результат = Результат + ПредставлениеТекстаЧенджлогаСоСсылками(Части[Индекс]);
        КонецЕсли;

    КонецЦикла;

    Возврат Результат;

КонецФункции

&НаСервере
Функция ТекстЯчейкиБиблиотекиЧенджлога(АрхивРелизов, Изменение)

    URLИконки     = URLИконкиИзмененияРелиза(АрхивРелизов, Изменение);
    ИмяБиблиотеки = Изменение["lib"];

    Если ЗначениеЗаполнено(URLИконки) Тогда
        Возврат СтрШаблон("<div class=""opi-lib-cell""><img src=""%1"" class=""opi-lib-icon"" width=""20"" height=""20"" alt=""""><span>%2</span></div>"
            , URLИконки
            , ИмяБиблиотеки);
    КонецЕсли;

    Возврат СтрШаблон("<div class=""opi-lib-cell""><span>%1</span></div>", ИмяБиблиотеки);

КонецФункции

