&НаСервере
Функция ЭкранироватьТекстHTML(Текст)

	Результат = Текст;
	Результат = СтрЗаменить(Результат, "&", "&amp;");
	Результат = СтрЗаменить(Результат, "<", "&lt;");
	Результат = СтрЗаменить(Результат, ">", "&gt;");

	Возврат Результат;

КонецФункции

&НаСервере
Функция ПредставлениеТекстаЧенджлогаСоСсылками(Текст)

	Если Не ЗначениеЗаполнено(Текст) Тогда
		Возврат "";
	КонецЕсли;

	Результат = "";
	Остаток   = Текст;

	Пока Истина Цикл

		НачалоСсылки = СтрНайти(Остаток, "[");

		Если НачалоСсылки = 0 Тогда
			Результат = Результат + ЭкранироватьТекстHTML(Остаток);
			Прервать;
		КонецЕсли;

		Результат = Результат + ЭкранироватьТекстHTML(Лев(Остаток, НачалоСсылки - 1));
		Остаток   = Сред(Остаток, НачалоСсылки + 1);

		КонецПодписи = СтрНайти(Остаток, "]");

		Если КонецПодписи = 0 Тогда
			Результат = Результат + ЭкранироватьТекстHTML("[" + Остаток);
			Прервать;
		КонецЕсли;

		Подпись  = Лев(Остаток, КонецПодписи - 1);
		Остаток  = Сред(Остаток, КонецПодписи + 1);

		Если Лев(Остаток, 1) <> "(" Тогда
			Результат = Результат + ЭкранироватьТекстHTML("[" + Подпись + "]" + Остаток);
			Прервать;
		КонецЕсли;

		Остаток = Сред(Остаток, 2);
		КонецURL = СтрНайти(Остаток, ")");

		Если КонецURL = 0 Тогда
			Результат = Результат + ЭкранироватьТекстHTML("[" + Подпись + "](" + Остаток);
			Прервать;
		КонецЕсли;

		URL     = Лев(Остаток, КонецURL - 1);
		Остаток = Сред(Остаток, КонецURL + 1);

		Результат = Результат + СтрШаблон(
			"<a href=""%1"" target=""_blank"" rel=""noopener noreferrer"">%2</a>"
			, ЭкранироватьТекстHTML(URL)
			, ЭкранироватьТекстHTML(Подпись));

	КонецЦикла;

	Возврат Результат;

КонецФункции

&НаСервере
Функция ПредставлениеОписанияЧенджлога(Описание)

	Если Не ЗначениеЗаполнено(Описание) Тогда
		Возврат "";
	КонецЕсли;

	Части   = СтрРазделить(Описание, "`");
	Результат = "";

	Для Индекс = 0 По Части.ВГраница() Цикл

		Если Индекс % 2 = 1 Тогда
			Результат = Результат + "<code>" + ЭкранироватьТекстHTML(Части[Индекс]) + "</code>";
		Иначе
			Результат = Результат + ПредставлениеТекстаЧенджлогаСоСсылками(Части[Индекс]);
		КонецЕсли;

	КонецЦикла;

	Возврат Результат;

КонецФункции

&НаСервере
Функция ТекстЯчейкиБиблиотекиЧенджлога(АрхивРелизов, Изменение)

	URLИконки = URLИконкиИзмененияРелиза(АрхивРелизов, Изменение);
	ИмяБиблиотеки = Изменение["lib"];

	Если ЗначениеЗаполнено(URLИконки) Тогда
		Возврат СтрШаблон("<div class=""opi-lib-cell""><img src=""%1"" class=""opi-lib-icon"" width=""20"" height=""20"" alt=""""><span>%2</span></div>"
			, URLИконки
			, ИмяБиблиотеки);
	КонецЕсли;

	Возврат СтрШаблон("<div class=""opi-lib-cell""><span>%1</span></div>", ИмяБиблиотеки);

КонецФункции

&НаСервере
Процедура ВставитьСтрокуЧенджлога(ФормаHTML, АрхивРелизов, Изменение, ИндексСтроки)

	ИдСтроки = "changelog-row-" + Строка(ИндексСтроки);

	ФормаHTML
		.ВставитьДочернийЭлемент(ИдСтроки, "tr")
			.ВставитьСыройДочернийБезСмещения(ИдСтроки + "-lib", "<td>" + ТекстЯчейкиБиблиотекиЧенджлога(АрхивРелизов, Изменение) + "</td>")
			.ВставитьСыройДочернийБезСмещения(ИдСтроки + "-desc"
				, "<td>" + ПредставлениеОписанияЧенджлога(Изменение["description_ru"]) + "</td>")
		.НаУровеньВыше();

КонецПроцедуры

&НаСервере
Процедура СобратьТаблицуЧенджлога(ФормаHTML, АрхивРелизов, Релиз)

	ФормаHTML
		.ВставитьДочернийЭлемент("updates-changelog-section", "div")
			.ДобавитьКласс("opi-updates-changelog")
			.ВставитьДочернийЭлемент("updates-changelog-title", "h3", Истина, , , , "Список изменений")
				.ДобавитьКласс("opi-updates-changelog__title")
			.НаУровеньВыше()
			.ВставитьДочернийЭлемент("changelog-table-wrap", "div")
			.ДобавитьКласс("opi-table-wrap")
			.ДобавитьКласс("opi-changelog-table-wrap")
			.ВставитьДочернийЭлемент("opi-changelog-table", "table")
				.ДобавитьКласс("opi-table")
				.УстановитьАтрибут("width", "100%")
				.ВставитьДочернийЭлемент("changelog-thead", "thead")
					.ВставитьДочернийЭлемент("changelog-head-row", "tr")
						.ВставитьДочернийБезСмещения("changelog-head-lib", "th", Истина, , , , "API")
						.ВставитьДочернийБезСмещения("changelog-head-desc", "th", Истина, , , , "Описание")
				.НаУровеньВыше(2)
				.ВставитьДочернийЭлемент("opi-changelog-body", "tbody");

	ИндексСтроки = 0;

	Для Каждого Изменение Из Релиз["changes"] Цикл
		ВставитьСтрокуЧенджлога(ФормаHTML, АрхивРелизов, Изменение, ИндексСтроки);
		ИндексСтроки = ИндексСтроки + 1;
	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура СобратьСелектВерсииРелиза(ФормаHTML, АрхивРелизов, Знач ВыбраннаяВерсия)

	ФормаHTML
		.ВставитьДочернийЭлемент("opi-release-version", "select")
			.ДобавитьКласс("opi-select")
			.ДобавитьКласс("opi-updates-version-select");

	Для Каждого Релиз Из АрхивРелизов["versions"] Цикл

		НомерВерсии = Релиз["version"];
		ИдОпции     = "opi-release-option-" + СтрЗаменить(НомерВерсии, ".", "-");

		ФормаHTML
			.ВставитьДочернийЭлемент(ИдОпции, "option", Истина, , , , НомерВерсии)
				.УстановитьАтрибут("value", НомерВерсии);

		Если НомерВерсии = ВыбраннаяВерсия Тогда
			ФормаHTML.УстановитьАтрибут("selected", "selected", ИдОпции);
		КонецЕсли;

		ФормаHTML.НаУровеньВыше();

	КонецЦикла;

	ФормаHTML.НаУровеньВыше();

КонецПроцедуры

&НаСервере
Процедура СобратьГруппуЗеркалРелиза(ФормаHTML, АрхивРелизов, Знач НомерВерсии)

	ФормаHTML
		.ВставитьДочернийЭлемент("opi-mirror-group", "div")
			.ДобавитьКласс("opi-mirror-group");

	ПервоеЗеркало = Истина;

	Для Каждого Зеркало Из АрхивРелизов["mirrors"] Цикл

		ИдЗеркала = Зеркало["id"];

		Если Не ЗеркалоОтображаетсяВПанели(ИдЗеркала) Тогда
			Продолжить;
		КонецЕсли;

		ИдЭлемента = "opi-mirror-" + ИдЗеркала;
		Доступно = ЗеркалоДоступноДляВерсии(АрхивРелизов, ИдЗеркала, НомерВерсии);

		ФормаHTML
			.ВставитьДочернийЭлемент(ИдЭлемента + "-wrap", "label")
				.ДобавитьКласс("opi-mirror-option")
				.УстановитьАтрибут("data-mirror", ИдЗеркала);

		Если Не Доступно Тогда
			ФормаHTML.УстановитьАтрибут("style", "display:none", ИдЭлемента + "-wrap");
		КонецЕсли;

		ФормаHTML
				.ВставитьДочернийЭлемент(ИдЭлемента, "input", Ложь)
					.ДобавитьКласс("opi-radio")
					.УстановитьАтрибут("type", "radio")
					.УстановитьАтрибут("name", "opi-mirror")
					.УстановитьАтрибут("value", ИдЗеркала);

		Если ПервоеЗеркало И Доступно Тогда
			ФормаHTML.УстановитьАтрибут("checked", "checked", ИдЭлемента);
			ПервоеЗеркало = Ложь;
		КонецЕсли;

		ФормаHTML
			.НаУровеньВыше()
			.ВставитьДочернийБезСмещения(ИдЭлемента + "-text", "span", Истина, , , , ПолучитьНаименованиеЗеркала(ИдЗеркала))
			.НаУровеньВыше();

	КонецЦикла;

	ФормаHTML.НаУровеньВыше();

КонецПроцедуры

&НаСервере
Процедура СобратьБлокСтатусаОбновления(ФормаHTML, АрхивРелизов, Знач ТекущаяВерсияОПИ)

	ПоследняяВерсия = ПолучитьПоследнююВерсиюАрхива(АрхивРелизов);
	ЕстьОбновление  = ЕстьДоступноеОбновление(АрхивРелизов, ТекущаяВерсияОПИ);

	Если ЕстьОбновление Тогда
		ЗаголовокСтатуса = "Доступно обновление";
		ТекстПодсказки   = СтрШаблон("Установлена версия: %1. Последняя доступная версия: %2", ТекущаяВерсияОПИ, ПоследняяВерсия);
		КлассСтатуса     = "opi-updates-status--available";
		ИконкаСтатуса    = ТекстИконкиСтатусаОбновления();
	Иначе
		ЗаголовокСтатуса = "Вы используете последнюю версию";
		ТекстПодсказки   = СтрШаблон("Версия %1 актуальна", ТекущаяВерсияОПИ);
		КлассСтатуса     = "opi-updates-status--current";
		ИконкаСтатуса    = ТекстИконкиСтатусаАктуально();
	КонецЕсли;

	ФормаHTML
		.ВставитьДочернийЭлемент("opi-updates-status", "div")
			.ДобавитьКласс("opi-updates-status")
			.ДобавитьКласс(КлассСтатуса)
			.ВставитьСыройДочернийБезСмещения("opi-updates-status-icon", ИконкаСтатуса)
			.ВставитьДочернийЭлемент("opi-updates-status-body", "div")
				.ДобавитьКласс("opi-updates-status__body")
				.ВставитьДочернийЭлемент("opi-updates-status-title", "div", Истина, , , , ЗаголовокСтатуса)
					.ДобавитьКласс("opi-updates-status__title")
				.НаУровеньВыше()
				.ВставитьДочернийБезСмещения("opi-updates-status-hint", "div", Истина, , , , ТекстПодсказки)
					.ДобавитьКласс("opi-updates-status__hint");

	ФормаHTML.НаУровеньВыше(2);

КонецПроцедуры

&НаСервере
Процедура СобратьЗаголовокРелиза(ФормаHTML, АрхивРелизов, Релиз, Знач ВыбраннаяВерсия)

	ФормаHTML
		.ВставитьДочернийЭлемент("opi-updates-release-header", "div")
			.ДобавитьКласс("opi-updates-release-header")
			.ВставитьДочернийЭлемент("opi-release-summary", "h2", Истина, , , , Релиз["summary_ru"])
				.ДобавитьКласс("opi-updates-summary")
			.НаУровеньВыше()
			.ВставитьДочернийЭлемент("opi-updates-version", "div")
				.ДобавитьКласс("opi-updates-version");

	СобратьСелектВерсииРелиза(ФормаHTML, АрхивРелизов, ВыбраннаяВерсия);

	ФормаHTML.НаУровеньВыше(2);

КонецПроцедуры

&НаСервере
Процедура СобратьВкладкуОбновления(ФормаHTML, АрхивРелизов, Знач ТекущаяВерсияОПИ)

	ФормаHTML
		.УстановитьТекущийЭлемент("main")
		.ВставитьДочернийЭлемент("panel-updates", "section")
			.УстановитьАтрибут("data-tab", "updates")
			.ДобавитьКласс("opi-tab-panel");

	Если Не АрхивРелизовЗагружен(АрхивРелизов) Тогда

		ФормаHTML
			.ВставитьДочернийЭлемент("updates-unavailable", "div")
				.ДобавитьКласс("opi-updates-empty")
				.ВставитьДочернийЭлемент("updates-unavailable-text", "p", Истина, , , ,
					"Не удалось загрузить архив релизов. Проверьте подключение к интернету и откройте панель заново");

		Возврат;

	КонецЕсли;

	ВыбраннаяВерсия = ПолучитьВерсиюРелизаПоУмолчанию(АрхивРелизов, ТекущаяВерсияОПИ);
	Релиз           = НайтиДанныеРелиза(АрхивРелизов, ВыбраннаяВерсия);

	Если Релиз = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ФормаHTML.УстановитьТекущийЭлемент("panel-updates");

	СобратьБлокСтатусаОбновления(ФормаHTML, АрхивРелизов, ТекущаяВерсияОПИ);

	ФормаHTML.УстановитьТекущийЭлемент("panel-updates");
	СобратьЗаголовокРелиза(ФормаHTML, АрхивРелизов, Релиз, ВыбраннаяВерсия);

	ФормаHTML.УстановитьТекущийЭлемент("panel-updates");
	СобратьТаблицуЧенджлога(ФормаHTML, АрхивРелизов, Релиз);

	ФормаHTML
		.УстановитьТекущийЭлемент("panel-updates")
		.ВставитьДочернийЭлемент("opi-updates-footer", "div")
			.ДобавитьКласс("opi-updates-footer")
			.ВставитьДочернийЭлемент("opi-updates-actions", "div")
				.ДобавитьКласс("opi-updates-actions");

	ВставитьКнопкуПанели(ФормаHTML, "opi-btn-releases", "Архив");
	ВставитьКнопкуПанели(ФормаHTML, "opi-btn-download-cf", "Скачать CF");
	ВставитьКнопкуПанели(ФормаHTML, "opi-btn-download-cfe", "Скачать CFE");
	ВставитьКнопкуПанели(ФормаHTML, "opi-btn-install-cfe", "Установить CFE");

	ФормаHTML
		.УстановитьТекущийЭлемент("opi-updates-footer")
		.ВставитьДочернийЭлемент("opi-updates-mirror", "div")
			.ДобавитьКласс("opi-updates-mirror")
			.ВставитьДочернийБезСмещения("opi-updates-mirror-label", "span", Истина, , , , "Зеркало")
				.ДобавитьКласс("opi-updates-mirror__label");

	СобратьГруппуЗеркалРелиза(ФормаHTML, АрхивРелизов, ВыбраннаяВерсия);

КонецПроцедуры

#КонецОбласти

#Область Верстка

&НаСервере
Процедура СформироватьHTMLПанелиНаСервере(ПоказыватьЗагрузку = Ложь)

	ЛогоSVG = ПолучитьЛоготипSVG();

	ФормаHTML = Обработки.OPI_HTMLФорма.Создать().Инициализировать();

	АрхивРелизов = ЗагрузитьАрхивРелизов();

	ПодключитьСтилиПанели(ФормаHTML);
	ПодключитьСкриптыПанели(ФормаHTML, АрхивРелизов);
	СобратьHTMLПанели(ФормаHTML, ЛогоSVG, ПоказыватьЗагрузку, АрхивРелизов);

	HTML = ФормаHTML.СгенерироватьHTML();

КонецПроцедуры

&НаСервере
Процедура СобратьHTMLПанели(ФормаHTML, ЛогоSVG, ПоказыватьЗагрузку = Ложь, АрхивРелизов = Неопределено)

	Если ПоказыватьЗагрузку Тогда
		СобратьЭкранЗагрузки(ФормаHTML);
	Иначе
		СобратьОболочкуПанели(ФормаHTML, АрхивРелизов, OPI_Инструменты.ВерсияОПИ());
		СобратьВкладкуГлавная(ФормаHTML, ЛогоSVG, OPI_Инструменты.ВерсияОПИ());
		СобратьВкладкуКомпоненты(ФормаHTML);
		СобратьВкладкуОбновления(ФормаHTML, АрхивРелизов, OPI_Инструменты.ВерсияОПИ());
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура СобратьОболочкуПанели(ФормаHTML, АрхивРелизов = Неопределено, Знач ТекущаяВерсияОПИ = "")

	ПодписьВкладкиОбновления = ПолучитьТекстВкладкиОбновления(АрхивРелизов, ТекущаяВерсияОПИ);

	ФормаHTML
		.ВставитьЭлемент("shell", "div")
			.ДобавитьКласс("opi-shell")
			.ВставитьДочернийЭлемент("header", "header")
				.ДобавитьКласс("opi-header")
				.ВставитьДочернийЭлемент("header-wrap", "div")
					.ДобавитьКласс("opi-header__wrap")
					.ВставитьСыройДочернийБезСмещения("header-icon", ТекстИконкиШестерни())
					.ВставитьДочернийЭлемент("header-text", "div")
						.ВставитьДочернийЭлемент("header-title", "h1", Истина, , , , "Панель управления расширением ОПИ")
							.ДобавитьКласс("opi-header__title")
						.НаУровеньВыше()
						.ВставитьДочернийЭлемент("header-subtitle", "p", Истина, , , , "Основная информация и настройки Открытого пакета интеграций")
							.ДобавитьКласс("opi-header__subtitle")
		.НаУровеньВыше(4)
		.ВставитьДочернийЭлемент("opi-tab-main", "input", Ложь)
			.УстановитьАтрибут("type", "radio")
			.УстановитьАтрибут("name", "opi-tab")
			.УстановитьАтрибут("checked", "checked")
			.ДобавитьКласс("opi-tab-input")
		.НаУровеньВыше()
		.ВставитьДочернийЭлемент("opi-tab-addins", "input", Ложь)
			.УстановитьАтрибут("type", "radio")
			.УстановитьАтрибут("name", "opi-tab")
			.ДобавитьКласс("opi-tab-input")
		.НаУровеньВыше()
		.ВставитьДочернийЭлемент("opi-tab-updates", "input", Ложь)
			.УстановитьАтрибут("type", "radio")
			.УстановитьАтрибут("name", "opi-tab")
			.ДобавитьКласс("opi-tab-input")
		.НаУровеньВыше()
		.ВставитьДочернийЭлемент("tabs", "nav")
			.УстановитьАтрибут("aria-label", "Разделы панели")
			.ДобавитьКласс("opi-tabs")
			.ВставитьДочернийЭлемент("tab-label-main", "label", Истина, , , , "Главная")
				.УстановитьАтрибут("for", "opi-tab-main")
				.ДобавитьКласс("opi-tab")
			.НаУровеньВыше()
			.ВставитьДочернийЭлемент("tab-label-addins", "label", Истина, , , , "Внешние компоненты")
				.УстановитьАтрибут("for", "opi-tab-addins")
				.ДобавитьКласс("opi-tab")
			.НаУровеньВыше()
			.ВставитьДочернийЭлемент("tab-label-updates", "label", Истина, , , , ПодписьВкладкиОбновления)
				.УстановитьАтрибут("for", "opi-tab-updates")
				.ДобавитьКласс("opi-tab")
		.НаУровеньВыше(2)
		.ВставитьДочернийЭлемент("main", "main")
			.ДобавитьКласс("opi-main");

КонецПроцедуры

&НаСервере
Процедура СобратьВкладкуГлавная(ФормаHTML, ЛогоSVG, ВерсияОПИ)

	ФормаHTML
		.УстановитьТекущийЭлемент("main")
			.ВставитьДочернийЭлемент("panel-main", "section")
				.УстановитьАтрибут("data-tab", "main")
				.ДобавитьКласс("opi-tab-panel")
				.ВставитьДочернийЭлемент("hero", "div")
					.ДобавитьКласс("opi-hero")
					.ВставитьДочернийЭлемент("opi-logo", "div")
						.ДобавитьКласс("opi-logo")
						.ВставитьСыройДочернийБезСмещения("logo-icon", ЛогоSVG)
					.НаУровеньВыше()
					.ВставитьДочернийЭлемент("hero-title", "h2", Истина, , , , "Открытый пакет интеграций")
						.ДобавитьКласс("opi-hero__title")
					.НаУровеньВыше()
					.ВставитьДочернийЭлемент("hero-tagline", "p", Истина, , , , "Набор инструментов интеграции с популярными сервисами и технологиями")
						.ДобавитьКласс("opi-hero__tagline")
					.НаУровеньВыше()
					.ВставитьДочернийЭлемент("opi-version", "span", Истина, , , , СтрШаблон("Версия %1", ВерсияОПИ))
						.ДобавитьКласс("opi-version-badge")
				.НаУровеньВыше(2)
				.ВставитьДочернийЭлемент("opi-main-actions", "div")
					.ДобавитьКласс("opi-actions");

	ВставитьКнопкуПанели(ФормаHTML, "opi-btn-docs", "Документация");
	ВставитьКнопкуПанели(ФормаHTML, "opi-btn-github", "GitHub");
	ВставитьКнопкуПанели(ФормаHTML, "opi-btn-sourcecraft", "SourceCraft");
	ВставитьКнопкуПанели(ФормаHTML, "opi-btn-boosty", "Поддержать проект");

	ФормаHTML
		.НаУровеньВыше()
		.ВставитьДочернийЭлемент("opi-licenses", "div")
			.ДобавитьКласс("opi-licenses");

	СобратьБлокТекстаЛицензии(ФормаHTML, "license-ru", "Лицензия (MIT)", "OPI_Text_LicenseRU");
	СобратьБлокТекстаЛицензии(ФормаHTML, "license-en", "License (MIT)", "OPI_Text_LicenseEN");

КонецПроцедуры

&НаСервере
Процедура СобратьБлокТекстаЛицензии(ФормаHTML, IDБлока, Заголовок, ИмяМакета)

	ТекстЛицензии = OPI_Инструменты.ПолучитьТекстовыйМакет(ИмяМакета);

	ФормаHTML
		.УстановитьТекущийЭлемент("opi-licenses")
		.ВставитьДочернийЭлемент(IDБлока, "div")
			.ДобавитьКласс("opi-license-block")
			.ВставитьДочернийЭлемент(IDБлока + "-title", "h3", Истина, , , , Заголовок)
				.ДобавитьКласс("opi-license-block__title")
			.НаУровеньВыше()
			.ВставитьДочернийЭлемент(IDБлока + "-text", "pre", Истина, , , , ТекстЛицензии)
				.ДобавитьКласс("opi-license-block__text");

КонецПроцедуры

&НаСервере
Процедура СобратьВкладкуКомпоненты(ФормаHTML)

	ФормаHTML
		.УстановитьТекущийЭлемент("main")
		.ВставитьДочернийЭлемент("panel-addins", "section")
			.УстановитьАтрибут("data-tab", "addins")
			.ДобавитьКласс("opi-tab-panel")
			.ВставитьДочернийЭлемент("opi-addins-toolbar", "div")
				.ДобавитьКласс("opi-toolbar");

	ВставитьКнопкуПанели(ФормаHTML, "opi-btn-refresh-list", "Обновить список");
	ВставитьКнопкуПанели(ФормаHTML, "opi-btn-install-addins", "Установить компоненты на клиенте");
	ВставитьКнопкуПанели(ФормаHTML, "opi-btn-open-cache", "Открыть каталог кэша");

	ФормаHTML
		.НаУровеньВыше()
		.ВставитьДочернийЭлемент("addins-alert", "div")
			.ДобавитьКласс("opi-alert")
			.ДобавитьКласс("opi-alert--warning")
			.ВставитьСыройДочернийБезСмещения("addins-alert-icon", ТекстИконкиПредупреждения())
			.ВставитьДочернийЭлемент("addins-alert-text", "div")
				.ДобавитьКласс("opi-alert__text")
				.ВставитьДочернийЭлемент("addins-alert-title", "p", Истина, , , , "Порядок обновления компонент на клиенте при обновлении расширения на новую версию:")
					.ДобавитьКласс("opi-alert__title")
				.НаУровеньВыше()
				.ВставитьДочернийЭлемент("addins-alert-steps", "ol")
					.ДобавитьКласс("opi-alert__steps")
					.ВставитьДочернийБезСмещения("addins-step-1", "li", Истина, , , , "Открыть каталог внешних компонент (ExtCompT) при помощи кнопки «Открыть каталог кэша» или вручную")
					.ВставитьДочернийБезСмещения("addins-step-2", "li", Истина, , , , "Удалить файлы компонент ОПИ (с префиксом AddIn.OPI_)")
					.ВставитьДочернийБезСмещения("addins-step-3", "li", Истина, , , , "Перезапустить приложение и вернутся в данную обработку")
					.ВставитьДочернийБезСмещения("addins-step-4", "li", Истина, , , , "Выделить необходимые компоненты и нажать «Установить компоненты на клиенте»");

	ФормаHTML
		.УстановитьТекущийЭлемент("panel-addins")
			.ВставитьДочернийЭлемент("addins-table-wrap", "div")
				.ДобавитьКласс("opi-table-wrap")
				.УстановитьАтрибут("style", "width:100%;display:block")
				.ВставитьДочернийЭлемент("opi-addins-table", "table")
					.ДобавитьКласс("opi-table")
					.УстановитьАтрибут("width", "100%")
							.ВставитьДочернийЭлемент("addins-thead", "thead")
								.ВставитьДочернийЭлемент("addins-head-row", "tr")
									.ВставитьСыройДочернийБезСмещения("addins-head-check", "<th class=""opi-col-check""><input type=""checkbox"" class=""opi-checkbox"" id=""opi-addins-check-all"" aria-label=""Выделить все""></th>")
									.ВставитьДочернийБезСмещения("addins-head-name", "th", Истина, , , , "Имя")
									.ВставитьДочернийБезСмещения("addins-head-cfg", "th", Истина, , , , "Версия в конфигурации")
									.ВставитьДочернийБезСмещения("addins-head-client", "th", Истина, , , , "Версия клиента")
							.НаУровеньВыше(2)
							.ВставитьДочернийЭлемент("opi-addins-body", "tbody");

	Для Каждого СтрокаКомпоненты Из ВерсииКомпонент Цикл
		ВставитьСтрокуКомпоненты(ФормаHTML, СтрокаКомпоненты);
	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура ВставитьКнопкуПанели(ФормаHTML, IDКнопки, ТекстКнопки)

	ФормаHTML
		.ВставитьДочернийЭлемент(IDКнопки, "button", Истина, , , , ТекстКнопки)
			.УстановитьАтрибут("type", "button")
			.ДобавитьКласс("opi-button")
		.НаУровеньВыше();

КонецПроцедуры

&НаСервере
Процедура ВставитьСтрокуКомпоненты(ФормаHTML, СтрокаКомпоненты)

	Идентификатор = СтрокаКомпоненты.ИмяКомпоненты;
	ПрефиксСтроки = "addin-row-" + Идентификатор;

	ФормаHTML
		.ВставитьДочернийЭлемент(ПрефиксСтроки, "tr")
			.УстановитьАтрибут("data-component", Идентификатор)
			.ВставитьДочернийЭлемент(ПрефиксСтроки + "-check", "td")
				.ДобавитьКласс("opi-col-check")
				.ВставитьДочернийЭлемент("opi-addin-" + Идентификатор, "input", Ложь)
					.УстановитьАтрибут("type", "checkbox")
					.ДобавитьКласс("opi-checkbox");

	Если СтрокаКомпоненты.Отметка Тогда
		ФормаHTML.УстановитьАтрибут("checked", "checked", "opi-addin-" + Идентификатор);
	КонецЕсли;

	ФормаHTML
		.НаУровеньВыше(2)
		.ВставитьДочернийБезСмещения(ПрефиксСтроки + "-name", "td", Истина, , , , ПредставлениеЗначенияКомпоненты(СтрокаКомпоненты.ИмяКомпоненты))
		.ВставитьДочернийБезСмещения(ПрефиксСтроки + "-cfg", "td", Истина, , , , ПредставлениеЗначенияКомпоненты(СтрокаКомпоненты.ВерсияКонфигурации))
		.ВставитьДочернийБезСмещения(ПрефиксСтроки + "-client", "td", Истина, , , , ПредставлениеВерсииКлиентаКомпоненты(СтрокаКомпоненты.ВерсияКлиента, СтрокаКомпоненты.ВерсияКонфигурации))
		.НаУровеньВыше();

КонецПроцедуры

&НаСервере
Процедура СобратьЭкранЗагрузки(ФормаHTML)

	ФормаHTML
		.ВставитьЭлемент("loading-screen", "div")
			.ДобавитьКласс("opi-loading")
			.ВставитьСыройДочернийБезСмещения("loading-icon", ТекстИконкиЗагрузки())
			.ВставитьДочернийЭлемент("loading-title", "p", Истина, , , , "Актуализация данных")
				.ДобавитьКласс("opi-loading__title")
			.НаУровеньВыше()
			.ВставитьДочернийЭлемент("loading-hint", "p", Истина, , , , "Пожалуйста, подождите")
				.ДобавитьКласс("opi-loading__hint");

КонецПроцедуры

