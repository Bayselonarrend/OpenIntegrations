&НаСервере
Процедура СформироватьHTMLПанелиНаСервере(ПоказыватьЗагрузку = Ложь)

    АрхивРелизов = ЗагрузитьАрхивРелизов();
    HTML         = СобратьHTMLПанелиШаблоном(ПоказыватьЗагрузку, АрхивРелизов);

КонецПроцедуры

&НаСервере
Функция СобратьHTMLПанелиШаблоном(ПоказыватьЗагрузку, АрхивРелизов)

    КонтекстДокумента = Новый Структура;
    КонтекстДокумента.Вставить("bodyClass", ?(ИспользуетсяТемнаяТема(), "opi-panel opi-panel--dark", "opi-panel"));
    КонтекстДокумента.Вставить("styles"   , ПолучитьCSSПанели());
    КонтекстДокумента.Вставить("scripts"  , ПолучитьСкриптыПанели(АрхивРелизов));

    Если ПоказыватьЗагрузку Тогда

        КонтекстЗагрузки = Новый Структура("loadingIcon", ТекстИконкиЗагрузки());
        КонтекстДокумента.Вставить("body", OPI_ШаблонизаторHTML.РендерМакета("OPI_Text_PanelLoading", КонтекстЗагрузки));

    Иначе

        КонтекстДокумента.Вставить("body", СобратьТелоПанелиШаблоном(АрхивРелизов));

    КонецЕсли;

    Возврат OPI_ШаблонизаторHTML.РендерМакета("OPI_Text_PanelDocument", КонтекстДокумента);

КонецФункции

&НаСервере
Функция СобратьТелоПанелиШаблоном(АрхивРелизов)

    ТекущаяВерсия = OPI_Инструменты.ВерсияОПИ();
    Контекст      = Новый Структура;

    Контекст.Вставить("tabUpdatesLabel", ПолучитьТекстВкладкиОбновления(АрхивРелизов, ТекущаяВерсия));
    Контекст.Вставить("logoSvg"        , ПолучитьЛоготипSVG());
    Контекст.Вставить("versionLabel"   , СтрШаблон("Версия %1"                      , ТекущаяВерсия));
    Контекст.Вставить("licenseRu"      , OPI_Инструменты.ПолучитьТекстовыйМакет("OPI_Text_LicenseRU"));
    Контекст.Вставить("licenseEn"      , OPI_Инструменты.ПолучитьТекстовыйМакет("OPI_Text_LicenseEN"));
    Контекст.Вставить("addinRows"      , СобратьСтрокиКомпонентДляШаблона());

    КонтекстОбновлений = СобратьКонтекстВкладкиОбновлений(АрхивРелизов, ТекущаяВерсия);

    Для Каждого КлючИЗначение Из КонтекстОбновлений Цикл
        Контекст.Вставить(КлючИЗначение.Ключ, КлючИЗначение.Значение);
    КонецЦикла;

    Возврат OPI_ШаблонизаторHTML.РендерМакета("OPI_Text_PanelShell", Контекст);

КонецФункции

&НаСервере
Функция СобратьСтрокиКомпонентДляШаблона()

    Строки = Новый Массив;

    Для Каждого СтрокаКомпоненты Из ВерсииКомпонент Цикл

        СтрокаКонтекста = Новый Структура;
        СтрокаКонтекста.Вставить("componentId"  , СтрокаКомпоненты.ИмяКомпоненты);
        СтрокаКонтекста.Вставить("name"         , ПредставлениеЗначенияКомпоненты(СтрокаКомпоненты.ИмяКомпоненты));
        СтрокаКонтекста.Вставить("cfgVersion"   , ПредставлениеЗначенияКомпоненты(СтрокаКомпоненты.ВерсияКонфигурации));
        СтрокаКонтекста.Вставить("clientVersion", ПредставлениеВерсииКлиентаКомпоненты(СтрокаКомпоненты.ВерсияКлиента, СтрокаКомпоненты.ВерсияКонфигурации));

        Если СтрокаКомпоненты.Отметка Тогда
            СтрокаКонтекста.Вставить("checked", Истина);
        КонецЕсли;

        Строки.Добавить(СтрокаКонтекста);

    КонецЦикла;

    Возврат Строки;

КонецФункции

&НаСервере
Функция СобратьКонтекстВкладкиОбновлений(АрхивРелизов, ТекущаяВерсия)

    Контекст = Новый Структура;

    Если Не АрхивРелизовЗагружен(АрхивРелизов) Тогда

        Контекст.Вставить("archiveError", Истина);
        Контекст.Вставить("errorIcon"   , ТекстИконкиОшибкиАрхива());
        Контекст.Вставить("archiveUrl"  , ПолучитьURLАрхиваРелизов());

        Возврат Контекст;

    КонецЕсли;

    Контекст.Вставить("archiveError", Ложь);

    ВыбраннаяВерсия = ПолучитьВерсиюРелизаПоУмолчанию(АрхивРелизов);
    Релиз           = НайтиДанныеРелиза(АрхивРелизов, ВыбраннаяВерсия);

    Если Релиз = Неопределено Тогда
        Возврат Контекст;
    КонецЕсли;

    ПоследняяВерсия = ПолучитьПоследнююВерсиюАрхива(АрхивРелизов);
    ЕстьОбновление  = ЕстьДоступноеОбновление(АрхивРелизов, ТекущаяВерсия);

    Если ЕстьОбновление Тогда

        Контекст.Вставить("statusClass", "opi-updates-status--available");
        Контекст.Вставить("statusIcon" , ТекстИконкиСтатусаОбновления());
        Контекст.Вставить("statusTitle", "Доступно обновление");
        Контекст.Вставить("statusHint" , СтрШаблон("Установлена версия: %1. Последняя доступная версия: %2", ТекущаяВерсия, ПоследняяВерсия));

    Иначе

        Контекст.Вставить("statusClass", "opi-updates-status--current");
        Контекст.Вставить("statusIcon" , ТекстИконкиСтатусаАктуально());
        Контекст.Вставить("statusTitle", "Вы используете последнюю версию");
        Контекст.Вставить("statusHint" , СтрШаблон("Версия %1 актуальна", ТекущаяВерсия));

    КонецЕсли;

    Контекст.Вставить("releaseSummary", Релиз["summary_ru"]);
    Контекст.Вставить("releaseOptions", СобратьОпцииВерсийРелиза(АрхивРелизов, ВыбраннаяВерсия));
    Контекст.Вставить("changelogRows" , СобратьСтрокиЧенджлога(АрхивРелизов  , Релиз));
    Контекст.Вставить("mirrorOptions" , СобратьОпцииЗеркал(АрхивРелизов      , ВыбраннаяВерсия));

    Возврат Контекст;

КонецФункции

&НаСервере
Функция СобратьОпцииВерсийРелиза(АрхивРелизов, ВыбраннаяВерсия)

    Опции = Новый Массив;

    Для Каждого Релиз Из АрхивРелизов["versions"] Цикл

        НомерВерсии = Релиз["version"];
        Опция       = Новый Структура;
        Опция.Вставить("version"  , НомерВерсии);
        Опция.Вставить("versionId", СтрЗаменить(НомерВерсии, ".", "-"));

        Если НомерВерсии = ВыбраннаяВерсия Тогда
            Опция.Вставить("selected", Истина);
        КонецЕсли;

        Опции.Добавить(Опция);

    КонецЦикла;

    Возврат Опции;

КонецФункции

&НаСервере
Функция СобратьСтрокиЧенджлога(АрхивРелизов, Релиз)

    Строки       = Новый Массив;
    ИндексСтроки = 0;

    Для Каждого Изменение Из Релиз["changes"] Цикл

        Строка       = Новый Структура;
        Строка.Вставить("rowIndex"   , ИндексСтроки);
        Строка.Вставить("libCell"    , ТекстЯчейкиБиблиотекиЧенджлога(АрхивРелизов, Изменение));
        Строка.Вставить("description", ПредставлениеОписанияЧенджлога(Изменение["description_ru"]));
        Строки.Добавить(Строка);
        ИндексСтроки = ИндексСтроки + 1;

    КонецЦикла;

    Возврат Строки;

КонецФункции

&НаСервере
Функция СобратьОпцииЗеркал(АрхивРелизов, НомерВерсии)

    Опции         = Новый Массив;
    ПервоеЗеркало = Истина;

    Для Каждого Зеркало Из АрхивРелизов["mirrors"] Цикл

        IDЗеркала = Зеркало["id"];

        Если Не ЗеркалоОтображаетсяВПанели(IDЗеркала) Тогда
            Продолжить;
        КонецЕсли;

        Доступно = ЗеркалоДоступноДляВерсии(АрхивРелизов, IDЗеркала, НомерВерсии);

        Опция = Новый Структура;
        Опция.Вставить("mirrorId"   , IDЗеркала);
        Опция.Вставить("mirrorLabel", ПолучитьНаименованиеЗеркала(IDЗеркала));

        Если Не Доступно Тогда
            Опция.Вставить("hidden", Истина);
        КонецЕсли;

        Если ПервоеЗеркало И Доступно Тогда
            Опция.Вставить("checked", Истина);
            ПервоеЗеркало = Ложь;
        КонецЕсли;

        Опции.Добавить(Опция);

    КонецЦикла;

    Возврат Опции;

КонецФункции

