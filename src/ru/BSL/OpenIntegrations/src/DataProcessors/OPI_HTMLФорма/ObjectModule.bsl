Функция Инициализировать() Экспорт

	ЭлементыHTML = Новый ТаблицаЗначений;
	ЭлементыHTML.Колонки.Добавить("ID");
	ЭлементыHTML.Колонки.Добавить("ОткрывающийТэг");
	ЭлементыHTML.Колонки.Добавить("ЗакрывающийТэг");
	ЭлементыHTML.Колонки.Добавить("Артибуты");
	ЭлементыHTML.Колонки.Добавить("Стили");
	ЭлементыHTML.Колонки.Добавить("Классы");
	ЭлементыHTML.Колонки.Добавить("Родитель");
	ЭлементыHTML.Колонки.Добавить("Уровень");
	
	СтилиCSS = Новый Соответствие;
	  
КонецФункции

Функция СгенерироватьHTML(Знач РодительскийЭлемент = "") Экспорт
	
	ДочерниеЭлементы      = НайтиДочерние(РодительскийЭлемент, Ложь);
	МассивСгенерированных = Новый Массив;
	
	Для Каждого Дочерний Из ДочерниеЭлементы Цикл
		МассивСгенерированных.Добавить(СгенерироватьHTML(Дочерний["ID"]));	
	КонецЦикла;
	
	ШаблонЭлемента = СоздатьШаблонЭлемента(РодительскийЭлемент);
		
	HTML = СтрШаблон(ШаблонЭлемента, СтрСоединить(МассивСгенерированных, Символы.ПС));
	
	Возврат HTML;
		
КонецФункции

Функция ВставитьЭлемент(Знач IDЭлемента
	, Знач ОткрывающийТэг
	, Знач ЗакрывающийТэг = Истина
	, Знач Родитель = ""
	, Знач Атрибуты = Неопределено
	, Знач Стили = Неопределено
	, Знач Классы = Неопределено) Экспорт
	
	OPI_ПреобразованиеТипов.ПолучитьСтроку(IDЭлемента);
	OPI_ПреобразованиеТипов.ПолучитьСтроку(ОткрывающийТэг);
	OPI_ПреобразованиеТипов.ПолучитьБулево(ЗакрывающийТэг);
	OPI_ПреобразованиеТипов.ПолучитьСтроку(Родитель);
	
	Если НайтиЭлемент(IDЭлемента) <> Неопределено Тогда
		ВызватьИсключение СтрШаблон("Нельзя создать два элемента с одинаковым ID (%1)", IDЭлемента);
	КонецЕсли;
	
	ЭлементРодитель = НайтиЭлемент(Родитель);
	
	Если ЗначениеЗаполнено(Родитель) И ЭлементРодитель = Неопределено Тогда
		ВызватьИсключение СтрШаблон("Элемент с указанным ID не найден (%1)", Родитель);
	КонецЕсли;
	
	Если Не ЭлементРодитель["ЗакрывающийТэг"] Тогда
		ВызватьИсключение СтрШаблон("Элемент без закрывающего тэга не может быть родителем (%1)", Родитель);	
	КонецЕсли;
	
	Если Атрибуты <> Неопределено Тогда
		OPI_ПреобразованиеТипов.ПолучитьКоллекциюКлючИЗначение(Атрибуты);
	Иначе
		Атрибуты = Новый Соответствие;
	КонецЕсли;
	
	Если Стили <> Неопределено Тогда
		OPI_ПреобразованиеТипов.ПолучитьКоллекциюКлючИЗначение(Стили);
	Иначе
		Стили = Новый Соответствие;
	КонецЕсли;
	
	Если Классы <> Неопределено Тогда
		OPI_ПреобразованиеТипов.ПолучитьКоллекцию(Классы);
	Иначе
		Классы = Новый Массив;
	КонецЕсли;
	
	НовыйЭлемент = ЭлементыHTML.Добавить();
	НовыйЭлемент.ID             = IDЭлемента;
	НовыйЭлемент.ОткрывающийТэг = ОткрывающийТэг;
	НовыйЭлемент.ЗакрывающийТэг = ЗакрывающийТэг;
	НовыйЭлемент.Родитель       = Родитель;
	НовыйЭлемент.Атрибуты       = Атрибуты;
	НовыйЭлемент.Стили          = Стили;
	НовыйЭлемент.Классы         = Классы;
	
	НовыйЭлемент.Уровень = ?(ЗначениеЗаполнено(ЭлементРодитель)
		, ЭлементРодитель.Уровень + 1
		, 1);
	 
	 Возврат ЭтотОбъект;
		
КонецФункции

Функция УдалитьЭлемент(Знач IDЭлемента) Экспорт

	OPI_ПреобразованиеТипов.ПолучитьСтроку(IDЭлемента);	
	
	СтрокаЭлемента = НайтиЭлемент(IDЭлемента);
	
	Если СтрокаЭлемента = Неопределено Тогда
		Возврат ЭтотОбъект;
	КонецЕсли;
	
	УдаляемыеЭлементы = НайтиДочерние(IDЭлемента);
	УдаляемыеЭлементы.Добавить(СтрокаЭлемента);
	
	Для Каждого УдаляемыйЭлемент Из УдаляемыеЭлементы Цикл
		ЭлементыHTML.Удалить(УдаляемыйЭлемент);
	КонецЦикла;
	
	Возврат ЭтотОбъект;
	
КонецФункции

#КонецОбласти

#Область Стили

Функция СоздатьКласс(Знач Имя, Знач НаборСтилей = Неопределено, Знач Перезаписывать = Ложь) Экспорт
		
	OPI_ПреобразованиеТипов.ПолучитьБулево(Перезаписывать);
	OPI_ПреобразованиеТипов.ПолучитьСтроку(Имя);
	
	Если Не Перезаписывать И Не СтилиCSS.Получить(Имя) = Неопределено Тогда
		
		Шаблон = "Нельзя перезаписать существующий стиль (%1) без явного указания Перезаписывать = Истина!";
		ВызватьИсключение СтрШаблон(Шаблон, Имя);
			
	КонецЕсли;
	
	Если НаборСтилей <> Неопределено Тогда
		
		OPI_ПреобразованиеТипов.ПолучитьКоллекциюКлючИЗначение(НаборСтилей);
		СтилиCSS.Вставить(Имя, НаборСтилей);
		
	Иначе
		СтилиCSS.Вставить(Имя, Новый Соответствие);
	КонецЕсли;
	
	Возврат ЭтотОбъект;
	
КонецФункции

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция НайтиЭлемент(Знач IDЭлемента)

	СтрокиТаблицы = ЭлементыHTML.НайтиСтроки(Новый Структура("ID", IDЭлемента));
	
	Возврат ?(СтрокиТаблицы.Количество() > 0, СтрокиТаблицы[0], Неопределено);
		
КонецФункции

Функция НайтиДочерние(Знач IDЭлемента, Знач Рекурсивно = Истина)

	СтрокиТаблицы = ЭлементыHTML.НайтиСтроки(Новый Структура("Родитель", IDЭлемента));
	
	Если Рекурсивно Тогда
	
		Для Каждого ДочернийЭлемент Из СтрокиТаблицы Цикл
			
			IDДочернего = ДочернийЭлемент["ID"];
			
			Для Каждого СтрокаДочернего Из НайтиДочерние(IDДочернего, Истина) Цикл
				СтрокиТаблицы.Добавить(СтрокаДочернего);	
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат СтрокиТаблицы;
	
КонецФункции

Функция СоздатьШаблонЭлемента(Знач IDЭлемента) Экспорт

	Если IDЭлемента = "" Тогда
		Возврат СоздатьОсновнойШаблон();
	КонецЕсли;
	
	ТекущийЭлемент = НайтиЭлемент(IDЭлемента);
	
	Если ТекущийЭлемент = Неопределено Тогда
		ВызватьИсключение СтрШаблон("Элемент с указанным ID не найден (%1)", IDЭлемента);
	КонецЕсли;
	
	ОткрывающийТэг = ТекущийЭлемент["ОткрывающийТэг"];
	ЗакрывающийТэг = ТекущийЭлемент["ЗакрывающийТэг"];
	Уровень        = ТекущийЭлемент["Уровень"];
	
	Атрибуты = ТекущийЭлемент["Атрибуты"];
	Стили    = ТекущийЭлемент["Стили"];
	Классы   = ТекущийЭлемент["Классы"];
	
	ТекстАртибутов = СформироватьТекстАртибутов(Атрибуты, Стили, Классы);
	
	Если ЗакрывающийТэг Тогда
		
		ОсновнойШаблон = "%1<%2%3>
		|    %1%%1
		|%1</%2>";
		
	Иначе
		ОсновнойШаблон = "%1<%2%3/>";
	КонецЕсли;
	
	СтрокаФормата     = СтрШаблон("ЧЦ=%1; ЧН=; ЧВН=; ЧГ=0", (Уровень - 1) * 4);
	ОтступВложенности = СтрЗаменить(Формат(0, СтрокаФормата), "0", " ");
	
	Отступ = СтрШаблон("%1%2", "        ", ОтступВложенности);
	
	HTML = СтрШаблон(ОсновнойШаблон, Отступ, ОткрывающийТэг, ТекстАртибутов);
	
	Возврат HTML;
		
КонецФункции

Функция СоздатьОсновнойШаблон()
	
	ОсновнойШаблон = "<!DOCTYPE html>
		|<html lang=""ru"">
		|    <head>
		|        <style>
		|%1
		|        </style>
		|    </head>
		|    <body>
		|%%1
		|    </body>
		|</html>";
		
	Возврат СтрШаблон(ОсновнойШаблон, СформироватьCSS());

КонецФункции

Функция СформироватьCSS()
	
	ШаблонНачалаКласса = "            %2 {";
	ШаблонКонцаКласса  = "            }";
	ШаблонСвойства     = "              %1: %2;";
	
	МассивСтрок = Новый Массив;
	
	Для Каждого Класс Из СтилиCSS Цикл
		
		МассивСтрок.Добавить(СтрШаблон(ШаблонНачалаКласса, Класс.Ключ));
		
		Для Каждого СвойствоКласса Из Класс.Значение Цикл
			МассивСтрок.Добавить(СтрШаблон(ШаблонСвойства, СвойствоКласса.Ключ, СвойствоКласса.Значение));
		КонецЦикла;
		
		МассивСтрок.Добавить(ШаблонКонцаКласса);
		МассивСтрок.Добавить("");
				
	КонецЦикла;
	
	Возврат СтрСоединить(МассивСтрок, Символы.ПС);
	
КонецФункции

Функция СформироватьТекстАртибутов(Знач Атрибуты, Знач Стили, Знач Классы)
	
	ШаблонАтрибута  = "%1=""%2""";
	МассивАтрибутов = Новый Массив;
	
	Для Каждого Атрибут Из Атрибуты Цикл
		
		КлючАтрибута     = Атрибут.Ключ;
		ЗначениеАтрибута = OPI_Инструменты.ЧислоВСтроку(Атрибут.Значение);
		
		МассивАтрибутов.Добавить(СтрШаблон(ШаблонАтрибута, КлючАтрибута, ЗначениеАтрибута));
		
	КонецЦикла;
			
	Если ЗначениеЗаполнено(Стили) Тогда
		
		ШаблонСтилей = "style=""%1""";
		ШаблонСтиля  = "%1:%2";
		МассивСтилей = Новый Массив;
		
		Для Каждого Стиль Из Стили Цикл
			МассивСтилей.Добавить(СтрШаблон(ШаблонСтиля, Стиль.Ключ, Стиль.Значение));
		КонецЦикла;
		
		МассивАтрибутов.Добавить(СтрШаблон(ШаблонСтилей, СтрСоединить(МассивСтилей, ";")));
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Классы) Тогда
		
		ШаблонСтилей = "class=""%1""";
		МассивАтрибутов.Добавить(СтрШаблон(ШаблонСтилей, СтрСоединить(Классы, " ")));
		
	КонецЕсли;
	
	Возврат СтрСоединить(МассивАтрибутов, " ");
	
КонецФункции

#КонецОбласти

