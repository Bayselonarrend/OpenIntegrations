#Область СлужебныеПроцедурыИФункции

Функция ИнициализироватьКоннектор(Знач АдресПорт, Знач Вид, Знач Логирование = Неопределено)

    Если СтрНачинаетсяС(Вид, "Connect") Тогда
        OPI_ПреобразованиеТипов.ПолучитьСтроку(АдресПорт);
        OPI_Инструменты.ВернутьУправляющиеПоследовательности(АдресПорт);
    Иначе
        OPI_ПреобразованиеТипов.ПолучитьЧисло(АдресПорт);
    КонецЕсли;

    ZMQ = OPI_Компоненты.ПолучитьКомпоненту("ZeroMQ");

    Если Логирование = Неопределено Тогда

        СтрокаНастроек = "";

    Иначе

        ТекстОшибки    = "Некорректные настройки логирования";
        OPI_ПреобразованиеТипов.ПолучитьКоллекциюКлючИЗначение(Логирование, ТекстОшибки);
        СтрокаНастроек = OPI_Инструменты.JSONСтрокой(Логирование);

    КонецЕсли;

    Если ЗначениеЗаполнено(СтрокаНастроек) Тогда

        РезультатЛога = ZMQ.SetLogger(СтрокаНастроек);
        РезультатЛога = OPI_Инструменты.JsonВСтруктуру(РезультатЛога);

        Если Не РезультатЛога["result"] Тогда
            Возврат РезультатЛога;
        КонецЕсли;

    КонецЕсли;

    Результат = ВыполнитьИнициализацию(ZMQ, АдресПорт, Вид);

    Возврат ?(Результат["result"], ZMQ, Результат);

КонецФункции

Функция ВыполнитьИнициализацию(Знач Коннектор, Знач АдресПорт, Знач Вид)

    Если Вид = "ConnectReq" Тогда
        Результат = Коннектор.ConnectReq(АдресПорт);
    ИначеЕсли Вид = "ConnectSub" Тогда
        Результат = Коннектор.ConnectSub(АдресПорт);
    ИначеЕсли Вид = "ConnectPush" Тогда
        Результат = Коннектор.ConnectPush(АдресПорт);
    ИначеЕсли Вид = "ConnectPull" Тогда
        Результат = Коннектор.ConnectPull(АдресПорт);
    ИначеЕсли Вид = "BindRep" Тогда
        Результат = Коннектор.BindRep(АдресПорт);
    ИначеЕсли Вид = "BindPub" Тогда
        Результат = Коннектор.BindPub(АдресПорт);
    ИначеЕсли Вид = "BindPush" Тогда
        Результат = Коннектор.BindPush(АдресПорт);
    ИначеЕсли Вид = "BindPull" Тогда
        Результат = Коннектор.BindPull(АдресПорт);
    Иначе
