#Область ПрограммныйИнтерфейс

Функция СериализоватьДанные(Знач Данные) Экспорт

	ПотокДанных = Новый ПотокВПамяти();
	ЗаписатьЗначение(Данные, ПотокДанных);

	СериализованныеДанные = ПотокДанных.ЗакрытьИПолучитьДвоичныеДанные();

	Возврат СериализованныеДанные;

КонецФункции

Функция ДесериализоватьДанные(Знач Данные) Экспорт

	Буфер  = ПолучитьБуферДвоичныхДанныхИзДвоичныхДанных(Данные);
	Чтение = ПрочитатьЗначение(Буфер, 0);

	Возврат Чтение.Значение;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ЗаписатьЗначение(Знач Данные, ПотокДанных)

	ТипДанных = ТипЗнч(Данные);

	Если Данные = Неопределено Тогда

		ЗаписатьNilВПоток(ПотокДанных);

	ИначеЕсли ТипДанных = Тип("Булево") Тогда

		ЗаписатьБулевоВПоток(Данные, ПотокДанных);

	ИначеЕсли ТипДанных = Тип("Строка") Тогда

		ЗаписатьСтрокуВПоток(Данные, ПотокДанных);

	ИначеЕсли ТипДанных = Тип("ДвоичныеДанные") Тогда

		ЗаписатьБинарныеДанныеВПоток(Данные, ПотокДанных);

	ИначеЕсли ТипДанных = Тип("Число") Тогда

		ЗаписатьЧислоВПоток(Данные, ПотокДанных);

	КонецЕсли;

КонецПроцедуры

Функция ПрочитатьЗначение(Знач Буфер, Знач Позиция)

	Тег = Буфер.Получить(Позиция);

	Если Тег <= _posFixintMax() Тогда
		Возврат РезультатЧтения(Тег, Позиция + 1);
	КонецЕсли;

	Если Тег >= _negFixintMin() Тогда
		Возврат РезультатЧтения(Тег - 256, Позиция + 1);
	КонецЕсли;

	Если Тег >= _fixstr() И Тег <= _fixstrMax() Тогда
		Возврат ПрочитатьСтрокуИзБуфера(Буфер, Позиция + 1, Тег - _fixstr());
	КонецЕсли;

	Если Тег = _str8() Тогда
		Длина = Буфер.Получить(Позиция + 1);
		Возврат ПрочитатьСтрокуИзБуфера(Буфер, Позиция + 2, Длина);
	КонецЕсли;

	Если Тег = _str16() Тогда
		ЧтениеДлины = ПрочитатьБеззнаковоеЦелое16ИзБуфера(Буфер, Позиция + 1);
		Возврат ПрочитатьСтрокуИзБуфера(Буфер, ЧтениеДлины.Позиция, ЧтениеДлины.Значение);
	КонецЕсли;

	Если Тег = _str32() Тогда
		ЧтениеДлины = ПрочитатьБеззнаковоеЦелое32ИзБуфера(Буфер, Позиция + 1);
		Возврат ПрочитатьСтрокуИзБуфера(Буфер, ЧтениеДлины.Позиция, ЧтениеДлины.Значение);
	КонецЕсли;

	Если Тег = _nil() Тогда
		Возврат РезультатЧтения(Неопределено, Позиция + 1);
	КонецЕсли;

	Если Тег = _false() Тогда
		Возврат РезультатЧтения(Ложь, Позиция + 1);
	КонецЕсли;

	Если Тег = _true() Тогда
		Возврат РезультатЧтения(Истина, Позиция + 1);
	КонецЕсли;

	Если Тег = _bin8() Тогда
		Длина = Буфер.Получить(Позиция + 1);
		Возврат ПрочитатьБинарныеДанныеИзБуфера(Буфер, Позиция + 2, Длина);
	КонецЕсли;

	Если Тег = _bin16() Тогда
		ЧтениеДлины = ПрочитатьБеззнаковоеЦелое16ИзБуфера(Буфер, Позиция + 1);
		Возврат ПрочитатьБинарныеДанныеИзБуфера(Буфер, ЧтениеДлины.Позиция, ЧтениеДлины.Значение);
	КонецЕсли;

	Если Тег = _bin32() Тогда
		ЧтениеДлины = ПрочитатьБеззнаковоеЦелое32ИзБуфера(Буфер, Позиция + 1);
		Возврат ПрочитатьБинарныеДанныеИзБуфера(Буфер, ЧтениеДлины.Позиция, ЧтениеДлины.Значение);
	КонецЕсли;

	ЧтениеЧисла = ПрочитатьЧисло(Буфер, Позиция, Тег);

	Если ЧтениеЧисла <> Неопределено Тогда
		Возврат ЧтениеЧисла;
	КонецЕсли;

	ВызватьИсключение "Неподдерживаемый тег MessagePack: " + Формат(Тег, "ЧН=0; ЧГ=");

КонецФункции

#Область Общее

Процедура ЗаписатьБуферВПоток(Знач Буфер, Знач Размер, ПотокДанных)

	ПотокДанных.Записать(Буфер, 0, Размер);

КонецПроцедуры

Функция СоздатьМеткуТипа(Знач РазмерМетки, Знач Байт, Знач РазмерДанных = Неопределено)

	Метка = Новый БуферДвоичныхДанных(РазмерМетки, ПорядокБайтов.BigEndian);
	Метка.Установить(0, Байт);

	Если РазмерДанных <> Неопределено Тогда
		Метка.Установить(1, РазмерДанных);
	КонецЕсли;

	Возврат Метка;

КонецФункции

Функция РезультатЧтения(Знач Значение, Знач Позиция)

	Возврат Новый Структура("Значение, Позиция", Значение, Позиция);

КонецФункции

Функция ПрочитатьБеззнаковоеЦелое16ИзБуфера(Знач Буфер, Знач Позиция)

	Байт0 = Буфер.Получить(Позиция);
	Байт1 = Буфер.Получить(Позиция + 1);

	Возврат РезультатЧтения(Байт0 * 256 + Байт1, Позиция + 2);

КонецФункции

Функция ПрочитатьБеззнаковоеЦелое32ИзБуфера(Знач Буфер, Знач Позиция)

	Значение = Буфер.ПрочитатьЦелое32(Позиция);

	Если Значение < 0 Тогда
		Значение = Значение + 4294967296;
	КонецЕсли;

	Возврат РезультатЧтения(Значение, Позиция + 4);

КонецФункции

Функция ПрочитатьБеззнаковоеЦелое64ИзБуфера(Знач Буфер, Знач Позиция)

	Значение = Буфер.ПрочитатьЦелое64(Позиция);

	Если Значение < 0 Тогда
		Значение = Значение + 18446744073709551616;
	КонецЕсли;

	Возврат РезультатЧтения(Значение, Позиция + 8);

КонецФункции

Функция ПрочитатьЗнаковоеЦелое8ИзБуфера(Знач Буфер, Знач Позиция)

	Байт = Буфер.Получить(Позиция);

	Если Байт >= 128 Тогда
		Байт = Байт - 256;
	КонецЕсли;

	Возврат РезультатЧтения(Байт, Позиция + 1);

КонецФункции

Функция ПрочитатьЗнаковоеЦелое16ИзБуфера(Знач Буфер, Знач Позиция)

	Значение = Буфер.ПрочитатьЦелое16(Позиция);

	Возврат РезультатЧтения(Значение, Позиция + 2);

КонецФункции

Функция ПрочитатьЗнаковоеЦелое32ИзБуфера(Знач Буфер, Знач Позиция)

	Значение = Буфер.ПрочитатьЦелое32(Позиция);

	Возврат РезультатЧтения(Значение, Позиция + 4);

КонецФункции

Функция ПрочитатьЗнаковоеЦелое64ИзБуфера(Знач Буфер, Знач Позиция)

	Значение = Буфер.ПрочитатьЦелое64(Позиция);

	Возврат РезультатЧтения(Значение, Позиция + 8);

КонецФункции

Функция ПрочитатьВещественное32ИзБуфера(Знач Буфер, Знач Позиция)

	БуферЧисла = Буфер.Прочитать(Позиция, 4);
	Значение   = ДекодироватьFloat32BE(БуферЧисла);

	Возврат РезультатЧтения(Значение, Позиция + 4);

КонецФункции

Функция ПрочитатьВещественное64ИзБуфера(Знач Буфер, Знач Позиция)

	БуферЧисла = Буфер.Прочитать(Позиция, 8);
	Значение   = ДекодироватьFloat64BE(БуферЧисла);

	Возврат РезультатЧтения(Значение, Позиция + 8);

КонецФункции

Функция ДелительМантиссыFloat32()

	Возврат 8388608;

КонецФункции

Функция ДелительМантиссыFloat64()

	Возврат 4503599627370496;

КонецФункции

Функция ПолучитьНесмещеннуюЭкспонентуIEEE754(Знач Абс)

	ЭкспНеСмещ = Цел(Log(Абс) / Log(2));

	Пока Абс < Pow(2, ЭкспНеСмещ) Цикл
		ЭкспНеСмещ = ЭкспНеСмещ - 1;
	КонецЦикла;

	Возврат ЭкспНеСмещ;

КонецФункции

Функция ЗакодироватьFloat32BE(Знач Число)

	Буфер = Новый БуферДвоичныхДанных(4, ПорядокБайтов.BigEndian);

	Если Число = 0 Тогда
		Возврат Буфер;
	КонецЕсли;

	Знак = ?(Число < 0, 1, 0);
	Абс  = ?(Число < 0, -Число, Число);

	ЭкспНеСмещ = ПолучитьНесмещеннуюЭкспонентуIEEE754(Абс);
	Доля         = Абс / Pow(2, ЭкспНеСмещ);
	Мантисса     = (Доля - 1) * ДелительМантиссыFloat32();
	МантиссаЦел  = Цел(Окр(Мантисса, 0));
	ЭкспСмещ     = ЭкспНеСмещ + 127;

	Буфер.Установить(0, Знак * 128 + Цел(ЭкспСмещ / 2));
	Буфер.Установить(1, (ЭкспСмещ % 2) * 128 + Цел(МантиссаЦел / 65536));

	ОстатокМантиссы = МантиссаЦел % 65536;
	Буфер.Установить(2, Цел(ОстатокМантиссы / 256));
	Буфер.Установить(3, ОстатокМантиссы % 256);

	Возврат Буфер;

КонецФункции

Функция ДекодироватьFloat32BE(Знач Буфер)

	Байт0 = Буфер.Получить(0);
	Байт1 = Буфер.Получить(1);

	Знак       = ?(Байт0 >= 128, -1, 1);
	Экспонента = (Байт0 % 128) * 2 + Цел(Байт1 / 128);
	Мантисса   = (Байт1 % 128) * 65536 + Буфер.Получить(2) * 256 + Буфер.Получить(3);

	Если Экспонента = 0 И Мантисса = 0 Тогда
		Возврат 0;
	КонецЕсли;

	Возврат Знак * (1 + Мантисса / ДелительМантиссыFloat32()) * Pow(2, Экспонента - 127);

КонецФункции

Функция ЗакодироватьFloat64BE(Знач Число)

	Буфер = Новый БуферДвоичныхДанных(8, ПорядокБайтов.BigEndian);

	Если Число = 0 Тогда
		Возврат Буфер;
	КонецЕсли;

	Знак = ?(Число < 0, 1, 0);
	Абс  = ?(Число < 0, -Число, Число);

	ЭкспНеСмещ  = ПолучитьНесмещеннуюЭкспонентуIEEE754(Абс);
	Доля        = Абс / Pow(2, ЭкспНеСмещ);
	Мантисса    = (Доля - 1) * ДелительМантиссыFloat64();
	МантиссаЦел = Цел(Окр(Мантисса, 0));
	ЭкспСмещ    = ЭкспНеСмещ + 1023;

	Буфер.Установить(0, Знак * 128 + Цел(ЭкспСмещ / 16));
	Буфер.Установить(1, (ЭкспСмещ % 16) * 16 + Цел(МантиссаЦел / Pow(2, 48)));

	ОстатокМантиссы = МантиссаЦел % Pow(2, 48);

	Для Индекс = 2 По 7 Цикл
		Сдвиг = (7 - Индекс) * 8;
		Буфер.Установить(Индекс, Цел(ОстатокМантиссы / Pow(2, Сдвиг)) % 256);
	КонецЦикла;

	Возврат Буфер;

КонецФункции

Функция ДекодироватьFloat64BE(Знач Буфер)

	Байт0 = Буфер.Получить(0);
	Байт1 = Буфер.Получить(1);

	Знак       = ?(Байт0 >= 128, -1, 1);
	Экспонента = (Байт0 % 128) * 16 + Цел(Байт1 / 16);
	Мантисса   = (Байт1 % 16) * Pow(2, 48);

	Для Индекс = 2 По 7 Цикл
		Мантисса = Мантисса + Буфер.Получить(Индекс) * Pow(2, (7 - Индекс) * 8);
	КонецЦикла;

	Если Экспонента = 0 И Мантисса = 0 Тогда
		Возврат 0;
	КонецЕсли;

	Возврат Знак * (1 + Мантисса / ДелительМантиссыFloat64()) * Pow(2, Экспонента - 1023);

КонецФункции

#КонецОбласти

#Область ТипNil

Процедура ЗаписатьNilВПоток(ПотокДанных)

	МеткаТипа = СоздатьМеткуТипа(1, _nil());
	ЗаписатьБуферВПоток(МеткаТипа, 1, ПотокДанных);

КонецПроцедуры

#КонецОбласти

#Область ТипБулево

Процедура ЗаписатьБулевоВПоток(Знач Данные, ПотокДанных)

	БайтМетки = ?(Данные, _true(), _false());
	МеткаТипа = СоздатьМеткуТипа(1, БайтМетки);

	ЗаписатьБуферВПоток(МеткаТипа, 1, ПотокДанных);

КонецПроцедуры

#КонецОбласти

#Область ТипСтрока

Процедура ЗаписатьСтрокуВПоток(Знач Данные, ПотокДанных)

	СтрокаДД     = ПолучитьДвоичныеДанныеИзСтроки(Данные, "UTF-8");
	РазмерДанных = СтрокаДД.Размер();

	Если РазмерДанных < 32 Тогда

		РазмерМетки = 1;
		МеткаТипа   = СоздатьМеткуТипа(РазмерМетки, _fixstr() + РазмерДанных);

	ИначеЕсли РазмерДанных < 256 Тогда

		РазмерМетки = 2;
		МеткаТипа   = СоздатьМеткуТипа(РазмерМетки, _str8(), РазмерДанных);

	ИначеЕсли РазмерДанных < 65536 Тогда

		РазмерМетки = 3;
		МеткаТипа   = СоздатьМеткуТипа(РазмерМетки, _str16());
		МеткаТипа.ЗаписатьЦелое16(1, РазмерДанных);

	Иначе

		РазмерМетки = 5;
		МеткаТипа   = СоздатьМеткуТипа(РазмерМетки, _str32());
		МеткаТипа.ЗаписатьЦелое32(1, РазмерДанных);

	КонецЕсли;

	СтрокаБуфер = ПолучитьБуферДвоичныхДанныхИзДвоичныхДанных(СтрокаДД);

	ЗаписатьБуферВПоток(МеткаТипа, РазмерМетки, ПотокДанных);
	ЗаписатьБуферВПоток(СтрокаБуфер, РазмерДанных, ПотокДанных);

КонецПроцедуры

Функция ПрочитатьСтрокуИзБуфера(Знач Буфер, Знач Позиция, Знач Длина)

	Если Длина = 0 Тогда
		Возврат РезультатЧтения("", Позиция);
	КонецЕсли;

	ФрагментБуфер = Буфер.Прочитать(Позиция, Длина);
	ФрагментДД    = ПолучитьДвоичныеДанныеИзБуфераДвоичныхДанных(ФрагментБуфер);
	Строка        = ПолучитьСтрокуИзДвоичныхДанных(ФрагментДД, "UTF-8");

	Возврат РезультатЧтения(Строка, Позиция + Длина);

КонецФункции

#КонецОбласти

#Область ТипБинарные

Процедура ЗаписатьБинарныеДанныеВПоток(Знач Данные, ПотокДанных)

	РазмерДанных = Данные.Размер();

	Если РазмерДанных < 256 Тогда

		РазмерМетки = 2;
		МеткаТипа   = СоздатьМеткуТипа(РазмерМетки, _bin8(), РазмерДанных);

	ИначеЕсли РазмерДанных < 65536 Тогда

		РазмерМетки = 3;
		МеткаТипа   = СоздатьМеткуТипа(РазмерМетки, _bin16());
		МеткаТипа.ЗаписатьЦелое16(1, РазмерДанных);

	Иначе

		РазмерМетки = 5;
		МеткаТипа   = СоздатьМеткуТипа(РазмерМетки, _bin32());
		МеткаТипа.ЗаписатьЦелое32(1, РазмерДанных);

	КонецЕсли;

	ТелоБуфер = ПолучитьБуферДвоичныхДанныхИзДвоичныхДанных(Данные);

	ЗаписатьБуферВПоток(МеткаТипа, РазмерМетки, ПотокДанных);
	ЗаписатьБуферВПоток(ТелоБуфер, РазмерДанных, ПотокДанных);

КонецПроцедуры

Функция ПрочитатьБинарныеДанныеИзБуфера(Знач Буфер, Знач Позиция, Знач Длина)

	Если Длина = 0 Тогда
		Возврат РезультатЧтения(ПолучитьДвоичныеДанныеИзСтроки(""), Позиция);
	КонецЕсли;

	ФрагментБуфер = Буфер.Прочитать(Позиция, Длина);
	ФрагментДД    = ПолучитьДвоичныеДанныеИзБуфераДвоичныхДанных(ФрагментБуфер);

	Возврат РезультатЧтения(ФрагментДД, Позиция + Длина);

КонецФункции

#КонецОбласти

#Область ТипЧисло

Процедура ЗаписатьЧислоВПоток(Знач Данные, ПотокДанных)

	Если Данные = Цел(Данные) Тогда

		Если Данные >= 0 Тогда
			ЗаписатьПоложительноеЦелоеВПоток(Данные, ПотокДанных);
		Иначе
			ЗаписатьОтрицательноеЦелоеВПоток(Данные, ПотокДанных);
		КонецЕсли;

	Иначе
		ЗаписатьВещественноеЧислоВПоток(Данные, ПотокДанных);
	КонецЕсли;

КонецПроцедуры

Процедура ЗаписатьВещественноеЧислоВПоток(Знач Число, ПотокДанных)

	БуферПроверки = ЗакодироватьFloat32BE(Число);

	Если ДекодироватьFloat32BE(БуферПроверки) = Число Тогда
		ЗаписатьВещественное32ВПоток(Число, ПотокДанных);
	Иначе
		ЗаписатьВещественное64ВПоток(Число, ПотокДанных);
	КонецЕсли;

КонецПроцедуры

Процедура ЗаписатьВещественное32ВПоток(Знач Число, ПотокДанных)

	МеткаТипа = СоздатьМеткуТипа(1, _float32());
	Тело      = ЗакодироватьFloat32BE(Число);

	ЗаписатьБуферВПоток(МеткаТипа, 1, ПотокДанных);
	ЗаписатьБуферВПоток(Тело, 4, ПотокДанных);

КонецПроцедуры

Процедура ЗаписатьВещественное64ВПоток(Знач Число, ПотокДанных)

	МеткаТипа = СоздатьМеткуТипа(1, _float64());
	Тело      = ЗакодироватьFloat64BE(Число);

	ЗаписатьБуферВПоток(МеткаТипа, 1, ПотокДанных);
	ЗаписатьБуферВПоток(Тело, 8, ПотокДанных);

КонецПроцедуры

Процедура ЗаписатьПоложительноеЦелоеВПоток(Знач Число, ПотокДанных)

	Если Число <= _posFixintMax() Тогда

		РазмерМетки = 1;
		МеткаТипа   = СоздатьМеткуТипа(РазмерМетки, Число);

	ИначеЕсли Число < 256 Тогда

		РазмерМетки = 2;
		МеткаТипа   = СоздатьМеткуТипа(РазмерМетки, _uint8(), Число);

	ИначеЕсли Число < 65536 Тогда

		РазмерМетки = 3;
		МеткаТипа   = СоздатьМеткуТипа(РазмерМетки, _uint16());
		МеткаТипа.ЗаписатьЦелое16(1, Число);

	ИначеЕсли Число < 4294967296 Тогда

		РазмерМетки = 5;
		МеткаТипа   = СоздатьМеткуТипа(РазмерМетки, _uint32());
		МеткаТипа.ЗаписатьЦелое32(1, Число);

	Иначе

		РазмерМетки = 9;
		МеткаТипа   = СоздатьМеткуТипа(РазмерМетки, _uint64());
		МеткаТипа.ЗаписатьЦелое64(1, Число);

	КонецЕсли;

	ЗаписатьБуферВПоток(МеткаТипа, РазмерМетки, ПотокДанных);

КонецПроцедуры

Процедура ЗаписатьОтрицательноеЦелоеВПоток(Знач Число, ПотокДанных)

	Если Число >= -32 Тогда

		РазмерМетки = 1;
		МеткаТипа   = СоздатьМеткуТипа(РазмерМетки, _negFixintMin() + 32 + Число);

	ИначеЕсли Число >= -128 Тогда

		РазмерМетки = 2;
		МеткаТипа   = СоздатьМеткуТипа(РазмерМетки, _int8(), _negFixintMin() + 32 + Число);

	ИначеЕсли Число >= -32768 Тогда

		РазмерМетки = 3;
		МеткаТипа   = СоздатьМеткуТипа(РазмерМетки, _int16());
		МеткаТипа.ЗаписатьЦелое16(1, Число);

	ИначеЕсли Число >= -2147483648 Тогда

		РазмерМетки = 5;
		МеткаТипа   = СоздатьМеткуТипа(РазмерМетки, _int32());
		МеткаТипа.ЗаписатьЦелое32(1, Число);

	Иначе

		РазмерМетки = 9;
		МеткаТипа   = СоздатьМеткуТипа(РазмерМетки, _int64());
		МеткаТипа.ЗаписатьЦелое64(1, Число);

	КонецЕсли;

	ЗаписатьБуферВПоток(МеткаТипа, РазмерМетки, ПотокДанных);

КонецПроцедуры

Функция ПрочитатьЧисло(Знач Буфер, Знач Позиция, Знач Тег)

	Если Тег = _uint8() Тогда
		Возврат РезультатЧтения(Буфер.Получить(Позиция + 1), Позиция + 2);
	КонецЕсли;

	Если Тег = _uint16() Тогда
		Возврат ПрочитатьБеззнаковоеЦелое16ИзБуфера(Буфер, Позиция + 1);
	КонецЕсли;

	Если Тег = _uint32() Тогда
		Возврат ПрочитатьБеззнаковоеЦелое32ИзБуфера(Буфер, Позиция + 1);
	КонецЕсли;

	Если Тег = _uint64() Тогда
		Возврат ПрочитатьБеззнаковоеЦелое64ИзБуфера(Буфер, Позиция + 1);
	КонецЕсли;

	Если Тег = _int8() Тогда
		Возврат ПрочитатьЗнаковоеЦелое8ИзБуфера(Буфер, Позиция + 1);
	КонецЕсли;

	Если Тег = _int16() Тогда
		Возврат ПрочитатьЗнаковоеЦелое16ИзБуфера(Буфер, Позиция + 1);
	КонецЕсли;

	Если Тег = _int32() Тогда
		Возврат ПрочитатьЗнаковоеЦелое32ИзБуфера(Буфер, Позиция + 1);
	КонецЕсли;

	Если Тег = _int64() Тогда
		Возврат ПрочитатьЗнаковоеЦелое64ИзБуфера(Буфер, Позиция + 1);
	КонецЕсли;

	Если Тег = _float32() Тогда
		Возврат ПрочитатьВещественное32ИзБуфера(Буфер, Позиция + 1);
	КонецЕсли;

	Если Тег = _float64() Тогда
		Возврат ПрочитатьВещественное64ИзБуфера(Буфер, Позиция + 1);
	КонецЕсли;

	Возврат Неопределено;

