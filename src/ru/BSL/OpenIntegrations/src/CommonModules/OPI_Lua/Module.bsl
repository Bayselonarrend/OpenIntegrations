#КонецОбласти

#Область ГлобальныеПеременные

// Установить глобальную переменную !NOCLI
// Устанавливает значение глобальной переменной в контексте
//
// Параметры:
//  Lua      - Произвольный - Компонента Lua или версия Lua для запуска - lua
//  Имя      - Строка       - Имя переменной                            - name
//  Значение - Произвольный - Значение переменной                       - value
//
// Возвращаемое значение:
//  Соответствие Из КлючИЗначение - Результат выполнения
Функция УстановитьГлобальнуюПеременную(Знач Lua, Знач Имя, Знач Значение) Экспорт

    Компонента = СоздатьVM(Lua);

    Если Не ЭтоVM(Компонента) Тогда
        Возврат Компонента;
    КонецЕсли;

    OPI_ПреобразованиеТипов.ПолучитьСтроку(Имя);

    Данные     = Новый Структура("data", Значение);
    ДанныеJanx = OPI_Компоненты.СериализоватьJanx(Данные);

    Результат = Компонента.SetGlobal(Имя, ДанныеJanx);

    Данные = РезультатИзJanx(Результат);

    Возврат Данные;

КонецФункции

// Получить глобальную переменную !NOCLI
// Получает значение глобальной переменной контекста
//
// Параметры:
//  Lua - Произвольный - Компонента Lua или версия Lua для запуска - lua
//  Имя - Строка       - Имя переменной                            - name
//
// Возвращаемое значение:
//  Произвольный - Значение переменной
Функция ПолучитьГлобальнуюПеременную(Знач Lua, Знач Имя) Экспорт

    Компонента = СоздатьVM(Lua);

    Если Не ЭтоVM(Компонента) Тогда
        Возврат Компонента;
    КонецЕсли;

    OPI_ПреобразованиеТипов.ПолучитьСтроку(Имя);

    Результат = Компонента.GetGlobal(Имя);

    Данные = РезультатИзJanx(Результат);

    Возврат Данные;

КонецФункции

#КонецОбласти

#Область УправлениеПакетами

// Добавить пакет из строки !NOCLI
// Добавляет код из строки как пакет с указанным именем
//
// Параметры:
//  Lua       - Произвольный - Компонента Lua или версия Lua для запуска                  - lua
//  ИмяПакета - Строка       - Имя пакета, по которому он будет доступен после добавления - name
//  Код       - Строка       - Программный код пакета                                     - code
//
// Возвращаемое значение:
//  Соответствие Из КлючИЗначение - Результат добавления
Функция ДобавитьПакетИзСтроки(Знач Lua, Знач ИмяПакета, Знач Код) Экспорт

    Компонента = СоздатьVM(Lua);

    Если Не ЭтоVM(Компонента) Тогда
        Возврат Компонента;
    КонецЕсли;
    
    OPI_ПреобразованиеТипов.ПолучитьСтроку(ИмяПакета);
    OPI_ПреобразованиеТипов.ПолучитьСтроку(Код);
    
	Результат = Компонента.AddPackage(ИмяПакета, Код);

    Возврат РезультатИзJanx(Результат);

КонецФункции

// Добавить пакет из файла !NOCLI
// Добавляет код из файла как пакет с указанным именем
//
// Параметры:
//  Lua       - Произвольный - Компонента Lua или версия Lua для запуска                  - lua
//  ИмяПакета - Строка       - Имя пакета, по которому он будет доступен после добавления - name
//  Путь      - Строка       - Путь к файлу кода                                          - filepath
//
// Возвращаемое значение:
//  Соответствие Из КлючИЗначение - Результат добавления
Функция ДобавитьПакетИзФайла(Знач Lua, Знач ИмяПакета, Знач Путь) Экспорт

    Компонента = СоздатьVM(Lua);

    Если Не ЭтоVM(Компонента) Тогда
        Возврат Компонента;
    КонецЕсли;
    
    OPI_ПреобразованиеТипов.ПолучитьСтроку(Путь);
    OPI_ПреобразованиеТипов.ПолучитьСтроку(ИмяПакета);

    ФайлСкрипта = Новый Файл(Путь);

    Если Не ФайлСкрипта.Существует() Тогда
        ВызватьИсключение "File not found";
    КонецЕсли;
    
	Результат = Компонента.LoadPackageFromFile(ИмяПакета, Путь);
	
	Возврат РезультатИзJanx(Результат);

КонецФункции

// Получить список пакетов !NOCLI
// Получает список добавленных в окружение пакетов
// 
// Параметры:
//  Lua - Произвольный - Компонента Lua или версия Lua для запуска - lua
//
// Возвращаемое значение:
//  Массив Из Строка - Результат выполнения
Функция ПолучитьСписокПакетов(Знач Lua) Экспорт

    Компонента = СоздатьVM(Lua);

    Если Не ЭтоVM(Компонента) Тогда
        Возврат Компонента;
    КонецЕсли;
    
	Результат = Компонента.GetPackages();
	
	Возврат РезультатИзJanx(Результат);

КонецФункции

#КонецОбласти

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Процедура ПодключитьПакеты(Знач Компонента, Знач Пакеты)

    OPI_ПреобразованиеТипов.ПолучитьКоллекциюКлючИЗначение(Пакеты);

    Для Каждого Пакет Из Пакеты Цикл

        ИмяПакета = Пакет.Ключ;
        Источник  = Пакет.Значение;

        OPI_ПреобразованиеТипов.ПолучитьСтроку(ИмяПакета);
        OPI_ПреобразованиеТипов.ПолучитьСтроку(Источник);

        ФайлПакета = Новый Файл(Источник);

        Если ФайлПакета.Существует() Тогда
            ДобавитьПакетИзФайла(Компонента, ИмяПакета, Источник);
        Иначе
            OPI_ПреобразованиеТипов.ПолучитьСтроку(Источник, Истина);
            ДобавитьПакетИзСтроки(Компонента, ИмяПакета, Источник);
        КонецЕсли;

        ВыполнитьКодИзСтроки(Компонента, СтрШаблон("%1 = require('%2')", ИмяПакета, ИмяПакета));

    КонецЦикла;

КонецПроцедуры

Функция РезультатИзJanx(Знач ДанныеJanx)

    Результат = OPI_Компоненты.ДесериализоватьJanx(ДанныеJanx);

    Если Не Результат["result"] Тогда
        ВызватьИсключение Результат["error"];
    КонецЕсли;

    Возврат Результат["data"];

КонецФункции

#КонецОбласти

