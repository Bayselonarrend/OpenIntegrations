#Область ПрограммныйИнтерфейс

// Сериализовать данные в формат Janx-1
//
// Параметры:
//  Данные - Произвольный - Значение для сериализации
//
// Возвращаемое значение:
//  ДвоичныеДанные - [u32 BE: длина JSON UTF-8][JSON][appendix: бинарные блоки]
Функция СериализоватьДанные(Знач Данные) Экспорт
	
	ТипМассив          = Тип("Массив");
	ТипДвоичнныеДанные = Тип("ДвоичныеДанные");
	ТипСтруктура       = Тип("Структура");
	ТипСоответствие    = Тип("Соответствие");

	МассивДвоичных = Новый Массив;
	Смещение       = 0;
	
	Подготовленные = ПодготовитьЗначениеДляJSONJanx(Данные
		, МассивДвоичных
		, Смещение
		, ТипМассив
		, ТипДвоичнныеДанные
		, ТипСтруктура
		, ТипСоответствие);

	JSONСтрока = ЗначениеВJSONJanx(Подготовленные);
	JSONДД     = ПолучитьДвоичныеДанныеИзСтроки(JSONСтрока, "UTF-8");
	РазмерJSON = JSONДД.Размер();

	ПрефиксДД = УпаковатьЦелое32BEJanx(РазмерJSON);

	ПотокДанных = Новый ПотокВПамяти();
	Запись      = Новый ЗаписьДанных(ПотокДанных);

	Запись.Записать(ПрефиксДД);
	Запись.Записать(JSONДД);

	Для Каждого Блок Из МассивДвоичных Цикл
		Запись.Записать(Блок);
	КонецЦикла;

	Запись.Закрыть();

	Возврат ПотокДанных.ЗакрытьИПолучитьДвоичныеДанные();

КонецФункции

// Десериализовать данные формата Janx-1
//
// Параметры:
//  Данные - ДвоичныеДанные - Сериализованное значение
//
// Возвращаемое значение:
//  Произвольный - Восстановленное значение
Функция ДесериализоватьДанные(Знач Данные) Экспорт
	
	РазмерВсего = Данные.Размер();

	Если РазмерВсего < РазмерПрефиксаJanx() Тогда
		ВызватьИсключение "Некорректный формат Janx: слишком короткие данные";
	КонецЕсли;

	Буфер = ПолучитьБуферДвоичныхДанныхИзДвоичныхДанных(Данные);
	
	РазмерJSON = ПрочитатьЦелое32BEJanx(Буфер, 0);
	НачалоJSON = РазмерПрефиксаJanx();
	КонецJSON  = НачалоJSON + РазмерJSON;

	Если КонецJSON > РазмерВсего Тогда
		ВызватьИсключение "Некорректный формат Janx: длина JSON выходит за границы данных";
	КонецЕсли;

	БуферJSON  = Буфер.Прочитать(НачалоJSON, РазмерJSON);
	JSONСтрока = ПолучитьСтрокуИзБуфераДвоичныхДанных(БуферJSON, "UTF-8");

	ДеревоJSON = ПрочитатьJSONJanx(JSONСтрока); 
	
	ТипМассив       = Тип("Массив");
	ТипСоответствие = Тип("Соответствие");
	ТипСтруктура    = Тип("Структура");
	
	Результат = ВосстановитьЗначениеИзJSONJanx(ДеревоJSON
		, Буфер
		, КонецJSON
		, ТипМассив
		, ТипСоответствие
		, ТипСтруктура);
		
	Возврат Результат;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область КонстантыJanx

Функция КлючМаркераБинарныхJanx()

	Возврат "__JANXB__";

КонецФункции

Функция РазмерПрефиксаJanx()

	Возврат 4;

КонецФункции

#КонецОбласти

#Область ПодготовкаJSON

Функция ПодготовитьЗначениеДляJSONJanx(Знач Данные
	, МассивДвоичных
	, Смещение
	, Знач ТипМассив
	, Знач ТипДвоичныеДанные
	, Знач ТипСтруктура
	, Знач ТипСоответствие)

	Если Данные = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	ТипДанных = ТипЗнч(Данные);
	
	Если ТипДанных = ТипДвоичныеДанные Тогда
		Возврат СоздатьМаркерБинарныхJanx(Данные, МассивДвоичных, Смещение);
	КонецЕсли;

	Если ТипДанных = ТипМассив Тогда

		Результат = Новый Массив;

		Для Каждого Элемент Из Данные Цикл    
			
			Результат.Добавить(ПодготовитьЗначениеДляJSONJanx(Элемент
				, МассивДвоичных
				, Смещение
				, ТипМассив
				, ТипДвоичныеДанные
				, ТипСтруктура
				, ТипСоответствие));           
				
		КонецЦикла;

		Возврат Результат;

	КонецЕсли;

	Если ТипДанных = ТипСтруктура Или ТипДанных = ТипСоответствие Тогда

		Результат = Новый Соответствие;

		Для Каждого Пара Из Данные Цикл
			
			ПодготовленноеЗначение = ПодготовитьЗначениеДляJSONJanx(Пара.Значение
				, МассивДвоичных
				, Смещение
				, ТипМассив
				, ТипДвоичныеДанные
				, ТипСтруктура
				, ТипСоответствие);
			
			КлючСтрока = Пара.Ключ;
			Результат.Вставить(КлючСтрока, ПодготовленноеЗначение);

		КонецЦикла;

		Возврат Результат;

	КонецЕсли;

	Возврат Данные;

КонецФункции

Функция СоздатьМаркерБинарныхJanx(Знач ДвоичныеДанные, МассивДанных, Смещение)

	Длина    = ДвоичныеДанные.Размер();

	МассивДанных.Добавить(ДвоичныеДанные);
	Смещение = Смещение + Длина;

	Описание = Новый Структура("s, l", Смещение, Длина);

	Возврат Новый Структура(КлючМаркераБинарныхJanx(), Описание);

КонецФункции

Функция ЗначениеВJSONJanx(Знач Данные)

	ПараметрыJSON = Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Нет, "");

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку(ПараметрыJSON);

	ЗаписатьJSON(ЗаписьJSON, Данные);

	Возврат ЗаписьJSON.Закрыть();

КонецФункции

Функция ПрочитатьJSONJanx(Знач JSONСтрока)

	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(JSONСтрока);

	Возврат ПрочитатьJSON(ЧтениеJSON, Истина);

КонецФункции

#КонецОбласти

#Область ВосстановлениеJSON

Функция ВосстановитьЗначениеИзJSONJanx(Знач Данные
	, Знач Буфер
	, Знач СмещениеПриложения
	, Знач ТипМассив
	, Знач ТипСоответствие
	, Знач ТипСтруктура)

	ЗначениеМаркера = Неопределено;
	
	МаркерJanx = ПопытатьсяПолучитьМаркерJanx(Данные
		, ЗначениеМаркера
		, ТипСоответствие
		, ТипСтруктура);
	
	Если МаркерJanx Тогда
		
		Возврат ИзвлечьБинарныеПоМаркеруJanx(ЗначениеМаркера
			, Буфер
			, СмещениеПриложения);    
			
	КонецЕсли;

	ТипДанных = ТипЗнч(Данные);

	Если ТипДанных = ТипМассив Тогда

		Результат = Новый Массив;

		Для Каждого Элемент Из Данные Цикл            
			
			ВосстановленноеЗначение = ВосстановитьЗначениеИзJSONJanx(Элемент
				, Буфер
				, СмещениеПриложения
				, ТипМассив
				, ТипСоответствие
				, ТипСтруктура);
				
			Результат.Добавить(ВосстановленноеЗначение);  
			
		КонецЦикла;

		Возврат Результат;

	КонецЕсли;

	Если ТипДанных = ТипСоответствие Тогда

		Результат = Новый Соответствие;

		Для Каждого Пара Из Данные Цикл 
			
			ВосстановленноеЗначение = ВосстановитьЗначениеИзJSONJanx(Пара.Значение
				, Буфер
				, СмещениеПриложения
				, ТипМассив
				, ТипСоответствие
				, ТипСтруктура);

			Результат.Вставить(Пара.Ключ, ВосстановленноеЗначение);
			
		КонецЦикла;

		Возврат Результат;

	КонецЕсли;

	Возврат Данные;

КонецФункции

Функция ПопытатьсяПолучитьМаркерJanx(Знач Данные
	, ЗначениеМаркера
	, Знач ТипСоответствие
	, Знач ТипСтруктура)

	ЗначениеМаркера = Неопределено;
	Ключ            = КлючМаркераБинарныхJanx();
	ТипДанных       = ТипЗнч(Данные);

	Если ТипДанных = ТипСтруктура Тогда

		Если Данные.Свойство(Ключ, ЗначениеМаркера) Тогда
			Возврат Истина;
		КонецЕсли;

	ИначеЕсли ТипДанных = ТипСоответствие Тогда

		Если Данные.Получить(Ключ) <> Неопределено Тогда
			ЗначениеМаркера = Данные[Ключ];
			Возврат Истина;
		КонецЕсли;

	КонецЕсли;

	Возврат Ложь;

КонецФункции

Функция ИзвлечьБинарныеПоМаркеруJanx(Знач Описание
	, Знач Буфер
	, Знач СмещениеПриложения)

	Поля = ПолучитьПоляМаркераJanx(Описание);

	Начало = СмещениеПриложения + Поля.s;
	Длина  = Поля.l;

	Если Длина = 0 Тогда
		Возврат ПолучитьДвоичныеДанныеИзСтроки("");
	КонецЕсли;

	Фрагмент = Буфер.Прочитать(Начало, Длина);

	Возврат ПолучитьДвоичныеДанныеИзБуфераДвоичныхДанных(Фрагмент);

КонецФункции

Функция ПолучитьПоляМаркераJanx(Знач Описание)

	Возврат Новый Структура("s, l", Описание["s"], Описание["l"]);

КонецФункции

#КонецОбласти

#Область БинарныйПрефикс

Функция УпаковатьЦелое32BEJanx(Знач Число)

	Буфер = Новый БуферДвоичныхДанных(РазмерПрефиксаJanx(), ПорядокБайтов.BigEndian);

	Буфер.Установить(0, Цел(Число / 16777216) % 256);
	Буфер.Установить(1, Цел(Число / 65536) % 256);
	Буфер.Установить(2, Цел(Число / 256) % 256);
	Буфер.Установить(3, Число % 256);

	Возврат ПолучитьДвоичныеДанныеИзБуфераДвоичныхДанных(Буфер);

КонецФункции

Функция ПрочитатьЦелое32BEJanx(Знач Буфер, Знач Позиция)

	Байт0 = Буфер.Получить(Позиция);
	Байт1 = Буфер.Получить(Позиция + 1);
	Байт2 = Буфер.Получить(Позиция + 2);
	Байт3 = Буфер.Получить(Позиция + 3);

	Возврат Байт0 * 16777216 + Байт1 * 65536 + Байт2 * 256 + Байт3;

КонецФункции

#КонецОбласти

#КонецОбласти

#КонецЕсли
