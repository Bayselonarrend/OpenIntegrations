#Область ПрограммныйИнтерфейс

// Сериализовать данные в формат Janx-1
//
// Параметры:
//  Данные - Произвольный - Значение для сериализации - value
//
// Возвращаемое значение:
//  ДвоичныеДанные - [u16 BE: версия][u32 BE: длина JSON][u32 BE: число маркеров][JSON][appendix]
Функция СериализоватьДанные(Знач Данные) Экспорт

    МассивДвоичных = Новый Массив;
    Смещение       = 0;
    Подготовленные = ПодготовитьЗначениеДляJSONJanx(Данные, МассивДвоичных, Смещение);
    JSONДД         = ПолучитьДвоичныеДанныеИзСтроки(ЗначениеВJSONJanx(Подготовленные), "UTF-8");
    РазмерJSON     = JSONДД.Размер();

    ПотокДанных = Новый ПотокВПамяти();
    Запись      = Новый ЗаписьДанных(ПотокДанных);

    Запись.ЗаписатьЦелое16(ВерсияФорматаJanx(), ПорядокБайтов.BigEndian);
    Запись.ЗаписатьЦелое32(РазмерJSON, ПорядокБайтов.BigEndian);
    Запись.ЗаписатьЦелое32(МассивДвоичных.Количество(), ПорядокБайтов.BigEndian);
    Запись.Записать(JSONДД);

    Для Каждого Блок Из МассивДвоичных Цикл
        Запись.Записать(Блок);
    КонецЦикла;

    Запись.Закрыть();

    Возврат ПотокДанных.ЗакрытьИПолучитьДвоичныеДанные();

КонецФункции

// Десериализовать данные формата Janx-1
//
// Параметры:
//  Данные - ДвоичныеДанные - Сериализованное значение - data
//
// Возвращаемое значение:
//  Произвольный - Восстановленное значение
Функция ДесериализоватьДанные(Знач Данные) Экспорт

    РазмерВсего = Данные.Размер();

    Если РазмерВсего < РазмерЗаголовкаJanx() Тогда
        ВызватьИсключение "Некорректный формат Janx: слишком короткие данные";
    КонецЕсли;

    Чтение = Новый ЧтениеДанных(Данные);

    Версия = Чтение.ПрочитатьЦелое16(ПорядокБайтов.BigEndian);

    Если Версия <> ВерсияФорматаJanx() Тогда
        ВызватьИсключение СтрШаблон("Некорректный формат Janx: неподдерживаемая версия %1", Версия);
    КонецЕсли;

    РазмерJSON    = Чтение.ПрочитатьЦелое32(ПорядокБайтов.BigEndian);
    ЧислоМаркеров = Чтение.ПрочитатьЦелое32(ПорядокБайтов.BigEndian);

    Если РазмерJSON > РазмерВсего - РазмерЗаголовкаJanx() Тогда
        Чтение.Закрыть();
        ВызватьИсключение "Некорректный формат Janx: длина JSON выходит за границы данных";
    КонецЕсли;

    JSONДанные       = Чтение.Прочитать(РазмерJSON);
    БуферПриложения  = Чтение.Прочитать().ПолучитьБуферДвоичныхДанных();
    Чтение.Закрыть();

    ДеревоJSON = ПрочитатьJSONJanx(JSONДанные);

    Контекст = Новый Структура;
    Контекст.Вставить("БуферПриложения"      , БуферПриложения);
    Контекст.Вставить("МаркеровВсего"        , ЧислоМаркеров);
    Контекст.Вставить("МаркеровВосстановлено", 0);

    Возврат ВосстановитьЗначениеИзJSONJanx(ДеревоJSON, Контекст);

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область КонстантыJanx

Функция КлючМаркераБинарныхJanx()

    Возврат "__JANXB__";

КонецФункции

Функция ВерсияФорматаJanx()

    Возврат 1;

КонецФункции

Функция РазмерПрефиксаJanx()

    Возврат 2;

КонецФункции

Функция РазмерЗаголовкаJanx()

    Возврат РазмерПрефиксаJanx() + 8;

КонецФункции

#КонецОбласти

#Область ПодготовкаJSON

Функция ПодготовитьЗначениеДляJSONJanx(Знач Данные, МассивДвоичных, Смещение)

    Если Данные = Неопределено Тогда
        Возврат Данные;
    КонецЕсли;

    ТипДанных = ТипЗнч(Данные);

    Если ТипДанных = Тип("Структура") Или ТипДанных = Тип("Соответствие") Тогда

        Результат = Новый(ТипДанных);

        Для Каждого Пара Из Данные Цикл
            Результат.Вставить(Пара.Ключ, ПодготовитьЗначениеДляJSONJanx(Пара.Значение, МассивДвоичных, Смещение));
        КонецЦикла;

        Возврат Результат;

    КонецЕсли;

    Если ТипДанных = Тип("Массив") Тогда

        Результат = Новый Массив;

        Для Каждого Элемент Из Данные Цикл
            Результат.Добавить(ПодготовитьЗначениеДляJSONJanx(Элемент, МассивДвоичных, Смещение));
        КонецЦикла;

        Возврат Результат;

    КонецЕсли;

    Если ТипДанных = Тип("ДвоичныеДанные") Тогда
        Возврат СоздатьМаркерБинарныхJanx(Данные, МассивДвоичных, Смещение);
    КонецЕсли;

    Возврат Данные;

КонецФункции

Функция СоздатьМаркерБинарныхJanx(Знач ДвоичныеДанные, МассивДанных, Смещение)

    Длина  = ДвоичныеДанные.Размер();
    Начало = Смещение;

    МассивДанных.Добавить(ДвоичныеДанные);
    Смещение = Смещение + Длина;

    Возврат Новый Структура(КлючМаркераБинарныхJanx(), Новый Структура("s, l", Начало, Длина));

КонецФункции

Функция ЗначениеВJSONJanx(Знач Данные)

    ЗаписьJSON = Новый ЗаписьJSON;
    ЗаписьJSON.УстановитьСтроку(Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Нет, ""));
    ЗаписатьJSON(ЗаписьJSON, Данные);
    Возврат ЗаписьJSON.Закрыть();

КонецФункции

Функция ПрочитатьJSONJanx(Знач JSONДанные)

    ЧтениеJSON = Новый ЧтениеJSON;
    
    ЧтениеJSON.ОткрытьПоток(JSONДанные.ОткрытьПотокДляЧтения(), "UTF-8"); // !OPI
    // !OInt ЧтениеJSON.УстановитьСтроку(ПолучитьСтрокуИзДвоичныхДанных(JSONДанные.ПолучитьДвоичныеДанные(), "UTF-8"));
    
    Возврат ПрочитатьJSON(ЧтениеJSON, Истина);

КонецФункции

#КонецОбласти

#Область ВосстановлениеJSON

Функция ВосстановитьЗначениеИзJSONJanx(Знач Данные, Контекст)

    Если НужноИскатьМаркерJanx(Данные, Контекст) Тогда

        ЗначениеМаркера = Неопределено;

        Если ПопытатьсяПолучитьМаркерJanx(Данные, ЗначениеМаркера) Тогда
            Возврат ИзвлечьБинарныеПоМаркеруJanx(ЗначениеМаркера, Контекст);
        КонецЕсли;

    КонецЕсли;

    ТипДанных = ТипЗнч(Данные);

    Если ТипДанных = Тип("Массив") Тогда

        Результат = Новый Массив;

        Для Каждого Элемент Из Данные Цикл
            Результат.Добавить(ВосстановитьЗначениеИзJSONJanx(Элемент, Контекст));
        КонецЦикла;

        Возврат Результат;

    КонецЕсли;

    Если ТипДанных = Тип("Соответствие") Тогда

        Результат = Новый(ТипДанных);

        Для Каждого Пара Из Данные Цикл
            ВосстановленноеЗначение = ВосстановитьЗначениеИзJSONJanx(Пара.Значение, Контекст);
            Результат.Вставить(Пара.Ключ, ВосстановленноеЗначение);
        КонецЦикла;

        Возврат Результат;

    КонецЕсли;

    Возврат Данные;

КонецФункции

Функция НужноИскатьМаркерJanx(Знач Данные, Контекст)

    Если Контекст.МаркеровВосстановлено = Контекст.МаркеровВсего Тогда
        Возврат Ложь;
    КонецЕсли;

    Возврат ТипЗнч(Данные) = Тип("Соответствие");

КонецФункции

Функция ПопытатьсяПолучитьМаркерJanx(Знач Данные, ЗначениеМаркера)

    ЗначениеМаркера = Данные.Получить(КлючМаркераБинарныхJanx());
    Возврат ЗначениеМаркера <> Неопределено;

КонецФункции

Функция ИзвлечьБинарныеПоМаркеруJanx(Знач Описание, Контекст)

    Начало = Описание["s"];
    Длина  = Описание["l"];

    Если Длина = 0 Тогда
        Результат = ПолучитьДвоичныеДанныеИзСтроки("");
    Иначе
        Фрагмент  = Контекст.БуферПриложения.Прочитать(Начало, Длина);
        Результат = ПолучитьДвоичныеДанныеИзБуфераДвоичныхДанных(Фрагмент);
    КонецЕсли;

    Контекст.МаркеровВосстановлено = Контекст.МаркеровВосстановлено + 1;

    Возврат Результат;

КонецФункции

#КонецОбласти

#КонецОбласти

#КонецЕсли // !OPI
