#Область ПрограммныйИнтерфейс

// Вызвать с настройками
// Вызывает указанный метод с расширенной установкой настроек
//
// Параметры:
//  ИмяМодуля  - Строка                     - Имя модуля ОПИ
//  ИмяФункции - Строка                     - Имя функции в модуле
//  Параметры  - Массив Из Произвольный     - Массив параметров функции
//  Настройки  - Структура Из КлючИЗначение - Набор настроек. См. ПолучитьДоступныеНастройки
//
// Возвращаемое значение:
//  Структура Из КлючИЗначение - Вызвать функцию с настройками
Функция ВызватьСНастройками(Знач ИмяМодуля, Знач ИмяФункции, Знач Параметры = Неопределено,
    Знач Настройки = Неопределено) Экспорт

    НормализованныеНастройки = НормализоватьНастройки(Настройки);

    Если OPI_Инструменты.ПолучитьИли(НормализованныеНастройки, "dontwait", Ложь) Тогда
		
		#Если Клиент Тогда
			
			ВызватьИсключение "Запуск фоновых заданий недоступен на клиенте!";
			
		#Иначе
			
	        UID = Новый УникальныйИдентификатор;
	
	        АдресРезультата = Неопределено;
	        АдресРезультата = ПоместитьВоВременноеХранилище(Неопределено, UID); // !OPI
	
	        ПараметрыЗадания = Новый Массив;
	        ПараметрыЗадания.Добавить(ИмяМодуля);
	        ПараметрыЗадания.Добавить(ИмяФункции);
	        ПараметрыЗадания.Добавить(Параметры);
	        ПараметрыЗадания.Добавить(НормализованныеНастройки);
	        ПараметрыЗадания.Добавить(АдресРезультата);
	
	        // !OInt Результат = ФоновыеЗадания.Выполнить(ЭтотОбъект, "ВызватьСНастройкамиСлужебный", ПараметрыЗадания);
	        Метод          = "OPI_РасширенныйВызов.ВызватьСНастройкамиСлужебный";                       // !OPI
	        ФоновоеЗадание = ФоновыеЗадания.Выполнить(Метод, ПараметрыЗадания);                         // !OPI
	        Результат      = Новый Структура("ФоновоеЗадание,Адрес", ФоновоеЗадание, АдресРезультата);  // !OPI
	        
		#КонецЕсли

    Иначе

        Результат = ВызватьСНастройкамиСлужебный(ИмяМодуля, ИмяФункции, Параметры, НормализованныеНастройки);

    КонецЕсли;

    //@skip-check constructor-function-return-section
    Возврат Результат;

КонецФункции

// Получить доступные настройки
// Получает описание доступных настроек для указанного метода (справочно)
//
// Параметры:
//  ИмяМодуля  - Строка - Имя модуля ОПИ
//  ИмяФункции - Строка - Имя функции в модуле
//
// Возвращаемое значение:
//  Строка - справка по доступным настройкам
Функция ПолучитьДоступныеНастройки(Знач ИмяМодуля, Знач ИмяФункции) Экспорт

    СтруктураМакета   = ПолучитьПолныйИндексНастроек();
    СтруктураНастроек = НайтиВИндексе(СтруктураМакета, ИмяМодуля, ИмяФункции);

    Если СтруктураНастроек = Неопределено Тогда
        Возврат "Для этой функции нет доступных настроек";
    КонецЕсли;

    МассивОписания = Новый Массив;

    Для Каждого Настройка Из СтруктураНастроек Цикл
        МассивОписания.Добавить(СтрШаблон("%1: %2", Настройка.Ключ, Настройка.Значение));
    КонецЦикла;

    Возврат СтрСоединить(МассивОписания, Символы.ПС);

КонецФункции

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Функция ВызватьСНастройкамиСлужебный(Знач ИмяМодуля, Знач ИмяФункции, Знач Параметры, Знач Настройки,
    Знач АдресХранилища = Неопределено) Экспорт

    УстановитьНастройки(Настройки);

    Если ЗначениеЗаполнено(Параметры) Тогда
        OPI_ПреобразованиеТипов.ПолучитьМассив(Параметры);
    Иначе
        Параметры = Новый Массив;
    КонецЕсли;

    ПараметрыСтроки = Новый Массив;

    Для Н = 0 По Параметры.ВГраница() Цикл
        ПараметрыСтроки.Добавить(СтрШаблон("Параметры[%1]", Н));
    КонецЦикла;

    OPI_ПреобразованиеТипов.ПолучитьСтроку(ИмяМодуля);
    OPI_ПреобразованиеТипов.ПолучитьСтроку(ИмяФункции);

    СтрокаВызова = СтрШаблон("Результат = %1.%2(%3);", ИмяМодуля, ИмяФункции, СтрСоединить(ПараметрыСтроки, ", "));

    Результат = Неопределено;

    Попытка
        //@skip-check server-execution-safe-mode
        Выполнить(СтрокаВызова);
    Исключение
        УдалитьНастройки();
        ВызватьИсключение;
    КонецПопытки;

    УдалитьНастройки();

    Если ЗначениеЗаполнено(АдресХранилища) Тогда
        ПоместитьВоВременноеХранилище(Результат, АдресХранилища); // !OPI
    КонецЕсли;

    //@skip-check constructor-function-return-section
    Возврат Результат;

КонецФункции

Функция ПолучитьТекущиеНастройки() Экспорт

    Попытка
        //@skip-check bsl-legacy-check-string-literal
        Возврат OPI_Инструменты.ПолучитьПараметрСеанса("OPI_НастройкиРасширенногоВызова"); // !OPI
        // !OInt Возврат ТекущиеНастройки;
    Исключение
        Возврат Неопределено;
    КонецПопытки;

КонецФункции

Функция ПолучитьПолныйИндексНастроек() Экспорт

    ТекстМакета     = OPI_Инструменты.ПолучитьТекстовыйМакет("OPI_Text_MethodSettings");
    СтруктураМакета = OPI_Инструменты.JsonВСтруктуру(ТекстМакета, Ложь);

    Возврат СтруктураМакета;

КонецФункции

Функция НайтиВИндексе(Знач Индекс, Знач ИмяМодуля, Знач ИмяФункции) Экспорт

    OPI_ПреобразованиеТипов.ПолучитьСтроку(ИмяМодуля);
    OPI_ПреобразованиеТипов.ПолучитьСтроку(ИмяФункции);

    НетНастроек = Ложь;

    Попытка
        СтруктураНастроек = Индекс[ИмяМодуля][ИмяФункции];
    Исключение

        НетНастроек = Истина;

    КонецПопытки;

    Если НетНастроек Или СтруктураНастроек.Количество() = 0 Тогда
        Возврат Неопределено;
    КонецЕсли;

    Возврат СтруктураНастроек;

КонецФункции

Функция УстановитьНастройки(Знач Настройки) Экспорт

    Если ЗначениеЗаполнено(Настройки) Тогда
    	
        ТекущиеНастройки = Настройки;
        
        OPI_Инструменты.УстановитьПараметрСеанса("OPI_НастройкиРасширенногоВызова" // !OPI
        	, Новый ФиксированнаяСтруктура(ТекущиеНастройки));                     // !OPI
        	
    КонецЕсли;

    Возврат ТекущиеНастройки;

КонецФункции

Процедура НормализоватьПромежуточныйРезультат(Результат) Экспорт

    НормализованныйРезультат = Неопределено;

    Если OPI_Инструменты.ПолучитьИли(ПолучитьТекущиеНастройки(), "adv_response", Ложь)
        И OPI_Инструменты.ПолеКоллекцииСуществует(Результат, "body", НормализованныйРезультат) Тогда

        Результат = НормализованныйРезультат;

    КонецЕсли;

КонецПроцедуры

Процедура УдалитьНастройки() Экспорт

    //@skip-check module-unused-local-variable
    ТекущиеНастройки = Новый Структура;

    OPI_Инструменты.УстановитьПараметрСеанса("OPI_НастройкиРасширенногоВызова" // !OPI
    	, Новый ФиксированнаяСтруктура);                                       // !OPI

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция НормализоватьНастройки(Знач Настройки)

    Если ЗначениеЗаполнено(Настройки) Тогда

        ТекстОшибки = "Переданные настройки не являются валидной структурой ключ и значение";
        OPI_ПреобразованиеТипов.ПолучитьКоллекциюКлючИЗначение(Настройки, ТекстОшибки);

        Если Не ТипЗнч(Настройки) = Тип("Структура") Тогда

            НормализованныеНастройки = Новый Структура;

            Для Каждого КлючЗначение Из Настройки Цикл
                НормализованныеНастройки.Вставить(КлючЗначение.Ключ, КлючЗначение.Значение);
            КонецЦикла;

        Иначе
            НормализованныеНастройки = OPI_Инструменты.КопироватьКоллекцию(Настройки);
        КонецЕсли;

    Иначе
        НормализованныеНастройки = Новый Структура;
    КонецЕсли;

    Возврат НормализованныеНастройки;

КонецФункции

#КонецОбласти

#КонецЕсли // !OPI
