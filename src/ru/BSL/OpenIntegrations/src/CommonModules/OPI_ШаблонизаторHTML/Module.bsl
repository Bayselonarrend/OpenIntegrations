#Если Не ВебКлиент Тогда // !OPI

#Область СлужебныйПрограммныйИнтерфейс

Функция Рендер(Знач Шаблон, Знач Контекст, Знач ЧастичныеМакеты = Неопределено) Экспорт

    СтекКонтекста = Новый Массив;
    СтекКонтекста.Добавить(Контекст);

    Возврат ОбработатьФрагмент(Шаблон, СтекКонтекста, ЧастичныеМакеты);

КонецФункции

Функция РендерМакета(Знач ИмяМакета, Знач Контекст, Знач ЧастичныеМакеты = Неопределено) Экспорт

    Шаблон = OPI_Инструменты.ПолучитьТекстовыйМакет(ИмяМакета);

    Возврат Рендер(Шаблон, Контекст, ЧастичныеМакеты);

КонецФункции

Функция ЭкранироватьHTML(Знач Текст) Экспорт

    Если Текст = Неопределено Или Текст = Null Тогда
        Возврат "";
    КонецЕсли;

    Результат = Строка(Текст);
    Результат = СтрЗаменить(Результат, "&" , "&amp;");
    Результат = СтрЗаменить(Результат, "<" , "&lt;");
    Результат = СтрЗаменить(Результат, ">" , "&gt;");
    Результат = СтрЗаменить(Результат, """", "&quot;");

    Возврат Результат;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ОбработатьФрагмент(Знач Шаблон, СтекКонтекста, ЧастичныеМакеты)

    Результат = "";
    Позиция   = 1;
    Длина     = СтрДлина(Шаблон);

    Пока Позиция <= Длина Цикл

        НачалоТега = СтрНайти(Шаблон, "{{", , Позиция);

        Если НачалоТега = 0 Тогда
            Результат = Результат + Сред(Шаблон, Позиция);
            Прервать;
        КонецЕсли;

        Результат = Результат + Сред(Шаблон, Позиция, НачалоТега - Позиция);

        Тег = РазобратьТег(Шаблон, НачалоТега);

        Если Тег.Тип = "var" Тогда

            Результат = Результат + ФорматироватьЗначение(ПолучитьЗначениеКонтекста(СтекКонтекста, Тег.Имя), Ложь);
            Позиция   = Тег.Конец + 1;

        ИначеЕсли Тег.Тип = "raw" Тогда

            Результат = Результат + ФорматироватьЗначение(ПолучитьЗначениеКонтекста(СтекКонтекста, Тег.Имя), Истина);
            Позиция   = Тег.Конец + 1;

        ИначеЕсли Тег.Тип = "section" Или Тег.Тип = "inverted" Тогда

            Закрытие     = НайтиЗакрытиеСекции(Шаблон, Тег.Конец + 1, Тег.Имя);
            Внутренность = Сред(Шаблон, Тег.Конец + 1, Закрытие.Начало - Тег.Конец - 1);
            
            Результат = Результат 
            	+ ОбработатьСекцию(Тег.Имя, Тег.Тип = "inverted", Внутренность, СтекКонтекста, ЧастичныеМакеты);
            
            Позиция = Закрытие.Конец + 1;

        ИначеЕсли Тег.Тип = "partial" Тогда

            ТекстМакета = ПолучитьТекстЧастичногоМакета(Тег.Имя, ЧастичныеМакеты);
            Результат   = Результат + ОбработатьФрагмент(ТекстМакета, СтекКонтекста, ЧастичныеМакеты);
            Позиция     = Тег.Конец + 1;

        Иначе
            Позиция = Тег.Конец + 1;
        КонецЕсли;

    КонецЦикла;

    Возврат Результат;

КонецФункции

Функция РазобратьТег(Знач Шаблон, Знач Начало)

    Тег = Новый Структура;
    Тег.Вставить("Тип"   , "");
    Тег.Вставить("Имя"   , "");
    Тег.Вставить("Начало", Начало);
    Тег.Вставить("Конец" , 0);

    Если Сред(Шаблон, Начало, 3) = "{{{" Тогда

        КонецТега = СтрНайти(Шаблон, "}}}", , Начало + 3);

        Если КонецТега = 0 Тогда
            ВызватьИсключение "Не найдено закрытие raw-тега }}}";
        КонецЕсли;

        Тег.Тип   = "raw";
        Тег.Имя   = СокрЛП(Сред(Шаблон, Начало + 3, КонецТега - Начало - 3));
        Тег.Конец = КонецТега + 2;

        Возврат Тег;

    КонецЕсли;

    КонецТега = СтрНайти(Шаблон, "}}", , Начало + 2);

    Если КонецТега = 0 Тогда
        ВызватьИсключение "Не найдено закрытие тега }}";
    КонецЕсли;

    Содержимое = СокрЛП(Сред(Шаблон, Начало + 2, КонецТега - Начало - 2));
    Тег.Конец  = КонецТега + 1;

    Если СтрНачинаетсяС(Содержимое, "#") Тогда
        Тег.Тип = "section";
        Тег.Имя = СокрЛП(Сред(Содержимое, 2));
    ИначеЕсли СтрНачинаетсяС(Содержимое, "^") Тогда
        Тег.Тип = "inverted";
        Тег.Имя = СокрЛП(Сред(Содержимое, 2));
    ИначеЕсли СтрНачинаетсяС(Содержимое, ">") Тогда
        Тег.Тип = "partial";
        Тег.Имя = СокрЛП(Сред(Содержимое, 2));
    Иначе
        Тег.Тип = "var";
        Тег.Имя = Содержимое;
    КонецЕсли;

    Возврат Тег;

КонецФункции

Функция НайтиЗакрытиеСекции(Знач Шаблон, Знач Начало, Знач ИмяСекции)

    Результат = Новый Структура("Начало, Конец", 0, 0);
    Глубина   = 1;
    Позиция   = Начало;
    Длина     = СтрДлина(Шаблон);
    Открытие  = "{{#" + ИмяСекции + "}}";
    Инверсия  = "{{^" + ИмяСекции + "}}";
    Закрытие  = "{{/" + ИмяСекции + "}}";

    Пока Глубина > 0 И Позиция <= Длина Цикл

        ПозицияОткрытия = СтрНайти(Шаблон, Открытие, , Позиция);
        ПозицияИнверсии = СтрНайти(Шаблон, Инверсия, , Позиция);
        ПозицияЗакрытия = СтрНайти(Шаблон, Закрытие, , Позиция);

        Если ПозицияЗакрытия = 0
            И (ПозицияОткрытия = 0 И ПозицияИнверсии = 0) Тогда
            ВызватьИсключение СтрШаблон("Не найдено закрытие секции {{/%1}}", ИмяСекции);
        КонецЕсли;

        Минимум = Длина + 1;

        Если ПозицияЗакрытия > 0 Тогда
            Минимум = ПозицияЗакрытия;
        КонецЕсли;

        Если ПозицияОткрытия > 0 И ПозицияОткрытия < Минимум Тогда
            Минимум = ПозицияОткрытия;
            ТипТега = "open";
        ИначеЕсли ПозицияИнверсии > 0 И ПозицияИнверсии < Минимум Тогда
            Минимум = ПозицияИнверсии;
            ТипТега = "open";
        Иначе
            ТипТега = "close";
        КонецЕсли;

        Если ТипТега = "close" Тогда
            Глубина = Глубина - 1;

            Если Глубина = 0 Тогда
                Результат.Начало = ПозицияЗакрытия;
                Результат.Конец  = ПозицияЗакрытия + СтрДлина(Закрытие) - 1;
                Прервать;
            КонецЕсли;

            Позиция = ПозицияЗакрытия + СтрДлина(Закрытие);
        Иначе
            Глубина = Глубина + 1;
            Позиция = Минимум + СтрДлина(Открытие);
        КонецЕсли;

    КонецЦикла;

    Возврат Результат;

КонецФункции

Функция ОбработатьСекцию(Знач Имя, Знач Инверсия, Знач Внутренность, СтекКонтекста, ЧастичныеМакеты)

    Значение = ПолучитьЗначениеКонтекста(СтекКонтекста, Имя);
    Истинно  = ЗначениеИстинно(Значение);

    Если Инверсия Тогда
        Если Истинно Тогда
            Возврат "";
        КонецЕсли;
    Иначе
        Если Не Истинно Тогда
            Возврат "";
        КонецЕсли;
    КонецЕсли;

    Если ТипЗнч(Значение) = Тип("Массив") Тогда

        Результат = "";

        Для Каждого Элемент Из Значение Цикл
            СтекКонтекста.Добавить(Элемент);
            Результат = Результат + ОбработатьФрагмент(Внутренность, СтекКонтекста, ЧастичныеМакеты);
            СтекКонтекста.Удалить(СтекКонтекста.ВГраница());
        КонецЦикла;

        Возврат Результат;

    КонецЕсли;

    Если ТипЗнч(Значение) = Тип("Структура")
        Или ТипЗнч(Значение) = Тип("Соответствие") Тогда

        СтекКонтекста.Добавить(Значение);

        Попытка
            Возврат ОбработатьФрагмент(Внутренность, СтекКонтекста, ЧастичныеМакеты);
        Исключение
            СтекКонтекста.Удалить(СтекКонтекста.ВГраница());
            ВызватьИсключение;
        КонецПопытки;

        СтекКонтекста.Удалить(СтекКонтекста.ВГраница());

    КонецЕсли;

    Возврат ОбработатьФрагмент(Внутренность, СтекКонтекста, ЧастичныеМакеты);

КонецФункции

Функция ПолучитьЗначениеКонтекста(СтекКонтекста, Знач Имя)

    ВерхняяГраница = СтекКонтекста.ВГраница();

    Для Индекс = 0 По ВерхняяГраница Цикл

        Значение = ПолучитьЗначениеИзКоллекции(СтекКонтекста[ВерхняяГраница - Индекс], Имя);

        Если Значение <> Неопределено Тогда
            Возврат Значение;
        КонецЕсли;

    КонецЦикла;

    Возврат Неопределено;

КонецФункции

Функция ПолучитьЗначениеИзКоллекции(Знач Коллекция, Знач Имя)

    Если Коллекция = Неопределено Тогда
        Возврат Неопределено;
    КонецЕсли;

    ТипКоллекции = ТипЗнч(Коллекция);

    Если ТипКоллекции = Тип("Структура") Тогда
        Если Коллекция.Свойство(Имя) Тогда
            Возврат Коллекция[Имя];
        КонецЕсли;
    ИначеЕсли ТипКоллекции = Тип("Соответствие") Тогда
        Значение = Коллекция.Получить(Имя);
        Если Значение <> Неопределено Тогда
            Возврат Значение;
        КонецЕсли;
    КонецЕсли;

    Возврат Неопределено;

КонецФункции

Функция ЗначениеИстинно(Знач Значение)

    Если Значение = Неопределено Или Значение = Null Тогда
        Возврат Ложь;
    КонецЕсли;

    Если ТипЗнч(Значение) = Тип("Булево") Тогда
        Возврат Значение;
    КонецЕсли;

    Если ТипЗнч(Значение) = Тип("Строка") Тогда
        Возврат Значение <> "";
    КонецЕсли;

    Если ТипЗнч(Значение) = Тип("Массив") Тогда
        Возврат Значение.Количество() > 0;
    КонецЕсли;

    Если ТипЗнч(Значение) = Тип("Структура")
        Или ТипЗнч(Значение) = Тип("Соответствие") Тогда
        Возврат Истина;
    КонецЕсли;

    Возврат Истина;

КонецФункции

Функция ФорматироватьЗначение(Знач Значение, Знач Сырой)

    Если Значение = Неопределено Или Значение = Null Тогда
        Возврат "";
    КонецЕсли;

    Если Сырой Тогда
        Возврат Строка(Значение);
    КонецЕсли;

    Возврат ЭкранироватьHTML(Значение);

КонецФункции

Функция ПолучитьТекстЧастичногоМакета(Знач Имя, ЧастичныеМакеты)

    Если ЧастичныеМакеты <> Неопределено Тогда
        ТекстМакета = ЧастичныеМакеты.Получить(Имя);
        Если ТекстМакета <> Неопределено Тогда
            Возврат ТекстМакета;
        КонецЕсли;
    КонецЕсли;

    Возврат OPI_Инструменты.ПолучитьТекстовыйМакет(Имя);

КонецФункции

#КонецОбласти

#КонецЕсли
