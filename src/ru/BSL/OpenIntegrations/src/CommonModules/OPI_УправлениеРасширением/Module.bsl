#Область СлужебныйПрограммныйИнтерфейс

Процедура ПодключитьВсеКомпоненты() Экспорт

    СписокМакетовКомпонент = OPI_ИнструментыВызовСервера.ПолучитьСписокКомпонент();

    Для Каждого МакетКомпоненты Из СписокМакетовКомпонент Цикл
        ПодключитьКомпоненту(МакетКомпоненты);
    КонецЦикла;

    OPI_Инструменты.Пауза(1);

КонецПроцедуры

Процедура ПодключитьКомпоненту(Знач ИмяКомпоненты) Экспорт

    Местоположение = СтрШаблон("ОбщийМакет.%1", ИмяКомпоненты);

    Попытка

        ТипКомпоненты = СтрШаблон("AddIn.%1.Main", ИмяКомпоненты);

        //@skip-check module-unused-local-variable
        Компонента    = Новый (ТипКомпоненты);

        #Если Клиент Тогда
            УведомитьОПодключенииКомпоненты(ИмяКомпоненты, Компонента);
        #КонецЕсли

    Исключение
        #Если Клиент Тогда

            ООп = Новый ОписаниеОповещения("ПослеПодключенияКомпоненты", ЭтотОбъект, ИмяКомпоненты);

            НачатьПодключениеВнешнейКомпоненты(ООп
                , Местоположение
                , ИмяКомпоненты
                , ТипВнешнейКомпоненты.Native);

        #Иначе
            ПодключитьВнешнююКомпоненту(Местоположение, ИмяКомпоненты, ТипВнешнейКомпоненты.Native);
        #КонецЕсли
    КонецПопытки;

КонецПроцедуры

Процедура ОбновитьКомпонентыНаКлиенте(Знач ИменаКомпонент) Экспорт

    #Если Клиент Тогда
        Для Каждого ИмяКомпоненты Из ИменаКомпонент Цикл

            ООп = Новый ОписаниеОповещения("ПодключитьКомпоненту", ЭтотОбъект, ИмяКомпоненты);
            НачатьУстановкуВнешнейКомпоненты(ООп, СтрШаблон("ОбщийМакет.%1", ИмяКомпоненты));

        КонецЦикла;
    #КонецЕсли

КонецПроцедуры

Функция ПолучитьСписокВерсийКомпонент() Экспорт

    СписокМакетовКомпонент = OPI_ИнструментыВызовСервера.ПолучитьСписокКомпонент();
    МассивДанныхКомпонент  = Новый Массив;

    Для Каждого МакетКомпоненты Из СписокМакетовКомпонент Цикл

        ВерсияКонфигурации = OPI_ИнструментыВызовСервера.ПолучитьВерсиюКомпоненты(МакетКомпоненты);
        ВерсияКлиента      = Неопределено;

        #Если Клиент Тогда

            Компонента = Неопределено;

            Попытка
                ТипКомпоненты = СтрШаблон("AddIn.%1.Main", МакетКомпоненты);
                Компонента    = Новый (ТипКомпоненты);
            Исключение
                ВерсияКлиента = Неопределено;
            КонецПопытки;

            Если Компонента <> Неопределено Тогда

                Попытка
                    ВерсияКлиента = Компонента.Version();
                Исключение
                    ВерсияКлиента = ОписаниеОшибки();
                КонецПопытки;

            КонецЕсли;

        #КонецЕсли

        СтруктураКомпоненты = Новый Структура;
        СтруктураКомпоненты.Вставить("ИмяКомпоненты"     , МакетКомпоненты);
        СтруктураКомпоненты.Вставить("ВерсияКонфигурации", ВерсияКонфигурации);
        СтруктураКомпоненты.Вставить("ВерсияКлиента"     , ВерсияКлиента);

        МассивДанныхКомпонент.Добавить(СтруктураКомпоненты);

    КонецЦикла;

    Возврат МассивДанныхКомпонент;

КонецФункции

Функция ПолучитьПутьКэшаКомпонент() Экспорт

    // BSLLS:UsingHardcodePath-off

    Возврат ?(OPI_Инструменты.ЭтоWindows()
        , "%APPDATA%\1C\1Cv8\ExtCompT"
        , "~/.1cv8/1C/1Cv8/ExtCompT/");

    // BSLLS:UsingHardcodePath-on

КонецФункции

#Если Клиент Тогда // !OPI

Процедура ПослеПодключенияКомпоненты(Знач Подключена, Знач ИмяКомпоненты) Экспорт

    Компонента = Неопределено;

    Если Подключена Тогда

        ТипКомпоненты = СтрШаблон("AddIn.%1.Main", ИмяКомпоненты);
        Компонента    = Новый (ТипКомпоненты);

    КонецЕсли;

    УведомитьОПодключенииКомпоненты(ИмяКомпоненты, Компонента);

КонецПроцедуры

Процедура УведомитьОПодключенииКомпоненты(Знач ИмяКомпоненты, Знач Компонента = Неопределено)

    Если Компонента <> Неопределено Тогда

        Попытка
            ВерсияКлиента = Компонента.Version();
        Исключение
            ВерсияКлиента = ОписаниеОшибки();
        КонецПопытки;

    Иначе
        ВерсияКлиента = Неопределено;
    КонецЕсли;

    ВерсияКонфигурации = OPI_ИнструментыВызовСервера.ПолучитьВерсиюКомпоненты(ИмяКомпоненты);

    СтруктураОповещения = Новый Структура();
    СтруктураОповещения.Вставить("ИмяКомпоненты"     , ИмяКомпоненты);
    СтруктураОповещения.Вставить("ВерсияКлиента"     , ВерсияКлиента);
    СтруктураОповещения.Вставить("ВерсияКонфигурации", ВерсияКонфигурации);

    Оповестить("OPI_ЗавершениеУстановки", СтруктураОповещения);

КонецПроцедуры

#КонецЕсли // !OPI

#Область Релизы

Функция ПолучитьИмяРасширения() Экспорт

    Возврат "OpenIntegrations";

КонецФункции

Функция ПолучитьЯзыкАртефакта() Экспорт

    Возврат OPI_Инструменты.ЯзыкОПИ();

КонецФункции

Функция ПолучитьИмяФайлаАртефакта(АрхивРелизов, Знач НомерВерсии, Знач IDАртефакта, Знач IDЗеркала, Знач Язык = "") Экспорт

    Если Не ЗначениеЗаполнено(Язык) Тогда
        Язык = ПолучитьЯзыкАртефакта();
    КонецЕсли;

    Попытка
        Артефакт = ПолучитьАртефактРелиза(АрхивРелизов, НомерВерсии, IDАртефакта, Язык);
    Исключение
        ВызватьИсключение "Ошибка получение артефакта релиза. Повторите попытку позже!"
    КонецПопытки;

    Если Артефакт = Неопределено Тогда
        Возврат "";
    КонецЕсли;

    Возврат Артефакт["filename"];

КонецФункции

Функция СкачатьАртефактРелиза(АрхивРелизов
    , Знач НомерВерсии
    , Знач IDАртефакта
    , Знач IDЗеркала
    , Знач ПутьСохранения
    , Знач Язык = "") Экспорт

    // !IRPSkip
    URLСкачивания = ПолучитьURLСкачиванияАртефакта(АрхивРелизов, НомерВерсии, IDАртефакта, IDЗеркала, Язык);

    СкачатьФайлПоURL(URLСкачивания, ПутьСохранения);

    Возврат "Файл успешно загружен";

КонецФункции

Функция ПолучитьURLСкачиванияАртефакта(АрхивРелизов
    , Знач НомерВерсии
    , Знач IDАртефакта
    , Знач IDЗеркала
    , Знач Язык = "") Экспорт

    Если Не ЗначениеЗаполнено(Язык) Тогда
        Язык = ПолучитьЯзыкАртефакта();
    КонецЕсли;

    Артефакт = ПолучитьАртефактРелиза(АрхивРелизов, НомерВерсии, IDАртефакта, Язык);

    Если Артефакт = Неопределено Тогда
        ВызватьИсключение СтрШаблон("Не найден артефакт %1 (%2) для версии %3", IDАртефакта, Язык, НомерВерсии);
    КонецЕсли;

    Если IDЗеркала = "s3" Тогда

        URL = Артефакт["s3Url"];

        Если Не ЗначениеЗаполнено(URL) Тогда
            URL = СтрШаблон("%1/versions/%2/%3", АрхивРелизов["s3BaseUrl"], НомерВерсии, Артефакт["filename"]);
        КонецЕсли;

        Возврат URL;

    ИначеЕсли IDЗеркала = "yandex" Тогда

        Возврат ПолучитьURLСкачиванияЯндексДиска(АрхивРелизов, НомерВерсии, Артефакт["filename"]);

    Иначе

        URL = Артефакт["githubUrl"];

        Если Не ЗначениеЗаполнено(URL) Тогда
            URL = СтрШаблон("%1/%2/%3", АрхивРелизов["githubDownloadBase"], НомерВерсии, Артефакт["filename"]);
        КонецЕсли;

        Возврат URL;

    КонецЕсли;

КонецФункции

#КонецОбласти

#Область УстановкаCfe

#Если Сервер Тогда // !OPI

Функция УстановитьРасширениеИзАрхива(АрхивРелизов, Знач НомерВерсии, Знач IDЗеркала, Знач Язык = "") Экспорт

    // !IRPSkip
    URLСкачивания = ПолучитьURLСкачиванияАртефакта(АрхивРелизов, НомерВерсии, "cfe", IDЗеркала, Язык);
    Двоичные      = ПолучитьДвоичныеДанныеПоURL(URLСкачивания);

    Возврат ПрименитьДвоичныеДанныеРасширения(Двоичные);

КонецФункции

#КонецЕсли

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПолучитьАртефактРелиза(АрхивРелизов, Знач НомерВерсии, Знач IDАртефакта, Знач Язык)

    Релиз = НайтиДанныеРелизаВАрхиве(АрхивРелизов, НомерВерсии);

    Если Релиз = Неопределено Тогда
        Возврат Неопределено;
    КонецЕсли;

    Артефакты = Релиз["artifacts"];

    Если ТипЗнч(Артефакты) <> Тип("Массив") Тогда
        Возврат Неопределено;
    КонецЕсли;

    Для Каждого Артефакт Из Артефакты Цикл

        Если Артефакт["id"] = IDАртефакта И Артефакт["lang"] = Язык Тогда
            Возврат Артефакт;
        КонецЕсли;

    КонецЦикла;

    Возврат Неопределено;

КонецФункции

Функция НайтиДанныеРелизаВАрхиве(АрхивРелизов, Знач НомерВерсии)

    Версии = АрхивРелизов["versions"];

    Если ТипЗнч(Версии) <> Тип("Массив") Тогда
        Возврат Неопределено;
    КонецЕсли;

    Для Каждого Релиз Из Версии Цикл

        Если Релиз["version"] = НомерВерсии Тогда
            Возврат Релиз;
        КонецЕсли;

    КонецЦикла;

    Возврат Неопределено;

КонецФункции

Функция ПолучитьURLСкачиванияЯндексДиска(АрхивРелизов, Знач НомерВерсии, Знач ИмяФайла)

    ПубличныйКлюч = АрхивРелизов["yandexDiskPublicKey"];

    Если Не ЗначениеЗаполнено(ПубличныйКлюч) Тогда
        ВызватьИсключение "В архиве релизов не указан публичный ключ Yandex.Disk";
    КонецЕсли;

    Параметры = Новый Структура;
    Параметры.Вставить("public_key", ПубличныйКлюч);
    Параметры.Вставить("path"      , СтрШаблон("/%1/%2", НомерВерсии, ИмяФайла));

    Ответ = OPI_ЗапросыHTTP.НовыйЗапрос()
        .Инициализировать("https://cloud-api.yandex.net/v1/disk/public/resources/download")
        .УстановитьПараметрыURL(Параметры)
        .УстановитьТаймаут(60)
        .ОбработатьЗапрос("GET")
        .ВернутьОтветКакJSONКоллекцию(Истина, Истина);

    Ответ = OPI_РасширенныйВызов.НормализоватьПромежуточныйРезультат(Ответ);

    URL = Ответ["href"];

    Если Не ЗначениеЗаполнено(URL) Тогда

        ДанныеОтвета = Ответ;

        Если ТипЗнч(Ответ) = Тип("Структура") Или ТипЗнч(Ответ) = Тип("Соответствие") Тогда

            Если Ответ["result"] = Истина Тогда
                ДанныеОтвета = Ответ["data"];
            КонецЕсли;

        КонецЕсли;

        Если ТипЗнч(ДанныеОтвета) = Тип("Структура") Или ТипЗнч(ДанныеОтвета) = Тип("Соответствие") Тогда
            URL = ДанныеОтвета["href"];
        КонецЕсли;

    КонецЕсли;

    Если Не ЗначениеЗаполнено(URL) Тогда
        ВызватьИсключение "Не удалось получить ссылку скачивания с Yandex.Disk";
    КонецЕсли;

    Возврат URL;

КонецФункции

Процедура СкачатьФайлПоURL(Знач URL, Знач ПутьСохранения)

    OPI_ПреобразованиеТипов.ПолучитьСтроку(URL);
    OPI_ПреобразованиеТипов.ПолучитьСтроку(ПутьСохранения);

    OPI_ЗапросыHTTP.НовыйЗапрос()
        .Инициализировать(URL)
        .УстановитьТаймаут(300)
        .УстановитьФайлОтвета(ПутьСохранения)
        .ОбработатьЗапрос("GET")
        .ВернутьОтвет(, Истина);

КонецПроцедуры

Функция ПолучитьДвоичныеДанныеПоURL(Знач URL)

    OPI_ПреобразованиеТипов.ПолучитьСтроку(URL);

    Возврат OPI_ЗапросыHTTP.НовыйЗапрос()
        .Инициализировать(URL)
        .УстановитьТаймаут(300)
        .ОбработатьЗапрос("GET")
        .ВернутьОтветКакДвоичныеДанные(, Истина);

КонецФункции

#Если Сервер Тогда // !OPI

Функция ПрименитьДвоичныеДанныеРасширения(Знач Двоичные)

    Результат = Новый Структура;
    Результат.Вставить("Успех"              , Ложь);
    Результат.Вставить("Сообщение"          , "");
    Результат.Вставить("ТребуетсяПерезапуск", Ложь);

    РасширениеОПИ = НайтиРасширениеОПИ();
    ЭтоНовое      = РасширениеОПИ = Неопределено;

    Если ЭтоНовое Тогда
        РасширениеОПИ = РасширенияКонфигурации.Создать();
    КонецЕсли;

    ПроверитьПрименениеРасширения(Двоичные, РасширениеОПИ);

    РасширениеОПИ.БезопасныйРежим = Ложь;
    РасширениеОПИ.Записать(Двоичные);

    Результат.Успех               = Истина;
    Результат.ТребуетсяПерезапуск = Не ПроверитьДоступностьМетаданныхРасширения();
    Результат.Сообщение           = ?(Результат.ТребуетсяПерезапуск
        , "Расширение установлено. Для применения изменений требуется перезапуск сеанса."
        , "Расширение успешно установлено");

    Возврат Результат;

КонецФункции

Функция НайтиРасширениеОПИ()

    Найденные = РасширенияКонфигурации.Получить(Новый Структура("Имя", ПолучитьИмяРасширения()));

    Если Найденные.Количество() = 0 Тогда
        Возврат Неопределено;
    КонецЕсли;

    Возврат Найденные[0];

КонецФункции

Процедура ПроверитьПрименениеРасширения(Знач Данные, Знач Расширение)

    ПроблемыУстановки = Расширение.ПроверитьВозможностьПрименения(Данные);

    Для Каждого Проблема Из ПроблемыУстановки Цикл

        Описание = Проблема["Описание"];

        Если Проблема.Важность = ВажностьПроблемыПримененияРасширенияКонфигурации.Критичная Тогда
            ВызватьИсключение Описание;
        КонецЕсли;

    КонецЦикла;

КонецПроцедуры

Функция ПроверитьДоступностьМетаданныхРасширения()

    Попытка
        OPI_Инструменты.ПолучитьТекстовыйМакет("OPI_Text_LicenseRU");
        Возврат Истина;
    Исключение
        Возврат Ложь;
    КонецПопытки;

КонецФункции

