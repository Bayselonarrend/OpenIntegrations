Процедура Tar_Архивация() Экспорт

    КаталогБазы = КаталогВременныхФайлов()
        + ПолучитьРазделительПути()
        + "opi_tar_"
        + Формат(ТекущаяУниверсальнаяДатаВМиллисекундах(), "ЧГ=0");

    КаталогИсточник        = ПутьTar(КаталогБазы, "src");
    КаталогНазначение      = ПутьTar(КаталогБазы, "out");
    КаталогНазначениеБуфер = ПутьTar(КаталогБазы, "out_buffer");
    ПутьАрхива             = ПутьTar(КаталогБазы, "archive.tar");
    ПутьАрхиваОписание     = ПутьTar(КаталогБазы, "archive_desc.tar");
    ПутьАрхиваGzip         = ПутьTar(КаталогБазы, "archive.tar.gz");
    ПутьАрхиваБуфер        = ПутьTar(КаталогБазы, "archive_buffer.tar");
    ПутьНовогоФайла        = ПутьTar(КаталогБазы, "extra_info.txt");

    СоздатьКаталог(КаталогБазы);
    СоздатьКаталог(КаталогИсточник);
    СоздатьКаталог(КаталогНазначение);
    СоздатьКаталог(КаталогНазначениеБуфер);

    ПолучитьДвоичныеДанныеИзСтроки("OpenIntegrations root", "UTF-8").Записать(ПутьTar(КаталогИсточник, "readme.txt"));

    СоздатьКаталог(ПутьTar(КаталогИсточник, "docs"));
    ПолучитьДвоичныеДанныеИзСтроки("Nested documentation", "UTF-8").Записать(ПутьTar(КаталогИсточник, "docs\note.txt"));

    СоздатьКаталог(ПутьTar(КаталогИсточник, "config"));
    ПолучитьДвоичныеДанныеИзСтроки("{""enabled"": true}", "UTF-8").Записать(ПутьTar(КаталогИсточник, "config\settings.json"));

    ПолучитьДвоичныеДанныеИзСтроки("Added via path", "UTF-8").Записать(ПутьНовогоФайла);

    ОжидаемыеФайлы = Новый Соответствие;
    ОжидаемыеФайлы.Вставить("readme.txt"             , "OpenIntegrations root");
    ОжидаемыеФайлы.Вставить("docs\note.txt"          , "Nested documentation");
    ОжидаемыеФайлы.Вставить("config\settings.json"   , "{""enabled"": true}");

    ОжидаемыеЧастичные = Новый Соответствие;
    ОжидаемыеЧастичные.Вставить("readme.txt"   , "OpenIntegrations root");
    ОжидаемыеЧастичные.Вставить("docs\note.txt", "Nested documentation");

    ПутиЧастичные = Новый Массив;
    ПутиЧастичные.Добавить("readme.txt");
    ПутиЧастичные.Добавить("docs/note.txt");

    ОжидаемыеПослеИзменения = Новый Соответствие;
    ОжидаемыеПослеИзменения.Вставить("readme.txt"    , "Replaced readme content");
    ОжидаемыеПослеИзменения.Вставить("docs\note.txt" , "Nested documentation");
    ОжидаемыеПослеИзменения.Вставить("extra\info.txt", "Added via path");

    ЗаписиОписания = Новый Массив;

    ЭлементReadme = Новый Соответствие;
    ЭлементReadme.Вставить("name"     , "readme.txt");
    ЭлементReadme.Вставить("directory", Ложь);
    ЭлементReadme.Вставить("from_path", Истина);
    ЭлементReadme.Вставить("path"     , ПутьTar(КаталогИсточник, "readme.txt"));
    ЗаписиОписания.Добавить(ЭлементReadme);

    ЗаписиDocs  = Новый Массив;
    ЭлементNote = Новый Соответствие;
    ЭлементNote.Вставить("name"     , "note.txt");
    ЭлементNote.Вставить("directory", Ложь);
    ЭлементNote.Вставить("from_path", Истина);
    ЭлементNote.Вставить("path"     , ПутьTar(КаталогИсточник, "docs\note.txt"));
    ЗаписиDocs.Добавить(ЭлементNote);

    ЭлементDocs = Новый Соответствие;
    ЭлементDocs.Вставить("name"     , "docs");
    ЭлементDocs.Вставить("directory", Истина);
    ЭлементDocs.Вставить("entries"  , ЗаписиDocs);
    ЗаписиОписания.Добавить(ЭлементDocs);

    ОписаниеАрхива = Новый Соответствие;
    ОписаниеАрхива.Вставить("entries", ЗаписиОписания);

    Параметры = Новый Структура;
    Параметры.Вставить("Tar_BaseDir"              , КаталогБазы);
    Параметры.Вставить("Tar_SourceDir"            , КаталогИсточник);
    Параметры.Вставить("Tar_ArchivePath"          , ПутьАрхива);
    Параметры.Вставить("Tar_ArchiveDescPath"      , ПутьАрхиваОписание);
    Параметры.Вставить("Tar_ArchiveGzipPath"      , ПутьАрхиваGzip);
    Параметры.Вставить("Tar_ArchiveBufferPath"    , ПутьАрхиваБуфер);
    Параметры.Вставить("Tar_DestDir"              , КаталогНазначение);
    Параметры.Вставить("Tar_DestBufferDir"        , КаталогНазначениеБуфер);
    Параметры.Вставить("Tar_NewFilePath"          , ПутьНовогоФайла);
    Параметры.Вставить("Tar_Description"          , ОписаниеАрхива);
    Параметры.Вставить("Tar_ExpectedFiles"        , ОжидаемыеФайлы);
    Параметры.Вставить("Tar_PartialPaths"         , ПутиЧастичные);
    Параметры.Вставить("Tar_PartialExpected"      , ОжидаемыеЧастичные);
    Параметры.Вставить("Tar_ExpectedAfterModify"  , ОжидаемыеПослеИзменения);

    OPI_ПолучениеДанныхТестов.ЗаписатьПараметрыАрхива(Параметры);

    Tar_ПолучитьСтруктуруНастроекАрхивации();
    Tar_АрхивироватьКаталог(Параметры);
    Tar_РазархивироватьКаталог(Параметры);
    Tar_РазархивироватьФайлы(Параметры);
    Tar_ИзменитьАрхив(Параметры);

    OPI_Инструменты.УдалитьФайлВПопытке(КаталогБазы, "Не удалось удалить каталог теста tar");

КонецПроцедуры

Процедура Tar_ПолучениеМетаданных() Экспорт

    КаталогБазы = КаталогВременныхФайлов()
        + ПолучитьРазделительПути()
        + "opi_tar_meta_"
        + Формат(ТекущаяУниверсальнаяДатаВМиллисекундах(), "ЧГ=0");

    КаталогИсточник = ПутьTar(КаталогБазы, "src");
    ПутьАрхива      = ПутьTar(КаталогБазы, "archive.tar");

    СоздатьКаталог(КаталогБазы);
    СоздатьКаталог(КаталогИсточник);

    ПолучитьДвоичныеДанныеИзСтроки("tar metadata test", "UTF-8").Записать(ПутьTar(КаталогИсточник, "readme.txt"));

    СоздатьКаталог(ПутьTar(КаталогИсточник, "docs"));
    ПолучитьДвоичныеДанныеИзСтроки("Nested file", "UTF-8").Записать(ПутьTar(КаталогИсточник, "docs\note.txt"));

    OPI_Tar.АрхивироватьКаталог(КаталогИсточник, ПутьАрхива);

    КаталогСжатие   = ПутьTar(КаталогБазы, "src_compress");
    ПутьАрхиваPlain = ПутьTar(КаталогБазы, "archive_plain.tar");
    ПутьАрхиваGzip  = ПутьTar(КаталогБазы, "archive_gzip.tar.gz");

    СоздатьКаталог(КаталогСжатие);

    Фрагмент    = "ABCD1234EFGH5678";
    ТекстСжатия = "";

    Для Индекс = 1 По 2000 Цикл
        ТекстСжатия = ТекстСжатия + Фрагмент;
    КонецЦикла;

    ПолучитьДвоичныеДанныеИзСтроки(ТекстСжатия, "UTF-8").Записать(ПутьTar(КаталогСжатие, "compressible.txt"));
    ПолучитьДвоичныеДанныеИзСтроки(ТекстСжатия, "UTF-8").Записать(ПутьTar(КаталогСжатие, "compressible2.txt"));

    OPI_Tar.АрхивироватьКаталог(КаталогСжатие, ПутьАрхиваPlain);

    НастройкиGzip               = OPI_Tar.ПолучитьСтруктуруНастроекАрхивации(Истина);
    НастройкиGzip["gzip"]       = Истина;
    НастройкиGzip["gzip_level"] = 9;

    OPI_Tar.АрхивироватьКаталог(КаталогСжатие, ПутьАрхиваGzip, НастройкиGzip);

    ОжидаемыеФайлы = Новый Соответствие;
    ОжидаемыеФайлы.Вставить("readme.txt"   , "tar metadata test");
    ОжидаемыеФайлы.Вставить("docs\note.txt", "Nested file");

    ОжидаемыеФайлыСжатие = Новый Соответствие;
    ОжидаемыеФайлыСжатие.Вставить("compressible.txt" , ТекстСжатия);
    ОжидаемыеФайлыСжатие.Вставить("compressible2.txt", ТекстСжатия);

    Параметры = Новый Структура;
    Параметры.Вставить("Tar_BaseDir"            , КаталогБазы);
    Параметры.Вставить("Tar_ArchivePath"        , ПутьАрхива);
    Параметры.Вставить("Tar_ArchivePlainPath"   , ПутьАрхиваPlain);
    Параметры.Вставить("Tar_ArchiveGzipPath"    , ПутьАрхиваGzip);
    Параметры.Вставить("Tar_ExpectedFiles"      , ОжидаемыеФайлы);
    Параметры.Вставить("Tar_ExpectedCompress"   , ОжидаемыеФайлыСжатие);

    OPI_ПолучениеДанныхТестов.ЗаписатьПараметрыАрхива(Параметры);

    Tar_ПолучитьСписокФайлов(Параметры);
    Tar_ПолучитьМетаданные(Параметры);

    OPI_Инструменты.УдалитьФайлВПопытке(КаталогБазы, "Не удалось удалить каталог теста tar");

КонецПроцедуры

#КонецОбласти // ЗапускаемыеТесты

#КонецОбласти // СлужебныйПрограммныйИнтерфейс

