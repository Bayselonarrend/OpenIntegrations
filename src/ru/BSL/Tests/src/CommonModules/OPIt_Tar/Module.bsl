Процедура Tar_ПолучитьСтруктуруНастроекАрхивации()

    Результат = OPI_Tar.ПолучитьСтруктуруНастроекАрхивации();

    // END

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "Tar", "ПолучитьСтруктуруНастроекАрхивации");

    Результат = OPI_Tar.ПолучитьСтруктуруНастроекАрхивации(Истина);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "Tar", "ПолучитьСтруктуруНастроекАрхивации", "Пустая");

    Результат = OPI_Tar.ПолучитьСтруктуруНастроекАрхивации(Ложь, Истина);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "Tar", "ПолучитьСтруктуруНастроекАрхивации", "КакСоответствие");

КонецПроцедуры

Процедура Tar_АрхивироватьКаталог(Параметры)

    OPI_ПолучениеДанныхТестов.ДополнитьПараметрыАрхива(Параметры, "Tar"); // SKIP

    КаталогИсточник = Параметры["Tar_SourceDir"];
    ПутьАрхива      = Параметры["Tar_ArchivePath"];

    Результат = OPI_Tar.АрхивироватьКаталог(КаталогИсточник, ПутьАрхива);

    // END

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "Tar", "АрхивироватьКаталог", , ПутьАрхива);

    Результат = OPI_Tar.АрхивироватьКаталог(КаталогИсточник);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "Tar", "АрхивироватьКаталог", "ВПамять");

    ПутьАрхиваGzip          = Параметры["Tar_ArchiveGzipPath"];
    Настройки               = OPI_Tar.ПолучитьСтруктуруНастроекАрхивации(Истина);
    Настройки["gzip"]       = Истина;
    Настройки["gzip_level"] = 9;

    Результат = OPI_Tar.АрхивироватьКаталог(КаталогИсточник, ПутьАрхиваGzip, Настройки);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "Tar", "АрхивироватьКаталог", "СGzip", ПутьАрхиваGzip);

    Описание       = Параметры["Tar_Description"];
    ПутьАрхиваDesc = Параметры["Tar_ArchiveDescPath"];

    Результат = OPI_Tar.АрхивироватьКаталог(Описание, ПутьАрхиваDesc);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "Tar", "АрхивироватьКаталог", "ИзОписания", ПутьАрхиваDesc);

    Результат = OPI_Tar.АрхивироватьКаталог(Описание);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "Tar", "АрхивироватьКаталог", "ИзОписанияВПамять");

КонецПроцедуры

Процедура Tar_РазархивироватьКаталог(Параметры)

    OPI_ПолучениеДанныхТестов.ДополнитьПараметрыАрхива(Параметры, "Tar"); // SKIP

    ПутьАрхива        = Параметры["Tar_ArchivePath"];
    КаталогНазначение = Параметры["Tar_DestDir"];

    Результат = OPI_Tar.РазархивироватьКаталог(ПутьАрхива, КаталогНазначение);

    // END

    ОжидаемыеФайлы = Параметры["Tar_ExpectedFiles"];

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "Tar", "РазархивироватьКаталог", , КаталогНазначение, ОжидаемыеФайлы);

    Результат = OPI_Tar.РазархивироватьКаталог(ПутьАрхива);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "Tar", "РазархивироватьКаталог", "ВОписание", "", ОжидаемыеФайлы);

    КаталогНазначениеБуфер = Параметры["Tar_DestBufferDir"];
    АрхивДвоичные          = Новый ДвоичныеДанные(ПутьАрхива);

    Результат = OPI_Tar.РазархивироватьКаталог(АрхивДвоичные, КаталогНазначениеБуфер);
    OPI_ПолучениеДанныхТестов.Обработать(Результат
        , "Tar"
        , "РазархивироватьКаталог"
        , "ИзПамяти"
        , КаталогНазначениеБуфер
        , ОжидаемыеФайлы);

    Результат = OPI_Tar.РазархивироватьКаталог(АрхивДвоичные);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "Tar", "РазархивироватьКаталог", "ВОписаниеИзПамяти", "", ОжидаемыеФайлы);

    ПутьАрхиваGzip        = Параметры["Tar_ArchiveGzipPath"];
    КаталогНазначениеGzip = Параметры["Tar_BaseDir"] + ПолучитьРазделительПути() + "out_gzip";
    СоздатьКаталог(КаталогНазначениеGzip);

    Результат = OPI_Tar.РазархивироватьКаталог(ПутьАрхиваGzip, КаталогНазначениеGzip);
    OPI_ПолучениеДанныхТестов.Обработать(Результат
        , "Tar"
        , "РазархивироватьКаталог"
        , "СGzip"
        , КаталогНазначениеGzip
        , ОжидаемыеФайлы);

КонецПроцедуры

Процедура Tar_РазархивироватьФайлы(Параметры)

    OPI_ПолучениеДанныхТестов.ДополнитьПараметрыАрхива(Параметры, "Tar"); // SKIP

    ПутьАрхива        = Параметры["Tar_ArchivePath"];
    КаталогНазначение = Параметры["Tar_DestDir"];
    Пути              = Параметры["Tar_PartialPaths"];

    Результат = OPI_Tar.РазархивироватьФайлы(ПутьАрхива, Пути, КаталогНазначение);

    // END

    ОжидаемыеФайлы = Параметры["Tar_PartialExpected"];

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "Tar", "РазархивироватьФайлы", , КаталогНазначение, ОжидаемыеФайлы);

    Результат = OPI_Tar.РазархивироватьФайлы(ПутьАрхива, Пути);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "Tar", "РазархивироватьФайлы", "ВОписание", "", ОжидаемыеФайлы);

    КаталогНазначениеБуфер = Параметры["Tar_DestBufferDir"];
    АрхивДвоичные          = Новый ДвоичныеДанные(ПутьАрхива);

    Результат = OPI_Tar.РазархивироватьФайлы(АрхивДвоичные, Пути, КаталогНазначениеБуфер);
    OPI_ПолучениеДанныхТестов.Обработать(Результат
        , "Tar"
        , "РазархивироватьФайлы"
        , "ИзПамяти"
        , КаталогНазначениеБуфер
        , ОжидаемыеФайлы);

    Результат = OPI_Tar.РазархивироватьФайлы(АрхивДвоичные, Пути);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "Tar", "РазархивироватьФайлы", "ВОписаниеИзПамяти", "", ОжидаемыеФайлы);

КонецПроцедуры

Процедура Tar_ИзменитьАрхив(Параметры)

    OPI_ПолучениеДанныхТестов.ДополнитьПараметрыАрхива(Параметры, "Tar"); // SKIP

    ПутьАрхива      = Параметры["Tar_ArchivePath"];
    ПутьНовогоФайла = Параметры["Tar_NewFilePath"];

    ДобавляемыеФайлы = Новый Соответствие;
    ДобавляемыеФайлы.Вставить("extra/info.txt", ПутьНовогоФайла);
    ДобавляемыеФайлы.Вставить("readme.txt"    , ПолучитьДвоичныеДанныеИзСтроки("Replaced readme content", "UTF-8"));

    УдаляемыеПути = Новый Массив;
    УдаляемыеПути.Добавить("config/settings.json");

    Результат = OPI_Tar.ИзменитьАрхив(ПутьАрхива, ДобавляемыеФайлы, УдаляемыеПути);

    // END

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "Tar", "ИзменитьАрхив", , ПутьАрхива);

    КаталогНазначение = Параметры["Tar_DestDir"];
    ОжидаемыеФайлы    = Параметры["Tar_ExpectedAfterModify"];

    СписокФайлов = OPI_Tar.ПолучитьСписокФайлов(ПутьАрхива);
    OPI_ПолучениеДанныхТестов.Обработать(СписокФайлов, "Tar", "ПолучитьСписокФайлов", "ПослеИзменения", ОжидаемыеФайлы);

    РезультатРаспаковки = OPI_Tar.РазархивироватьКаталог(ПутьАрхива, КаталогНазначение);
    OPI_ПолучениеДанныхТестов.Обработать(РезультатРаспаковки
        , "Tar"
        , "РазархивироватьКаталог"
        , "ПослеИзменения"
        , КаталогНазначение
        , ОжидаемыеФайлы);

    ПутьАрхиваБуфер = Параметры["Tar_ArchiveBufferPath"];
    КаталогИсточник = Параметры["Tar_SourceDir"];
    OPI_Tar.АрхивироватьКаталог(КаталогИсточник, ПутьАрхиваБуфер);

    АрхивДвоичные  = Новый ДвоичныеДанные(ПутьАрхиваБуфер);
    Результат      = OPI_Tar.ИзменитьАрхив(АрхивДвоичные, ДобавляемыеФайлы, УдаляемыеПути);
    АрхивДляСписка = Результат;

    Если OPI_Инструменты.ЭтоКоллекция(Результат, Истина)
        И OPI_Инструменты.ПолеКоллекцииСуществует(Результат, "result") Тогда

        Результат      = OPI_Tar.ИзменитьАрхив(ПутьАрхиваБуфер, ДобавляемыеФайлы, УдаляемыеПути);
        АрхивДляСписка = ПутьАрхиваБуфер;

        OPI_ПолучениеДанныхТестов.Обработать(Результат, "Tar", "ИзменитьАрхив", "ИзПамятиДиск", ПутьАрхиваБуфер);

    Иначе

        OPI_ПолучениеДанныхТестов.Обработать(Результат, "Tar", "ИзменитьАрхив", "ИзПамяти");

    КонецЕсли;

    СписокФайлов = OPI_Tar.ПолучитьСписокФайлов(АрхивДляСписка);
    OPI_ПолучениеДанныхТестов.Обработать(СписокФайлов, "Tar", "ПолучитьСписокФайлов", "ПослеИзмененияИзПамяти", ОжидаемыеФайлы);

КонецПроцедуры

Процедура Tar_ПолучитьСписокФайлов(Параметры)

    OPI_ПолучениеДанныхТестов.ДополнитьПараметрыАрхива(Параметры, "Tar"); // SKIP

    ПутьАрхива = Параметры["Tar_ArchivePath"];

    Результат = OPI_Tar.ПолучитьСписокФайлов(ПутьАрхива);

    // END

    ОжидаемыеФайлы = Параметры["Tar_ExpectedFiles"];

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "Tar", "ПолучитьСписокФайлов", , ОжидаемыеФайлы);

    АрхивДвоичные = Новый ДвоичныеДанные(ПутьАрхива);

    Результат = OPI_Tar.ПолучитьСписокФайлов(АрхивДвоичные);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "Tar", "ПолучитьСписокФайлов", "ИзПамяти", ОжидаемыеФайлы);

КонецПроцедуры

Процедура Tar_ПолучитьМетаданные(Параметры)

    OPI_ПолучениеДанныхТестов.ДополнитьПараметрыАрхива(Параметры, "Tar"); // SKIP

    ПутьАрхива = Параметры["Tar_ArchivePath"];

    Результат = OPI_Tar.ПолучитьМетаданные(ПутьАрхива);

    // END

    ОжидаемыеФайлы = Параметры["Tar_ExpectedFiles"];

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "Tar", "ПолучитьМетаданные", , ОжидаемыеФайлы);

    АрхивДвоичные = Новый ДвоичныеДанные(ПутьАрхива);

    Результат = OPI_Tar.ПолучитьМетаданные(АрхивДвоичные);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "Tar", "ПолучитьМетаданные", "ИзПамяти", ОжидаемыеФайлы);

    ПутьАрхиваPlain = Параметры["Tar_ArchivePlainPath"];
    ПутьАрхиваGzip  = Параметры["Tar_ArchiveGzipPath"];
    ОжидаемыеСжатие = Параметры["Tar_ExpectedCompress"];

    МетаданныеPlain = OPI_Tar.ПолучитьМетаданные(ПутьАрхиваPlain);
    РазмерPlain     = МетаданныеPlain["archive_size"];

    ОжиданияМетаданных = Новый Структура;
    ОжиданияМетаданных.Вставить("archive_less_than", РазмерPlain);

    Результат = OPI_Tar.ПолучитьМетаданные(ПутьАрхиваGzip);
    OPI_ПолучениеДанныхТестов.Обработать(Результат
        , "Tar"
        , "ПолучитьМетаданные"
        , "СGzip"
        , ОжидаемыеСжатие
        , ОжиданияМетаданных);

КонецПроцедуры

#КонецОбласти // АтомарныеТесты

Функция ПутьTar(БазовыйКаталог, ОтносительныйПуть)

    ОтносительныйПуть = СтрЗаменить(ОтносительныйПуть, "\", "/");
    Возврат СтрШаблон("%1/%2", БазовыйКаталог, ОтносительныйПуть);

КонецФункции

#КонецОбласти // СлужебныеПроцедурыИФункции

