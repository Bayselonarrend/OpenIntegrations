Функция MessagePackБазовыйURLЭталона()

    Возврат СтрШаблон("http://%1:19090", OPI_ПолучениеДанныхТестов.ПолучитьLocalhost());

КонецФункции

Функция MessagePackЭталонУпаковать(БазовыйURL, Данные)

    Запрос = OPI_ЗапросыHTTP.НовыйЗапрос().Инициализировать(БазовыйURL + "/pack");

    Если Данные = Неопределено Тогда

        Запрос = Запрос
            .УстановитьТипДанных("application/json")
            .УстановитьСтроковоеТело("null");

    ИначеЕсли OPI_Инструменты.ЭтоКоллекция(Данные, Истина) Тогда

        Запрос = Запрос.УстановитьJsonТело(Данные);

    Иначе

        Запрос = Запрос
            .УстановитьТипДанных("application/json; charset=utf-8")
            .УстановитьСтроковоеТело(OPI_Инструменты.JSONСтрокой(Данные, "Нет", Ложь));

    КонецЕсли;

    Возврат Запрос.ОбработатьЗапрос("POST").ВернутьОтветКакДвоичныеДанные();

КонецФункции

Функция MessagePackЭталонРаспаковать(БазовыйURL, Двоичные)

    Возврат OPI_ЗапросыHTTP.НовыйЗапрос()
        .Инициализировать(БазовыйURL + "/unpack")
        .УстановитьТипДанных("application/msgpack")
        .УстановитьДвоичноеТело(Двоичные)
        .ОбработатьЗапрос("POST")
        .ВернутьОтветКакJSONКоллекцию();

КонецФункции

Процедура MessagePack_СериализоватьДанные()

    Исходное = Новый Соответствие;
    Исходное.Вставить("title"  , "Пример");
    Исходное.Вставить("count"  , 42);
    Исходное.Вставить("active" , Истина);
    Исходное.Вставить("payload", ПолучитьДвоичныеДанныеИзHexСтроки("DEADBEEF"));

    Вложенная = Новый Соответствие;
    Вложенная.Вставить("label", "nested");
    Вложенная.Вставить("inner", ПолучитьДвоичныеДанныеИзHexСтроки("010203"));
    Исходное.Вставить("nested", Вложенная);

    Мета = Новый Массив;
    Мета.Добавить("tag");
    Мета.Добавить(1);
    Мета.Добавить(Ложь);
    Мета.Добавить(ПолучитьДвоичныеДанныеИзHexСтроки("0A0B"));
    Исходное.Вставить("items", Мета);

    Результат       = OPI_MessagePack.СериализоватьДанные(Исходное);
    Восстановленное = OPI_MessagePack.ДесериализоватьДанные(Результат);

    // END

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "MessagePack", "СериализоватьДанные", , Восстановленное, Исходное);

    ФайлДанных = ПолучитьИмяВременногоФайла("json");
    OPI_Инструменты.ЗаписатьJSONФайл(ФайлДанных, Исходное);

    Если Не Новый Файл(ФайлДанных).Существует() Тогда
        ВызватьИсключение "Файл данных не найден!";
    КонецЕсли;

    Результат       = OPI_MessagePack.СериализоватьДанные(ФайлДанных, Истина);
    Восстановленное = OPI_MessagePack.ДесериализоватьДанные(Результат);

    OPI_Инструменты.УдалитьФайлВПопытке(ФайлДанных, "Не удалось удалить временный файл после теста!");

    // END

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "MessagePack", "СериализоватьДанные", "ИзФайла", Восстановленное, Исходное);

    Результат = OPI_MessagePack.СериализоватьДанные("");
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "MessagePack", "СериализоватьДанные", "ПустаяСтрока");

    Результат = OPI_MessagePack.СериализоватьДанные("a");

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "MessagePack", "СериализоватьДанные", "СтрокаFixstr");

    Результат = OPI_MessagePack.СериализоватьДанные("Привет");

    Восстановленное = OPI_MessagePack.ДесериализоватьДанные(Результат);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "MessagePack", "СериализоватьДанные", "СтрокаUTF8", Восстановленное);

    Результат = OPI_MessagePack.СериализоватьДанные(0);

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "MessagePack", "СериализоватьДанные", "Целое0");

    Результат = OPI_MessagePack.СериализоватьДанные(127);

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "MessagePack", "СериализоватьДанные", "Целое127");

    Результат = OPI_MessagePack.СериализоватьДанные(128);

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "MessagePack", "СериализоватьДанные", "Uint8");

    Данные    = -1;
    Результат = OPI_MessagePack.СериализоватьДанные(Данные);

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "MessagePack", "СериализоватьДанные", "ОтрицательноеFixint");

    Данные    = -33;
    Результат = OPI_MessagePack.СериализоватьДанные(Данные);

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "MessagePack", "СериализоватьДанные", "Int8");

    Исходное  = 0.2;
    Результат = OPI_MessagePack.СериализоватьДанные(Исходное);

    Восстановленное = OPI_MessagePack.ДесериализоватьДанные(Результат);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "MessagePack", "СериализоватьДанные", "Вещественное", Восстановленное, Исходное);

    Результат = OPI_MessagePack.СериализоватьДанные(Неопределено);

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "MessagePack", "СериализоватьДанные", "Nil");

    Результат = OPI_MessagePack.СериализоватьДанные(Истина);

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "MessagePack", "СериализоватьДанные", "Истина");

    Результат = OPI_MessagePack.СериализоватьДанные(Ложь);

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "MessagePack", "СериализоватьДанные", "Ложь");

    Данные    = ПолучитьДвоичныеДанныеИзHexСтроки("");
    Результат = OPI_MessagePack.СериализоватьДанные(Данные);

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "MessagePack", "СериализоватьДанные", "ПустойБинарник");

    Данные    = ПолучитьДвоичныеДанныеИзHexСтроки("010203");
    Результат = OPI_MessagePack.СериализоватьДанные(Данные);

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "MessagePack", "СериализоватьДанные", "БинарникBin8");

    Массив    = Новый Массив;
    Результат = OPI_MessagePack.СериализоватьДанные(Массив);

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "MessagePack", "СериализоватьДанные", "ПустойМассив");

    Массив    = Новый Массив;
    Массив.Добавить(1);
    Массив.Добавить(2);
    Массив.Добавить(3);
    Результат = OPI_MessagePack.СериализоватьДанные(Массив);

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "MessagePack", "СериализоватьДанные", "МассивТриЧисла");

    Карта     = Новый Соответствие;
    Результат = OPI_MessagePack.СериализоватьДанные(Карта);

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "MessagePack", "СериализоватьДанные", "ПустаяКарта");

    Структура = Новый Структура("a", 1);
    Результат = OPI_MessagePack.СериализоватьДанные(Структура);

    OPI_ПолучениеДанныхТестов.Обработать(Результат, "MessagePack", "СериализоватьДанные", "КартаОднаПара");

    Карта     = Новый Соответствие;
    Карта.Вставить("x", 10);
    Карта.Вставить("y", 20);
    Результат = OPI_MessagePack.СериализоватьДанные(Карта);

    Восстановленное = OPI_MessagePack.ДесериализоватьДанные(Результат);
    OPI_ПолучениеДанныхТестов.Обработать(Результат, "MessagePack", "СериализоватьДанные", "КартаДвеПары", Восстановленное);

КонецПроцедуры

