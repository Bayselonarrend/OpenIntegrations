Процедура Z7_ПолучениеМетаданных() Экспорт

    КаталогБазы = КаталогВременныхФайлов()
        + "\opi_sevenz_meta_"
        + Формат(ТекущаяУниверсальнаяДатаВМиллисекундах(), "ЧГ=0");

    СоздатьКаталог(КаталогБазы);

    КаталогИсточник = Путь7z(КаталогБазы, "src");
    ПутьАрхива      = Путь7z(КаталогБазы, "archive.7z");

    СоздатьКаталог(КаталогИсточник);

    ОжидаемыеФайлы = Новый Соответствие;

    ОжидаемыеФайлы.Вставить("readme.txt", "7z metadata test");
    ПолучитьДвоичныеДанныеИзСтроки("7z metadata test", "UTF-8").Записать(Путь7z(КаталогИсточник, "readme.txt"));

    СоздатьКаталог(Путь7z(КаталогИсточник, "docs"));
    ОжидаемыеФайлы.Вставить("docs\note.txt", "Nested file");
    ПолучитьДвоичныеДанныеИзСтроки("Nested file", "UTF-8").Записать(Путь7z(КаталогИсточник, "docs\note.txt"));

    OPI_7z.АрхивироватьКаталог(КаталогИсточник, ПутьАрхива);

    Параметры = Новый Структура;
    Параметры.Вставить("SevenZ_ArchivePath"  , ПутьАрхива);
    Параметры.Вставить("SevenZ_ExpectedFiles", ОжидаемыеФайлы);

    Z7_ПолучитьСписокФайлов(Параметры);
    Z7_ПолучитьМетаданные(Параметры);

    КаталогСжатие   = Путь7z(КаталогБазы, "src_compress");
    ПутьАрхиваCopy  = Путь7z(КаталогБазы, "archive_copy.7z");
    ПутьАрхиваLzma  = Путь7z(КаталогБазы, "archive_lzma.7z");
    ПутьФайлаСжатия = Путь7z(КаталогСжатие, "compressible.txt");

    СоздатьКаталог(КаталогСжатие);

    ОжидаемыеФайлыСжатие = Новый Соответствие;

    Фрагмент    = "ABCD1234EFGH5678";
    ТекстСжатия = "";

    Для Индекс = 1 По 2000 Цикл
        ТекстСжатия = ТекстСжатия + Фрагмент;
    КонецЦикла;

    ОжидаемыеФайлыСжатие.Вставить("compressible.txt" , ТекстСжатия);
    ОжидаемыеФайлыСжатие.Вставить("compressible2.txt", ТекстСжатия);
    ПолучитьДвоичныеДанныеИзСтроки(ТекстСжатия, "UTF-8").Записать(ПутьФайлаСжатия);
    ПолучитьДвоичныеДанныеИзСтроки(ТекстСжатия, "UTF-8").Записать(Путь7z(КаталогСжатие, "compressible2.txt"));

    ПараметрыСжатие = Новый Структура;
    ПараметрыСжатие.Вставить("SevenZ_SourceDirCompress", КаталогСжатие);
    ПараметрыСжатие.Вставить("SevenZ_ArchiveCopyPath"  , ПутьАрхиваCopy);
    ПараметрыСжатие.Вставить("SevenZ_ArchiveLzmaPath"  , ПутьАрхиваLzma);
    ПараметрыСжатие.Вставить("SevenZ_ExpectedFiles"    , ОжидаемыеФайлыСжатие);

    Z7_АрхивироватьКаталог(ПараметрыСжатие);
    Z7_ПолучитьМетаданные(ПараметрыСжатие);

    OPI_Инструменты.УдалитьФайлВПопытке(КаталогБазы, "Не удалось удалить каталог теста 7z");

КонецПроцедуры

