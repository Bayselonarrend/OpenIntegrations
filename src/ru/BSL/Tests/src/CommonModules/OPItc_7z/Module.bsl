КонецПроцедуры

Процедура Z7_РазархивироватьФайлы(Параметры)

    ПутьАрхива             = Параметры["SevenZ_ArchivePath"];
    КаталогНазначение      = Параметры["SevenZ_DestDir"];
    КаталогНазначениеБуфер = Параметры["SevenZ_DestBufferDir"];
    ПутиЧастичные          = Параметры["SevenZ_PartialPaths"];
    ОжидаемыеФайлы         = Параметры["SevenZ_PartialExpected"];

    Опции = Новый Структура;
    Опции.Вставить("src", ПутьАрхива);
    Опции.Вставить("paths", ПутиЧастичные);
    Опции.Вставить("dest", КаталогНазначение);

    Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("7z", "РазархивироватьФайлы", Опции);

    // END

    OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "7z", "РазархивироватьФайлы", , КаталогНазначение, ОжидаемыеФайлы);

    Опции = Новый Структура;
    Опции.Вставить("src", ПутьАрхива);
    Опции.Вставить("paths", ПутиЧастичные);

    Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("7z", "РазархивироватьФайлы", Опции);
    OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "7z", "РазархивироватьФайлы", "ВОписание", "", ОжидаемыеФайлы);

    АрхивДвоичные = Новый ДвоичныеДанные(ПутьАрхива);

    Опции = Новый Структура;
    Опции.Вставить("src", АрхивДвоичные);
    Опции.Вставить("paths", ПутиЧастичные);
    Опции.Вставить("dest", КаталогНазначениеБуфер);

    Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("7z", "РазархивироватьФайлы", Опции);
    OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "7z", "РазархивироватьФайлы", "ИзПамяти", КаталогНазначениеБуфер, ОжидаемыеФайлы);

    Опции = Новый Структура;
    Опции.Вставить("src", АрхивДвоичные);
    Опции.Вставить("paths", ПутиЧастичные);

    Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("7z", "РазархивироватьФайлы", Опции);
    OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "7z", "РазархивироватьФайлы", "ВОписаниеИзПамяти", "", ОжидаемыеФайлы);

КонецПроцедуры

Процедура Z7_ИзменитьАрхив(Параметры)

    ПутьАрхива        = Параметры["SevenZ_ArchivePath"];
    ПутьАрхиваБуфер   = Параметры["SevenZ_ArchiveBufferPath"];
    КаталогНазначение = Параметры["SevenZ_DestDir"];
    ПутьНовогоФайла   = Параметры["SevenZ_NewFilePath"];
    ОжидаемыеФайлы    = Параметры["SevenZ_ExpectedAfterModify"];

    ДобавляемыеФайлы = Новый Соответствие;
    ДобавляемыеФайлы.Вставить("extra/info.txt", ПутьНовогоФайла);
    ДобавляемыеФайлы.Вставить("readme.txt"    , ПолучитьДвоичныеДанныеИзСтроки("Replaced readme content", "UTF-8"));

    УдаляемыеПути = Новый Массив;
    УдаляемыеПути.Добавить("config/settings.json");
    УдаляемыеПути.Добавить("missing/path.txt");

    Опции = Новый Структура;
    Опции.Вставить("src", ПутьАрхива);
    Опции.Вставить("additions", ДобавляемыеФайлы);
    Опции.Вставить("deletions", УдаляемыеПути);

    Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("7z", "ИзменитьАрхив", Опции);

    // END

    OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "7z", "ИзменитьАрхив", , ПутьАрхива);

    Опции = Новый Структура;
    Опции.Вставить("src", ПутьАрхива);

    СписокФайлов = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("7z", "ПолучитьСписокФайлов", Опции);
    OPI_ПолучениеДанныхТестов.ОбработатьCLI(СписокФайлов, "7z", "ПолучитьСписокФайлов", "ПослеИзменения", ОжидаемыеФайлы);

    Опции = Новый Структура;
    Опции.Вставить("src", ПутьАрхива);
    Опции.Вставить("dest", КаталогНазначение);

    РезультатРаспаковки = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("7z", "РазархивироватьКаталог", Опции);
    OPI_ПолучениеДанныхТестов.ОбработатьCLI(РезультатРаспаковки, "7z", "РазархивироватьКаталог", "ПослеИзменения", КаталогНазначение, ОжидаемыеФайлы);

    АрхивДвоичные = Новый ДвоичныеДанные(ПутьАрхиваБуфер);

    Опции = Новый Структура;
    Опции.Вставить("src", АрхивДвоичные);
    Опции.Вставить("additions", ДобавляемыеФайлы);
    Опции.Вставить("deletions", УдаляемыеПути);

    Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("7z", "ИзменитьАрхив", Опции);
    OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "7z", "ИзменитьАрхив", "ИзПамяти");

    Опции = Новый Структура;
    Опции.Вставить("src", Результат);

    СписокФайлов = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("7z", "ПолучитьСписокФайлов", Опции);
    OPI_ПолучениеДанныхТестов.ОбработатьCLI(СписокФайлов, "7z", "ПолучитьСписокФайлов", "ПослеИзмененияИзПамяти", ОжидаемыеФайлы);

КонецПроцедуры

