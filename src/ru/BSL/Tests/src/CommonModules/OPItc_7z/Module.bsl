    OPI_7z.АрхивироватьКаталог(КаталогИсточник, ПутьАрхива);
    КопироватьФайл(ПутьАрхива, ПутьАрхиваБуфер);

    ПолучитьДвоичныеДанныеИзСтроки("Added via path", "UTF-8").Записать(ПутьНовогоФайла);

    ОжидаемыеПослеИзменения = Новый Соответствие;
    ОжидаемыеПослеИзменения.Вставить("readme.txt"             , "Replaced readme content");
    ОжидаемыеПослеИзменения.Вставить("docs\note.txt"          , "Nested documentation");
    ОжидаемыеПослеИзменения.Вставить("data\nested\payload.bin", ОписаниеБинарника);
    ОжидаемыеПослеИзменения.Вставить("extra\info.txt"         , "Added via path");

    Параметры = Новый Структура;
    Параметры.Вставить("SevenZ_ArchivePath"        , ПутьАрхива);
    Параметры.Вставить("SevenZ_ArchiveBufferPath"  , ПутьАрхиваБуфер);
    Параметры.Вставить("SevenZ_DestDir"            , КаталогНазначение);
    Параметры.Вставить("SevenZ_NewFilePath"        , ПутьНовогоФайла);
    Параметры.Вставить("SevenZ_ExpectedAfterModify", ОжидаемыеПослеИзменения);

    Z7_ИзменитьАрхив(Параметры);

    OPI_Инструменты.УдалитьФайлВПопытке(КаталогБазы, "Не удалось удалить каталог теста 7z");

КонецПроцедуры

