Процедура Z7_АрхивироватьКаталог(Параметры)

    Если Параметры.Свойство("SevenZ_SourceDir") И Параметры.Свойство("SevenZ_ArchivePath") Тогда

        КаталогИсточник = Параметры["SevenZ_SourceDir"];
        ПутьАрхива      = Параметры["SevenZ_ArchivePath"];

        Опции = Новый Структура;
        Опции.Вставить("src", КаталогИсточник);
        Опции.Вставить("dest", ПутьАрхива);

        Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("7z", "АрхивироватьКаталог", Опции);

        // END

        OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "7z", "АрхивироватьКаталог", , ПутьАрхива);

        Опции = Новый Структура;
        Опции.Вставить("src", КаталогИсточник);

        Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("7z", "АрхивироватьКаталог", Опции);
        OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "7z", "АрхивироватьКаталог", "ВПамять");

        Описание       = Параметры["SevenZ_Description"];
        ПутьАрхиваDesc = Параметры["SevenZ_ArchiveDescPath"];

        Опции = Новый Структура;
        Опции.Вставить("src", Описание);
        Опции.Вставить("dest", ПутьАрхиваDesc);

        Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("7z", "АрхивироватьКаталог", Опции);
        OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "7z", "АрхивироватьКаталог", "ИзОписания", ПутьАрхиваDesc);

        Опции = Новый Структура;
        Опции.Вставить("src", Описание);

        Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("7z", "АрхивироватьКаталог", Опции);
        OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "7z", "АрхивироватьКаталог", "ИзОписанияВПамять");

    КонецЕсли;

    Если Параметры.Свойство("SevenZ_Password") Тогда

        КаталогИсточник          = Параметры["SevenZ_SourceDir"];
        Пароль                   = Параметры["SevenZ_Password"];
        ПутьАрхиваПароль         = Параметры["SevenZ_ArchivePasswordPath"];
        Опции = Новый Структура;
        Опции.Вставить("empty", Истина);

        Настройки = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("7z", "ПолучитьСтруктуруНастроекАрхивации", Опции);
        Настройки.password       = Пароль;
        Настройки.encrypt_header = Истина;

        Опции = Новый Структура;
        Опции.Вставить("src", КаталогИсточник);
        Опции.Вставить("dest", ПутьАрхиваПароль);
        Опции.Вставить("settings", Настройки);

        Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("7z", "АрхивироватьКаталог", Опции);
        OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "7z", "АрхивироватьКаталог", "СПаролем", ПутьАрхиваПароль);

    КонецЕсли;

    Если Параметры.Свойство("SevenZ_SourceDirCompress") Тогда

        КаталогСжатие  = Параметры["SevenZ_SourceDirCompress"];
        ПутьАрхиваCopy = Параметры["SevenZ_ArchiveCopyPath"];
        ПутьАрхиваLzma = Параметры["SevenZ_ArchiveLzmaPath"];

        Опции = Новый Структура;
        Опции.Вставить("empty", Истина);

        НастройкиCopy = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("7z", "ПолучитьСтруктуруНастроекАрхивации", Опции);
        НастройкиCopy.method = "Copy";

        Опции = Новый Структура;
        Опции.Вставить("src", КаталогСжатие);
        Опции.Вставить("dest", ПутьАрхиваCopy);
        Опции.Вставить("settings", НастройкиCopy);

        Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("7z", "АрхивироватьКаталог", Опции);
        OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "7z", "АрхивироватьКаталог", "Copy", ПутьАрхиваCopy);

        Опции = Новый Структура;
        Опции.Вставить("empty", Истина);

        НастройкиLzma = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("7z", "ПолучитьСтруктуруНастроекАрхивации", Опции);
        НастройкиLzma.method = "Lzma2";
        НастройкиLzma.level  = 9;
        НастройкиLzma.solid  = Истина;

        Опции = Новый Структура;
        Опции.Вставить("src", КаталогСжатие);
        Опции.Вставить("dest", ПутьАрхиваLzma);
        Опции.Вставить("settings", НастройкиLzma);

        Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("7z", "АрхивироватьКаталог", Опции);
        OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "7z", "АрхивироватьКаталог", "Lzma2Solid", ПутьАрхиваLzma);

    КонецЕсли;

КонецПроцедуры

Процедура Z7_РазархивироватьКаталог(Параметры)

    Если Параметры.Свойство("SevenZ_ArchivePath") Тогда

        ПутьАрхива             = Параметры["SevenZ_ArchivePath"];
        КаталогНазначение      = Параметры["SevenZ_DestDir"];
        КаталогНазначениеБуфер = Параметры["SevenZ_DestBufferDir"];
        ОжидаемыеФайлы         = Параметры["SevenZ_ExpectedFiles"];

        Опции = Новый Структура;
        Опции.Вставить("src", ПутьАрхива);
        Опции.Вставить("dest", КаталогНазначение);

        Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("7z", "РазархивироватьКаталог", Опции);

        // END

        OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "7z", "РазархивироватьКаталог", , КаталогНазначение, ОжидаемыеФайлы);

        Опции = Новый Структура;
        Опции.Вставить("src", ПутьАрхива);

        Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("7z", "РазархивироватьКаталог", Опции);
        OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "7z", "РазархивироватьКаталог", "ВОписание", "", ОжидаемыеФайлы);

        АрхивДвоичные = Новый ДвоичныеДанные(ПутьАрхива);

        Опции = Новый Структура;
        Опции.Вставить("src", АрхивДвоичные);
        Опции.Вставить("dest", КаталогНазначениеБуфер);

        Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("7z", "РазархивироватьКаталог", Опции);
        OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "7z", "РазархивироватьКаталог", "ИзПамяти", КаталогНазначениеБуфер, ОжидаемыеФайлы);

        Опции = Новый Структура;
        Опции.Вставить("src", АрхивДвоичные);

        Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("7z", "РазархивироватьКаталог", Опции);
        OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "7z", "РазархивироватьКаталог", "ВОписаниеИзПамяти", "", ОжидаемыеФайлы);

    КонецЕсли;

    Если Параметры.Свойство("SevenZ_Password") Тогда

        Пароль           = Параметры["SevenZ_Password"];
        ПутьАрхиваПароль = Параметры["SevenZ_ArchivePasswordPath"];
        ОжидаемыеФайлы   = Параметры["SevenZ_ExpectedFiles"];
        КаталогПароль    = Путь7z(Параметры["SevenZ_BaseDir"], "out_pwd");

        СоздатьКаталог(КаталогПароль);

        Опции = Новый Структура;
        Опции.Вставить("src", ПутьАрхиваПароль);
        Опции.Вставить("dest", КаталогПароль);
        Опции.Вставить("password", Пароль);

        Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("7z", "РазархивироватьКаталог", Опции);
        OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "7z", "РазархивироватьКаталог", "СПаролем", КаталогПароль, ОжидаемыеФайлы);

        АрхивПароль = Новый ДвоичныеДанные(ПутьАрхиваПароль);

        Опции = Новый Структура;
        Опции.Вставить("src", АрхивПароль);
        Опции.Вставить("dest", "");
        Опции.Вставить("password", Пароль);

        Результат = OPI_ПолучениеДанныхТестов.ВыполнитьТестCLI("7z", "РазархивироватьКаталог", Опции);
        OPI_ПолучениеДанныхТестов.ОбработатьCLI(Результат, "7z", "РазархивироватьКаталог", "ВОписаниеСПаролем", "", ОжидаемыеФайлы);

    КонецЕсли;

