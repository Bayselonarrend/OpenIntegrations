    OPI_ПолучениеДанныхТестов.Обработать(Проверка, "ZeroMQ", "СоздатьСоединениеSub", "Проверка", Сообщение);
    
    OPI_ZeroMQ.ЗакрытьСоединение(ОбъектСервера);
    OPI_ZeroMQ.ЗакрытьСоединение(Результат);

