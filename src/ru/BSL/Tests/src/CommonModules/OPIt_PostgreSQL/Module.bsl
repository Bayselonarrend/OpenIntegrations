    СтруктураКолонок.Вставить("id"    , "INT PRIMARY KEY"); // SKIP
    СтруктураКолонок.Вставить("name"  , "TEXT");            // SKIP
    СтруктураКолонок.Вставить("age"   , "INT");             // SKIP
