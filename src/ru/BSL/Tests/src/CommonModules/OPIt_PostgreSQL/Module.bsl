    OPI_ПолучениеДанныхТестов.Обработать(Проверка, "PostgreSQL", "ГарантироватьЗаписи", "Проверка обновления");

    OPI_PostgreSQL.УдалитьТаблицу(Таблица, СтрокаПодключения, НастройкиTLS);

